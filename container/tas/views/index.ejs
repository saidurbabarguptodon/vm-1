<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Emerald Theme</title>
    <style>
        /* Color Palette & Basic Reset */
        :root {
            --emerald: #10B981;
            --emerald-light: #d1fae5;
            --white: #ffffff;
            --bg-color: #f8fafc;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            overflow-x: hidden; 
        }

        /* ----- HEADER ----- */
        header {
            background-color: var(--emerald);
            height: 80px;
            
            /* Made bottom two corners LESS round */
            border-bottom-left-radius: 15px;
            border-bottom-right-radius: 15px;
            
            display: flex;
            align-items: center;
            justify-content: flex-end; 
            padding: 0 30px;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
            
            position: sticky;
            top: 0;
            z-index: 100; /* Lower z-index than sidebar */
        }

        /* Sidebar Toggle Button */
        #menu-btn {
            background: none;
            border: none;
            color: var(--white);
            font-size: 32px;
            cursor: pointer;
            transition: transform 0.2s ease;
        }

        #menu-btn:hover {
            transform: scale(1.1);
        }

        /* ----- FLOATING SIDEBAR ----- */
        #sidebar {
            position: fixed;
            
            /* Moved UP so it aligns near the top of the screen, NOT below the header */
            top: 16px; 
            left: 16px; 
            width: 260px;
            
            /* Adjusted height to maintain a gap at the bottom */
            height: calc(100vh - 32px); 
            
            background-color: var(--white);
            border-radius: 24px; /* All four corners rounded */
            
            box-shadow: 0 10px 30px rgba(16, 185, 129, 0.25);
            border: 2px solid var(--emerald-light);
            
            padding: 24px;
            
            /* High z-index to stay ABOVE the header */
            z-index: 1000; 
            
            transform: translateX(-150%);
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        #sidebar.open {
            transform: translateX(0);
        }

        .sidebar-title {
            color: var(--emerald);
            font-size: 20px;
            margin-bottom: 20px;
            text-align: center;
        }

    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <button id="menu-btn">☰</button>
    </header>

    <!-- Floating Sidebar -->
    <nav id="sidebar">
        <h3 class="sidebar-title">Menu</h3>
    </nav>

    <!-- Script to handle sidebar toggle -->
    <script>
        const menuBtn = document.getElementById('menu-btn');
        const sidebar = document.getElementById('sidebar');

        menuBtn.addEventListener('click', (event) => {
            sidebar.classList.toggle('open');
            // Prevent the click from immediately bubbling up to the document
            event.stopPropagation();
        });

        document.addEventListener('click', (event) => {
            if (!sidebar.contains(event.target) && !menuBtn.contains(event.target)) {
                sidebar.classList.remove('open');
            }
        });
    </script>

</body>
</html>
