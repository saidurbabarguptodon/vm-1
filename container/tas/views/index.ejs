<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Black & Dark Theme App</title>
    
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        /* Updated Color Palette for Dark Theme */
        :root {
            --green: #1ad76f;
            --yellow: #FBBF24;
            --red: #EF4444;
            --blue: #3B82F6;
            
            /* Dark Mode Variables */
            --bg-body: #121212;
            --bg-surface: #1E1E1E;
            --bg-header: #000000;
            --text-main: #F1F5F9;
            --text-muted: #94A3B8;
            --border-color: #2a2a2a;
            --hover-bg: rgba(255, 255, 255, 0.08);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            overflow-x: hidden; 
        }

        /* ----- HEADER ----- */
        header {
            /* Changed header to black */
            background-color: var(--bg-header);
            height: 80px;
            
            display: flex;
            align-items: center;
            justify-content: flex-end; 
            padding: 0 30px;
            
            /* Added line and shadow at the bottom */
            border-bottom: 1px solid var(--border-color);
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.6); 
            
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* Sidebar Toggle Button */
        #menu-btn {
            background: none;
            border: none;
            color: #ffffff;
            font-size: 36px;
            cursor: pointer;
            transition: transform 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #menu-btn:hover {
            transform: scale(1.1);
        }

        /* ----- BACKGROUND OVERLAY (FREEZE EFFECT) ----- */
        #overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.7);
            z-index: 900; /* Below sidebar, above header */
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        #overlay.show {
            opacity: 1;
            pointer-events: auto;
        }

        /* ----- FLOATING SIDEBAR ----- */
        #sidebar {
            position: fixed;
            
            /* Made top and bottom gap identical */
            top: 24px; 
            bottom: 24px; 
            left: 16px; 
            width: 320px; 
            height: auto; 
            overflow-y: auto; 
            
            background-color: var(--bg-surface);
            border-radius: 24px; 
            
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
            
            padding: 24px;
            z-index: 1000; 
            
            transform: translateX(-150%);
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        #sidebar.open {
            transform: translateX(0);
        }

        /* Custom Scrollbar for sidebar */
        #sidebar::-webkit-scrollbar {
            width: 5px;
        }
        #sidebar::-webkit-scrollbar-thumb {
            background-color: var(--text-muted);
            border-radius: 10px;
        }

        .sidebar-title {
            color: var(--green); 
            font-size: 22px;
            margin-bottom: 24px;
            text-align: center;
            font-weight: 600;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            text-decoration: none;
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 8px;
            font-size: 16px;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
        }

        .sidebar-link:hover {
            background-color: var(--hover-bg);
            color: var(--text-main);
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <button id="menu-btn">
            <i class="bi bi-list"></i>
        </button>
    </header>

    <!-- Overlay Element to freeze background -->
    <div id="overlay"></div>

    <!-- Floating Sidebar -->
    <nav id="sidebar">
        <h3 class="sidebar-title">Menu</h3>
        
        <a href="#" class="sidebar-link">
            <i class="bi bi-house-door" style="color: var(--blue);"></i> Home
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-star" style="color: var(--yellow);"></i> Favorites
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-bell" style="color: var(--red);"></i> Notifications
        </a>
    </nav>

    <!-- Script to handle sidebar & background freeze -->
    <script>
        const menuBtn = document.getElementById('menu-btn');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');

        function toggleSidebar(forceOpen) {
            const isOpen = forceOpen !== undefined ? forceOpen : !sidebar.classList.contains('open');
            
            if (isOpen) {
                sidebar.classList.add('open');
                overlay.classList.add('show');
                document.body.style.overflow = 'hidden'; // Freezes the main web page scrolling
            } else {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
                document.body.style.overflow = ''; // Unfreezes the main web page
            }
        }

        menuBtn.addEventListener('click', (event) => {
            toggleSidebar();
            event.stopPropagation();
        });

        // Tapping anywhere on the dark overlay closes the menu
        overlay.addEventListener('click', () => {
            toggleSidebar(false);
        });
    </script>

</body>
</html>
