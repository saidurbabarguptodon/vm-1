<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Light & Green Theme App</title>
    
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        /* Updated Color Palette for Light Theme */
        :root {
            /* Requested Green */
            --theme-green: #24cd77;
            
            --yellow: #FBBF24;
            --red: #EF4444;
            --blue: #3B82F6;
            
            /* Light Theme Variables */
            --bg-body: #ffffff; 
            --bg-surface: #ffffff; 
            
            --text-main: #111827; /* Dark text for readability on white */
            --text-muted: #4B5563; /* Gray text for secondary information */
            --hover-bg: #f3f4f6; /* Light gray for hover effects */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            overflow-x: hidden; 
        }

        /* ----- HEADER ----- */
        header {
            /* Changed to the requested green */
            background-color: var(--theme-green);
            height: 80px;
            
            display: flex;
            align-items: center;
            justify-content: flex-end; 
            padding: 0 30px;
            
            /* Straight corners as requested previously, with a matching soft shadow */
            box-shadow: 0 4px 16px rgba(36, 205, 119, 0.3); 
            
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* Sidebar Toggle Button */
        #menu-btn {
            background: none;
            border: none;
            color: #ffffff; /* Keeping icon white for contrast against green header */
            font-size: 36px;
            cursor: pointer;
            transition: transform 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #menu-btn:hover {
            transform: scale(1.1);
        }

        /* ----- BACKGROUND OVERLAY (FREEZE EFFECT) ----- */
        #overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            /* Solid dark overlay background */
            background: rgba(0, 0, 0, 0.6);
            
            z-index: 900; /* Below sidebar, above header */
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        #overlay.show {
            opacity: 1;
            pointer-events: auto;
        }

        /* ----- FLOATING SIDEBAR ----- */
        #sidebar {
            position: fixed;
            
            top: 24px; 
            bottom: 24px; 
            left: 16px; 
            width: 320px; 
            height: auto; 
            overflow-y: auto; 
            
            background-color: var(--bg-surface);
            
            /* Moderately round corners */
            border-radius: 16px; 
            
            /* Softer shadow suitable for a white background */
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            
            padding: 24px;
            z-index: 1000; 
            
            transform: translateX(-150%);
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        #sidebar.open {
            transform: translateX(0);
        }

        /* Custom Scrollbar for sidebar */
        #sidebar::-webkit-scrollbar {
            width: 5px;
        }
        #sidebar::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 10px;
        }

        .sidebar-title {
            color: var(--theme-green); 
            font-size: 22px;
            margin-bottom: 24px;
            text-align: center;
            font-weight: 700;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            text-decoration: none;
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 8px;
            font-size: 16px;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
        }

        .sidebar-link:hover {
            background-color: var(--hover-bg);
            color: var(--text-main);
        }
        
        /* Placeholder content */
        .content-demo {
            padding: 40px;
            line-height: 1.8;
        }
        
        .content-demo h1 {
            color: var(--text-main);
            margin-bottom: 16px;
        }
        
        .content-demo p {
            color: var(--text-muted);
            margin-bottom: 16px;
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <button id="menu-btn">
            <i class="bi bi-list"></i>
        </button>
    </header>

    <!-- Demo content -->
    <div class="content-demo">
        <h1>Welcome to the Dashboard</h1>
        <p>Click the menu button in the top right to open the sidebar. Notice how the background freezes cleanly.</p>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
    </div>

    <!-- Overlay Element to freeze background -->
    <div id="overlay"></div>

    <!-- Floating Sidebar -->
    <nav id="sidebar">
        <h3 class="sidebar-title">Menu</h3>
        
        <a href="#" class="sidebar-link">
            <i class="bi bi-house-door" style="color: var(--blue);"></i> Home
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-star" style="color: var(--yellow);"></i> Favorites
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-bell" style="color: var(--red);"></i> Notifications
        </a>
    </nav>

    <!-- Script to handle sidebar & background freeze -->
    <script>
        const menuBtn = document.getElementById('menu-btn');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');

        function toggleSidebar(forceOpen) {
            const isOpen = forceOpen !== undefined ? forceOpen : !sidebar.classList.contains('open');
            
            if (isOpen) {
                sidebar.classList.add('open');
                overlay.classList.add('show');
                document.body.style.overflow = 'hidden'; // Freezes the main web page scrolling
            } else {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
                document.body.style.overflow = ''; // Unfreezes the main web page
            }
        }

        menuBtn.addEventListener('click', (event) => {
            toggleSidebar();
            event.stopPropagation();
        });

        // Tapping anywhere on the dark overlay closes the menu
        overlay.addEventListener('click', () => {
            toggleSidebar(false);
        });
    </script>

</body>
</html>
