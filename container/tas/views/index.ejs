<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dark Gray & Green Theme App</title>
    
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        /* Updated Color Palette */
        :root {
            --green: #1ad76f;
            --yellow: #FBBF24;
            --red: #EF4444;
            --blue: #3B82F6;
            
            /* Unified Gray for Body and Header */
            --bg-gray: #1f1f1f; 
            /* Slightly lighter gray for the sidebar so it pops out */
            --bg-surface: #2c2c2c; 
            
            --text-main: #F1F5F9;
            --text-muted: #94A3B8;
            --hover-bg: rgba(255, 255, 255, 0.08);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-gray);
            color: var(--text-main);
            overflow-x: hidden; 
        }

        /* ----- HEADER ----- */
        header {
            background-color: var(--bg-gray);
            height: 80px;
            
            display: flex;
            align-items: center;
            justify-content: flex-end; 
            padding: 0 30px;
            
            /* Rounded corners at the bottom */
            border-bottom-left-radius: 24px;
            border-bottom-right-radius: 24px;
            
            /* 
               FIX FOR THINNING CORNERS:
               Using a 1px solid box-shadow instead of border-bottom.
               Borders naturally taper off on curved corners, but a shadow keeps a uniform thickness perfectly.
               Combined with the glowing green shadow underneath.
            */
            box-shadow: 
                0 1px 0 0 var(--green), 
                0 8px 24px rgba(26, 215, 111, 0.15); 
            
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* Sidebar Toggle Button */
        #menu-btn {
            background: none;
            border: none;
            color: #ffffff;
            font-size: 36px;
            cursor: pointer;
            transition: transform 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #menu-btn:hover {
            transform: scale(1.1);
        }

        /* ----- BACKGROUND OVERLAY (FREEZE EFFECT - REVERTED TO PREVIOUS) ----- */
        #overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            /* Solid dark background without the blur effect */
            background: rgba(0, 0, 0, 0.7);
            
            z-index: 900; /* Below sidebar, above header */
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        #overlay.show {
            opacity: 1;
            pointer-events: auto;
        }

        /* ----- FLOATING SIDEBAR ----- */
        #sidebar {
            position: fixed;
            
            top: 24px; 
            bottom: 24px; 
            left: 16px; 
            width: 320px; 
            height: auto; 
            overflow-y: auto; 
            
            background-color: var(--bg-surface);
            
            /* Made the corners less round as requested (changed from 32px to 16px) */
            border-radius: 16px; 
            
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
            
            padding: 24px;
            z-index: 1000; 
            
            transform: translateX(-150%);
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        #sidebar.open {
            transform: translateX(0);
        }

        /* Custom Scrollbar for sidebar */
        #sidebar::-webkit-scrollbar {
            width: 5px;
        }
        #sidebar::-webkit-scrollbar-thumb {
            background-color: var(--text-muted);
            border-radius: 10px;
        }

        .sidebar-title {
            color: var(--green); 
            font-size: 22px;
            margin-bottom: 24px;
            text-align: center;
            font-weight: 600;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            text-decoration: none;
            padding: 14px 16px;
            border-radius: 12px;
            margin-bottom: 8px;
            font-size: 16px;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
        }

        .sidebar-link:hover {
            background-color: var(--hover-bg);
            color: var(--text-main);
        }
        
        /* Placeholder content */
        .content-demo {
            padding: 40px;
            color: var(--text-muted);
            line-height: 1.8;
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <button id="menu-btn">
            <i class="bi bi-list"></i>
        </button>
    </header>

    <!-- Demo content -->
    <div class="content-demo">
        <h1>Welcome to the Dashboard</h1>
        <p>Click the menu button in the top right to open the sidebar. Notice how the background freezes cleanly.</p>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
    </div>

    <!-- Overlay Element to freeze background -->
    <div id="overlay"></div>

    <!-- Floating Sidebar -->
    <nav id="sidebar">
        <h3 class="sidebar-title">Menu</h3>
        
        <a href="#" class="sidebar-link">
            <i class="bi bi-house-door" style="color: var(--blue);"></i> Home
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-star" style="color: var(--yellow);"></i> Favorites
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-bell" style="color: var(--red);"></i> Notifications
        </a>
    </nav>

    <!-- Script to handle sidebar & background freeze -->
    <script>
        const menuBtn = document.getElementById('menu-btn');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');

        function toggleSidebar(forceOpen) {
            const isOpen = forceOpen !== undefined ? forceOpen : !sidebar.classList.contains('open');
            
            if (isOpen) {
                sidebar.classList.add('open');
                overlay.classList.add('show');
                document.body.style.overflow = 'hidden'; // Freezes the main web page scrolling
            } else {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
                document.body.style.overflow = ''; // Unfreezes the main web page
            }
        }

        menuBtn.addEventListener('click', (event) => {
            toggleSidebar();
            event.stopPropagation();
        });

        // Tapping anywhere on the dark overlay closes the menu
        overlay.addEventListener('click', () => {
            toggleSidebar(false);
        });
    </script>

</body>
</html>
