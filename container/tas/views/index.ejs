<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Play Store</title>
    <style>
        /* Basic Reset */
        * {
            box-sizing: border-box;
        }
        
        body {
            margin: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #ffffff;
            color: #202124;
            display: flex;
            flex-direction: column;
            min-height: 100vh; /* Keeps footer at the bottom */
        }

        /* ----- HEADER STYLING ----- */
        header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 24px;
            border-bottom: 1px solid #e8eaed;
            background: #ffffff;
            position: sticky;
            top: 0;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 40px;
            width: 100%;
        }

        .logo {
            font-size: 22px;
            font-weight: 500;
            color: #5f6368;
            text-decoration: none;
        }

        .search-bar {
            flex-grow: 1;
            max-width: 700px;
            background: #f1f3f4;
            border-radius: 8px;
            padding: 12px 16px;
            display: flex;
            align-items: center;
        }

        .search-bar input {
            border: none;
            background: transparent;
            width: 100%;
            font-size: 16px;
            outline: none;
            color: #202124;
        }

        /* ----- MAIN CONTENT AREA ----- */
        main {
            flex: 1; /* Pushes the footer down */
            padding: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #80868b;
        }

        /* ----- FOOTER STYLING ----- */
        footer {
            background-color: #f8f9fa;
            border-top: 1px solid #e8eaed;
            padding: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 12px;
            color: #5f6368;
        }

        .footer-links a {
            color: #5f6368;
            text-decoration: none;
            margin-right: 20px;
        }

        .footer-links a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <!-- Header Area -->
    <header>
        <div class="header-left">
            <a href="#" class="logo">Google Play</a>
            <div class="search-bar">
                <input type="text" placeholder="Search for apps & games">
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main>
        <!-- The app grids and content will go here later -->
        <h2>App content will be displayed here...</h2>
    </main>

    <!-- Footer Area -->
    <footer>
        <div class="footer-links">
            <a href="#">Terms of Service</a>
            <a href="#">Privacy Policy</a>
            <a href="#">About Google Play</a>
            <a href="#">Developers</a>
        </div>
        <div>
            &copy; 2026 Google LLC
        </div>
    </footer>

</body>
</html>
