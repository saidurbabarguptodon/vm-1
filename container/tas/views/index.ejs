<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Green Theme App</title>
    
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        /* Renamed Color Palette & Basic Reset */
        :root {
            --green: #1ad76f;
            --dark-green: #0E713B;
            --yellow: #FBBF24;
            --dark-yellow: #B45309;
            --red: #EF4444;
            --dark-red: #991B1B;
            --blue: #3B82F6;
            --dark-blue: #1E3A8A;
            --white: #F1F5F9; /* This is a soft off-white/gray */
            --gray: #94A3B8;

            --pure-white: #ffffff; /* Kept for the solid white sidebar */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            /* Using the newly added --white for the background */
            background-color: var(--white);
            overflow-x: hidden; 
        }

        /* ----- HEADER ----- */
        header {
            /* Using the new vibrant green */
            background-color: var(--green);
            height: 80px;
            
            border-bottom-left-radius: 15px;
            border-bottom-right-radius: 15px;
            
            display: flex;
            align-items: center;
            justify-content: flex-end; 
            padding: 0 30px;
            
            /* Updated shadow to match the new green */
            box-shadow: 0 4px 12px rgba(26, 215, 111, 0.3); 
            
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* Sidebar Toggle Button */
        #menu-btn {
            background: none;
            border: none;
            color: var(--pure-white);
            font-size: 36px;
            cursor: pointer;
            transition: transform 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #menu-btn:hover {
            transform: scale(1.1);
        }

        /* ----- FLOATING SIDEBAR ----- */
        #sidebar {
            position: fixed;
            top: 16px; 
            left: 16px; 
            width: 260px;
            height: calc(100vh - 32px); 
            
            background-color: var(--pure-white);
            border-radius: 24px; 
            
            /* Soft shadow and border using the new colors */
            box-shadow: 0 10px 30px rgba(14, 113, 59, 0.15);
            border: 2px solid var(--green);
            
            padding: 24px;
            z-index: 1000; 
            
            transform: translateX(-150%);
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        #sidebar.open {
            transform: translateX(0);
        }

        .sidebar-title {
            /* Using the darker green for nice contrast on text */
            color: var(--dark-green);
            font-size: 20px;
            margin-bottom: 20px;
            text-align: center;
            font-weight: 600;
        }

        /* Example of how you can use the other colors for links */
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--gray);
            text-decoration: none;
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 8px;
            transition: background 0.2s, color 0.2s;
        }

        .sidebar-link:hover {
            background-color: var(--white);
            color: var(--dark-green);
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <button id="menu-btn">
            <i class="bi bi-list"></i>
        </button>
    </header>

    <!-- Floating Sidebar -->
    <nav id="sidebar">
        <h3 class="sidebar-title">Menu</h3>
        
        <!-- Example links utilizing the new colors -->
        <a href="#" class="sidebar-link">
            <i class="bi bi-house-door" style="color: var(--blue);"></i> Home
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-star" style="color: var(--yellow);"></i> Favorites
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-bell" style="color: var(--red);"></i> Notifications
        </a>
    </nav>

    <!-- Script to handle sidebar toggle -->
    <script>
        const menuBtn = document.getElementById('menu-btn');
        const sidebar = document.getElementById('sidebar');

        menuBtn.addEventListener('click', (event) => {
            sidebar.classList.toggle('open');
            event.stopPropagation();
        });

        document.addEventListener('click', (event) => {
            if (!sidebar.contains(event.target) && !menuBtn.contains(event.target)) {
                sidebar.classList.remove('open');
            }
        });
    </script>

</body>
</html>
