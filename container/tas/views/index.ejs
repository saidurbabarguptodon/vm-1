<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Emerald Theme</title>
    <style>
        /* Color Palette & Basic Reset */
        :root {
            --emerald: #10B981;
            --emerald-light: #d1fae5;
            --white: #ffffff;
            --bg-color: #f8fafc; /* Very light off-white to make the white sidebar pop */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            overflow-x: hidden; /* Prevents horizontal scrollbar */
        }

        /* ----- HEADER ----- */
        header {
            background-color: var(--emerald);
            height: 80px;
            /* Round the bottom two corners */
            border-bottom-left-radius: 30px;
            border-bottom-right-radius: 30px;
            
            /* Align items */
            display: flex;
            align-items: center;
            justify-content: flex-end; /* Pushes the button to the right */
            padding: 0 30px;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
            
            /* Keep it sticky at the top */
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* Sidebar Toggle Button */
        #menu-btn {
            background: none;
            border: none;
            color: var(--white);
            font-size: 32px;
            cursor: pointer;
            transition: transform 0.2s ease;
        }

        #menu-btn:hover {
            transform: scale(1.1);
        }

        /* ----- FLOATING SIDEBAR ----- */
        #sidebar {
            position: fixed;
            top: 100px; /* Pushed down from the header to float */
            left: 20px; /* Pushed away from the left edge to float */
            width: 260px;
            height: calc(100vh - 130px); /* Adjust height so it floats above the bottom too */
            
            background-color: var(--white);
            
            /* All four corners rounded */
            border-radius: 24px; 
            
            /* Floating shadow effect with emerald tint */
            box-shadow: 0 10px 30px rgba(16, 185, 129, 0.15);
            border: 2px solid var(--emerald-light);
            
            padding: 24px;
            z-index: 1000;
            
            /* Animation logic: hidden to the left by default */
            transform: translateX(-150%);
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        /* Class added via JavaScript to slide it in */
        #sidebar.open {
            transform: translateX(0);
        }

        /* Sidebar dummy content styles */
        .sidebar-title {
            color: var(--emerald);
            font-size: 20px;
            margin-bottom: 20px;
            text-align: center;
        }

    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <!-- Button positioned on the right -->
        <button id="menu-btn">☰</button>
    </header>

    <!-- Floating Sidebar opening from the left -->
    <nav id="sidebar">
        <h3 class="sidebar-title">Menu</h3>
        <!-- You can add your sidebar links/items here later -->
    </nav>

    <!-- Script to handle sidebar toggle -->
    <script>
        const menuBtn = document.getElementById('menu-btn');
        const sidebar = document.getElementById('sidebar');

        // Toggle sidebar open/close on button click
        menuBtn.addEventListener('click', () => {
            sidebar.classList.toggle('open');
        });

        // Optional: Close sidebar if clicking outside of it
        document.addEventListener('click', (event) => {
            if (!sidebar.contains(event.target) && !menuBtn.contains(event.target)) {
                sidebar.classList.remove('open');
            }
        });
    </script>

</body>
</html>
