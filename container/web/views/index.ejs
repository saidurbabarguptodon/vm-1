<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud</title>
  
  <!-- Optimized via CDNs -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;600;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- AOS Animation CSS -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">
  
  <style>
    :root {
      --kex-green: #1ad76f; --kex-dark-green: #0E713B;
      --kex-yellow: #FBBF24; --kex-dark-yellow: #B45309;
      --kex-red: #EF4444; --kex-dark-red: #991B1B;
      --kex-blue: #3B82F6; --kex-dark-blue: #1E3A8A;
      --kex-white: #F1F5F9; --kex-gray: #94A3B8;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    body {
      width: 100%; overflow-x: hidden; font-family: 'Inter', sans-serif;
      background-color: #0A0A0F; color: var(--kex-white); line-height: 1.6;
      -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; scroll-behavior: smooth;
    }
    body.has-sidebar-open { overflow: hidden; touch-action: none; }

    #snow-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; }

    .bg-ambient-glow {
      position: fixed; top: -150px; left: -150px; width: 500px; height: 500px;
      background: rgba(26, 215, 111, 0.25); border-radius: 50%; z-index: 0;
      pointer-events: none; filter: blur(100px);
    }

    .container { position: relative; z-index: 2; width: 100%; max-width: 1280px; margin: 0 auto; padding: 0 20px; }

    .header {
      width: calc(100% - 32px); max-width: 1240px; margin: 16px auto 0;
      background: rgba(18, 18, 24, 0.65);
      backdrop-filter: blur(24px) saturate(180%); -webkit-backdrop-filter: blur(24px) saturate(180%);
      position: sticky; top: 16px; z-index: 100;
      border: 1px solid rgba(26, 215, 111, 0.5); border-radius: 16px;
      box-shadow: 0 10px 40px -10px rgba(0,0,0,0.5), 0 0 20px rgba(26,215,111,0.15);
    }
    .header .container { padding: 0 16px; }
    .header__nav { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; }

    .header__toggle, .sidebar__close {
      background: transparent; border: none; color: var(--kex-white); cursor: pointer;
      display: flex; align-items: center; justify-content: center; border-radius: 8px; transition: all 0.15s ease;
    }
    .header__toggle { font-size: 1.6rem; width: 40px; height: 40px; margin-right: 0; }
    .sidebar__close { font-size: 1.5rem; width: 36px; height: 36px; margin-right: -8px; }
    .sidebar.is-expanded .sidebar__close i { transform: rotate(90deg); }

    .brand { display: flex; align-items: center; gap: 10px; transition: opacity 0.2s ease; text-decoration: none; }
    .brand--header { height: 36px; margin-left: 0; }
    .brand--sidebar { height: 32px; }

    .logoimg { height: 100%; width: auto; object-fit: contain; }
    .alticon, .alttext { color: var(--kex-green); text-shadow: 0 0 12px rgba(26,215,111,.45); }
    .alticon { font-size: 1.6rem; display: inline-block; }
    .alttext { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.5px; font-family: 'Playfair Display', serif; color: #fff; text-shadow: none; }

    .overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.6); backdrop-filter: blur(5px);
      opacity: 0; visibility: hidden; transition: all 0.3s ease; z-index: 998; cursor: pointer;
    }
    .overlay.is-visible { opacity: 1; visibility: visible; }

    .sidebar {
      position: fixed; top: 0; bottom: 0; left: 0; height: 100vh; width: 280px; max-width: 80vw;
      background: rgba(15,15,20,0.65); backdrop-filter: blur(28px) saturate(180%);
      z-index: 999; display: flex; flex-direction: column; border-radius: 0 24px 24px 0;
      border-right: 1px solid rgba(255,255,255,.08); box-shadow: 10px 0 30px rgba(0,0,0,.5);
      transform: translateX(-100%); transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
    }
    .sidebar.is-expanded { transform: translateX(0); }

    .sidebar__header, .sidebar__body, .sidebar__footer { opacity: 0; transform: translateY(15px); transition: all 0.4s ease; }
    .sidebar.is-expanded .sidebar__header, .sidebar.is-expanded .sidebar__body, .sidebar.is-expanded .sidebar__footer { opacity: 1; transform: translateY(0); }
    .sidebar.is-expanded .sidebar__header { transition-delay: 0.1s; }
    .sidebar.is-expanded .sidebar__body   { transition-delay: 0.18s; }
    .sidebar.is-expanded .sidebar__footer { transition-delay: 0.26s; }

    .sidebar__header { display: flex; justify-content: space-between; align-items: center; padding: 0 24px; border-bottom: 1px solid rgba(255,255,255,.08); height: 73px; flex-shrink: 0; }
    .sidebar__body { flex: 1; padding: 16px 12px 20px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.15) transparent; }
    .sidebar__footer { border-top: 1px solid rgba(255,255,255,.08); flex-shrink: 0; min-height: 73px; padding: 15px 24px; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,.15); }

    .navmenu { display: flex; flex-direction: column; gap: 6px; }
    .navbutton { display: flex; align-items: center; gap: 12px; padding: 14px 15px; min-height: 56px; color: #fff; text-decoration: none; border-radius: 12px; transition: all 0.25s; overflow: hidden; }
    .navbutton i { font-size: 1.25rem; width: 28px; text-align: center; color: var(--kex-green); }
    .navbutton.is-active { background: var(--kex-dark-green); color: #fff; font-weight: 700; }
    .navbutton__text { font-size: 1.05rem; font-weight: 500; }

    .sociallinks { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; width: 100%; }
    .sociallink { display: flex; align-items: center; justify-content: center; width: 42px; height: 42px; background: var(--kex-green); border: 1px solid var(--kex-green); color: #fff; border-radius: 50%; text-decoration: none; font-size: 19px; transition: all 0.3s; }

    .hero { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 100px 0 80px; min-height: 50vh; scroll-margin-top: 80px; }
    .hero-title { font-size: clamp(1.8rem,5vw,2.8rem); font-weight: 800; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 20px; }
    .hero-description { font-size: clamp(1.1rem,4vw,1.4rem); color: var(--kex-gray); margin-bottom: 32px; }
    .hero-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--kex-green); color: #fff; font-weight: 600; font-size: 1.1rem; padding: 14px 24px; border-radius: 60px; text-decoration: none; transition: all 0.3s; box-shadow: 0 8px 20px -6px rgba(26,215,111,.5); margin-bottom: 24px; }
    .hero-footer { font-size: 0.95rem; color: var(--kex-gray); opacity: 0.8; }

    .cards-section, .faqs-section { padding: 40px 0 100px; scroll-margin-top: 85px; position: relative; z-index: 2; }
    .cards-header, .faqs-header { text-align: center; margin-bottom: 50px; }
    .cards-title, .faqs-title { font-size: clamp(1.8rem,4vw,2.4rem); font-weight: 800; margin-bottom: 16px; letter-spacing: -0.02em; }
    .cards-description, .faqs-description { font-size: clamp(1rem,3vw,1.15rem); color: var(--kex-gray); max-width: 650px; margin: 0 auto; }
    
    .cards-grid, .faqs-container { display: flex; flex-wrap: wrap; justify-content: center; gap: 24px; width: 100%; align-items: flex-start; }
    
    .card-bg, .faq-item {
      background: rgba(20,20,30,0.4); border: 1px solid rgba(255,255,255,0.05); border-radius: 20px;
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      flex: 1 1 320px; max-width: 400px; width: 100%; min-width: min(100%, 280px); position: relative; transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    }
    
    .card-bg { padding: 32px 28px; text-decoration: none; display: flex; flex-direction: column; overflow: hidden; }
    .card-status { position: absolute; top: 24px; right: 24px; display: flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 20px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; border: 1px solid; }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; position: relative; }
    .status-dot::after { content: ''; position: absolute; inset: 0; border-radius: 50%; animation: pulse 2s infinite; }
    @keyframes pulse { 0% { transform: scale(0.95); box-shadow: 0 0 0 0 var(--pulse-color); } 70% { transform: scale(1); box-shadow: 0 0 0 4px transparent; } 100% { transform: scale(0.95); box-shadow: 0 0 0 0 transparent; } }

    .status-online { color: var(--kex-green); border-color: rgba(26,215,111,0.2); background: rgba(26,215,111,0.05); } .status-online .status-dot { background: var(--kex-green); --pulse-color: rgba(26,215,111,0.7); }
    .status-maintenance { color: var(--kex-yellow); border-color: rgba(251,191,36,0.2); background: rgba(251,191,36,0.05); } .status-maintenance .status-dot { background: var(--kex-yellow); --pulse-color: rgba(251,191,36,0.7); }
    .status-offline { color: var(--kex-red); border-color: rgba(239,68,68,0.2); background: rgba(239,68,68,0.05); } .status-offline .status-dot { background: var(--kex-red); --pulse-color: rgba(239,68,68,0.7); }
    .status-soon { color: var(--kex-blue); border-color: rgba(59,130,246,0.2); background: rgba(59,130,246,0.05); } .status-soon .status-dot { background: var(--kex-blue); --pulse-color: rgba(59,130,246,0.7); }
    .status-default { color: var(--kex-white); border-color: rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); } .status-default .status-dot { background: var(--kex-white); --pulse-color: rgba(255,255,255,0.7); }

    .card-icon { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; background: rgba(26,215,111,0.1); color: var(--kex-green); border-radius: 14px; font-size: 1.6rem; margin-bottom: 24px; transition: all 0.3s; }
    .card-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 12px; transition: color 0.3s; }
    .card-description { font-size: 0.95rem; color: var(--kex-gray); flex-grow: 1; }

    .faq-item { border-radius: 16px; overflow: hidden; }
    .faq-question { width: 100%; text-align: left; background: transparent; border: none; padding: 24px; display: flex; justify-content: space-between; align-items: center; color: var(--kex-white); font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: color 0.3s; font-family: inherit; }
    .faq-icon { color: var(--kex-green); font-size: 1.2rem; transition: transform 0.3s; flex-shrink: 0; margin-left: 16px; }
    .faq-item.is-active .faq-icon { transform: rotate(45deg); }
    .faq-item.is-active { border-color: rgba(26,215,111,0.3); background: rgba(20,20,30,0.6); }
    .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out, padding 0.3s ease; padding: 0 24px; color: var(--kex-gray); font-size: 0.95rem; }

    .cards-footer, .faqs-footer { display: flex; justify-content: center; width: 100%; margin-top: 48px; }

    @media (hover: hover) {
      .header__toggle:hover, .sidebar__close:hover { background: rgba(255,255,255,.06); }
      .brand:hover { opacity: 0.8; }
      .navbutton:hover { background: var(--kex-dark-green); transform: translateX(4px); color: #fff; }
      .sociallink:hover { background: var(--kex-dark-green); border-color: var(--kex-dark-green); transform: translateY(-4px) scale(1.05); box-shadow: 0 10px 20px -5px rgba(26,215,111,.5); }
      .hero-btn:hover { background: var(--kex-dark-green); transform: translateY(-2px); box-shadow: 0 12px 24px -8px rgba(26,215,111,.6); }
      .card-bg:hover { transform: translateY(-8px); border-color: rgba(26,215,111,0.4); box-shadow: 0 15px 35px -10px rgba(0,0,0,0.6), 0 0 25px rgba(26,215,111,0.08); }
      .card-bg:hover .card-icon { transform: scale(1.1) rotate(-5deg); background: var(--kex-green); color: #fff; box-shadow: 0 8px 20px -6px rgba(26,215,111,0.5); }
      .card-bg:hover .card-title { color: var(--kex-green); }
      .faq-question:hover { color: var(--kex-green); }
    }

    .sociallink:active, .hero-btn:active, .card-bg:active { transform: scale(0.98); }
  </style>
</head>
<body>
  <canvas id="snow-canvas"></canvas>
  <div class="bg-ambient-glow"></div>

  <header class="header" data-aos="fade-down" data-aos-duration="600">
    <div class="container">
      <nav class="header__nav">
        <a href="/" class="brand brand--header" id="brand-header">
          <% if (header.logourl) { %>
            <img src="<%= header.logourl %>" alt="<%= header.alttext %>" class="logoimg">
          <% } else { %>
            <% if (header.alticon) { %><i class="<%= header.alticon %> alticon"></i><% } %>
            <% if (header.alttext) { %><span class="alttext"><%= header.alttext %></span><% } %>
          <% } %>
        </a>
        <button class="header__toggle" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <div class="overlay" id="overlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar__header">
      <a href="/" class="brand brand--sidebar" id="brand-sidebar">
        <% if (sidebar.header && sidebar.header.logourl) { %>
          <img src="<%= sidebar.header.logourl %>" alt="<%= sidebar.header.alttext %>" class="logoimg">
        <% } else { %>
          <% if (sidebar.header && sidebar.header.alticon) { %><i class="<%= sidebar.header.alticon %> alticon"></i><% } %>
          <% if (sidebar.header && sidebar.header.alttext) { %><span class="alttext"><%= sidebar.header.alttext %></span><% } %>
        <% } %>
      </a>
      <button class="sidebar__close" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <div class="sidebar__body">
      <nav class="navmenu" id="navmenu">
        <% if (sidebar.body && sidebar.body.length > 0) { %>
          <% sidebar.body.forEach(link => { %>
            <a href="<%= link.url || '#' %>" class="navbutton">
              <% if (link.icon) { %><i class="<%= link.icon %>"></i><% } %>
              <div class="navbutton__content">
                <span class="navbutton__text"><%= link.text || '' %></span>
              </div>
            </a>
          <% }) %>
        <% } %>
      </nav>
    </div>

    <div class="sidebar__footer">
      <div class="sociallinks" id="sociallinks">
        <% if (sidebar.footer && sidebar.footer.length > 0) { %>
          <% sidebar.footer.forEach(social => { %>
            <a href="<%= social.url || '#' %>" target="_blank" class="sociallink" rel="noopener">
              <% if (social.icon) { %><i class="<%= social.icon %>"></i><% } %>
            </a>
          <% }) %>
        <% } %>
      </div>
    </div>
  </aside>

  <section class="hero" id="home">
    <div class="container">
      <% if (hero.primarytext) { %>
        <h1 class="hero-title" data-aos="fade-up"><%- fmt(hero.primarytext) %></h1>
      <% } %>
      <% if (hero.secondarytext) { %>
        <p class="hero-description" data-aos="fade-up" data-aos-delay="100"><%- fmt(hero.secondarytext) %></p>
      <% } %>
      <% if (hero.buttonenabled === true || hero.buttonenabled === 'true') { %>
        <a href="<%= hero.buttonurl || '#' %>" class="hero-btn" target="_blank" rel="noopener" data-aos="fade-up" data-aos-delay="200">
          <% if (hero.buttonicon) { %><i class="<%= hero.buttonicon %>"></i><% } %>
          <span><%= hero.buttontext || '' %></span>
        </a>
      <% } %>
      <% if (hero.footertext) { %>
        <div class="hero-footer" data-aos="fade-up" data-aos-delay="300"><%- fmt(hero.footertext) %></div>
      <% } %>
    </div>
  </section>

  <section class="cards-section container" id="services">
    <% if (cards && cards.data && (cards.data.title || cards.data.description)) { %>
      <div class="cards-header" data-aos="fade-up">
        <% if (cards.data.title) { %>
          <h2 class="cards-title"><%- fmt(cards.data.title) %></h2>
        <% } %>
        <% if (cards.data.description) { %>
          <p class="cards-description"><%- fmt(cards.data.description) %></p>
        <% } %>
      </div>
    <% } %>

    <div class="cards-grid">
      <% 
        let sortedCards =[];
        if (cards && cards.items && cards.items.length > 0) {
          sortedCards = cards.items.slice().sort((a, b) => (Number(b.rating) || 0) - (Number(a.rating) || 0));
        }
      %>
      <% if (sortedCards.length > 0) { %>
        <% sortedCards.slice(0, 6).forEach((card, index) => { %>
          <a href="<%= card.url || '#' %>" class="card-bg" target="_blank" rel="noopener" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <% if (card.status && card.status.trim() !== '') { 
              let statusClass = 'status-default';
              let statusText = card.status.trim().toLowerCase();
              if (statusText === 'online') statusClass = 'status-online';
              else if (statusText === 'maintenance') statusClass = 'status-maintenance';
              else if (statusText === 'offline') statusClass = 'status-offline';
              else if (statusText === 'soon') statusClass = 'status-soon';
            %>
              <div class="card-status <%= statusClass %>">
                <div class="status-dot"></div>
                <span><%= card.status %></span>
              </div>
            <% } %>
            <% if (card.icon) { %>
              <div class="card-icon">
                <i class="<%= card.icon %>"></i>
              </div>
            <% } %>
            <h3 class="card-title"><%- fmt(card.title || '') %></h3>
            <p class="card-description"><%- fmt(card.description || '') %></p>
          </a>
        <% }) %>
      <% } %>
    </div>

    <% if (cards && cards.data && (cards.data.buttonenabled === true || cards.data.buttonenabled === 'true')) { %>
      <div class="cards-footer" data-aos="fade-up" data-aos-offset="50">
        <a href="<%= cards.data.buttonurl || '#' %>" class="hero-btn" target="_blank" rel="noopener">
          <% if (cards.data.buttonicon) { %><i class="<%= cards.data.buttonicon %>"></i><% } %>
          <span><%= cards.data.buttontext || '' %></span>
        </a>
      </div>
    <% } %>
  </section>

  <section class="faqs-section container" id="faqs">
    <% if (faqs && faqs.data && (faqs.data.title || faqs.data.description)) { %>
      <div class="faqs-header" data-aos="fade-up">
        <% if (faqs.data.title) { %>
          <h2 class="faqs-title"><%- fmt(faqs.data.title) %></h2>
        <% } %>
        <% if (faqs.data.description) { %>
          <p class="faqs-description"><%- fmt(faqs.data.description) %></p>
        <% } %>
      </div>
    <% } %>

    <div class="faqs-container">
      <% if (faqs && faqs.items && faqs.items.length > 0) { %>
        <% faqs.items.forEach((faq, index) => { %>
          <div class="faq-item" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <button class="faq-question" aria-expanded="false">
              <span><%- fmt(faq.title || '') %></span>
              <i class="fa-solid fa-plus faq-icon"></i>
            </button>
            <div class="faq-answer">
              <%- fmt(faq.description || '') %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <% if (faqs && faqs.data && (faqs.data.buttonenabled === true || faqs.data.buttonenabled === 'true')) { %>
      <div class="faqs-footer" data-aos="fade-up" data-aos-offset="50">
        <a href="<%= faqs.data.buttonurl || '#' %>" class="hero-btn" target="_blank" rel="noopener">
          <% if (faqs.data.buttonicon) { %><i class="<%= faqs.data.buttonicon %>"></i><% } %>
          <span><%= faqs.data.buttontext || '' %></span>
        </a>
      </div>
    <% } %>
  </section>

  <% function fmt(t) {
    if (!t) return '';
    t = t.replace(/\[a url=([^\]]+)\](.*?)\[\/a\]/gi, '<a href="$1" target="_blank" rel="noopener" style="color: var(--kex-green); text-decoration: none;">$2</a>');
    t = t.replace(/\[icon\](.*?)\[\/icon\]/gi, '<i class="$1"></i>');
    t = t.replace(/\[color=#([0-9a-fA-F]{3,8})\](.*?)\[\/color\]/gi, '<span style="color: #$1;">$2</span>');
    t = t.replace(/\[b\](.*?)\[\/b\]/gi, '<b>$1</b>');
    t = t.replace(/\[i\](.*?)\[\/i\]/gi, '<i>$1</i>');
    t = t.replace(/\[u\](.*?)\[\/u\]/gi, '<u>$1</u>');
    t = t.replace(/\[br\]/gi, '<br>');
    t = t.replace(/\n/g, '<br>');
    return t;
  } %>

  <!-- AOS JS -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <script>
    // Initialize Animations
    AOS.init({ duration: 700, once: true, offset: 80, easing: 'ease-out-cubic' });

    // Handle Links & Buttons
    document.querySelectorAll('.hero-btn, .card-bg, .sociallink').forEach(el => {
      el.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        const target = this.getAttribute('target') || '_self';
        if (href && href !== '#' && !href.startsWith('#')) e.preventDefault();
        
        if (href && href !== '#' && !href.startsWith('#')) {
          setTimeout(() => target === '_blank' ? window.open(href, '_blank') : window.location.href = href, 200);
        }
      });
    });

    // FAQs Logic
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.parentElement;
        const ans = item.querySelector('.faq-answer');
        const active = item.classList.contains('is-active');

        if (!active) {
          item.classList.add('is-active');
          btn.setAttribute('aria-expanded', 'true');
          ans.style.maxHeight = ans.scrollHeight + 24 + "px";
          ans.style.paddingBottom = "24px";
        } else {
          item.classList.remove('is-active');
          btn.setAttribute('aria-expanded', 'false');
          ans.style.maxHeight = null;
          ans.style.paddingBottom = "0";
        }
      });
    });

    // Navigation Logic
    (function() {
      const navBtns = document.querySelectorAll('.navbutton');
      const sections = Array.from(document.querySelectorAll('section[id]'));
      let isNavigating = false, navTimeout = null, lastActive = '';

      function setNavActive(id) {
        navBtns.forEach(b => {
          const href = b.getAttribute('href');
          b.classList.toggle('is-active', (id === 'home' && (href === '/' || href === '#home')) || href === `#${id}`);
        });
      }

      function scrollToTop() {
        isNavigating = true;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        history.pushState(null, null, window.location.pathname);
        setNavActive('home'); lastActive = 'home';
        clearTimeout(navTimeout); navTimeout = setTimeout(() => isNavigating = false, 800); 
      }

      document.querySelectorAll('.brand').forEach(b => {
        b.addEventListener('click', e => { e.preventDefault(); scrollToTop(); window.dispatchEvent(new Event('hideSidebar')); });
      });

      navBtns.forEach(btn => {
        btn.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          if (href === '/' || href === '#home') {
            e.preventDefault(); scrollToTop(); window.dispatchEvent(new Event('hideSidebar'));
          } else if (href && href.startsWith('#')) {
            e.preventDefault();
            const target = document.getElementById(href.substring(1));
            if (target) {
              isNavigating = true; target.scrollIntoView({ behavior: 'smooth' });
              history.pushState(null, null, href);
              setNavActive(href.substring(1)); lastActive = href.substring(1);
              window.dispatchEvent(new Event('hideSidebar'));
              clearTimeout(navTimeout); navTimeout = setTimeout(() => isNavigating = false, 800); 
            }
          }
        });
      });

      window.addEventListener('scroll', () => {
        if (isNavigating) return;
        const scrollPos = window.scrollY, middle = 85 + (window.innerHeight / 3);
        let curr = null;
        if ((window.innerHeight + scrollPos) >= document.body.offsetHeight - 10) curr = sections[sections.length - 1].id;
        else if (scrollPos < 50) curr = 'home';
        else sections.forEach(s => { const r = s.getBoundingClientRect(); if (r.top <= middle && r.bottom >= middle) curr = s.id; });
        if (!curr && sections.length) curr = sections[0].id;
        if (curr !== lastActive) {
          lastActive = curr; setNavActive(curr);
          const newUrl = window.location.pathname + (curr === 'home' ? '' : '#' + curr);
          if (window.location.pathname + window.location.hash !== newUrl) history.replaceState(null, null, newUrl);
        }
      }, { passive: true });

      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      window.addEventListener('load', () => {
        if (window.location.hash) history.replaceState(null, null, window.location.pathname);
        window.scrollTo(0, 0); setNavActive('home'); lastActive = 'home';
      });
    })();

    // Snow Effect
    (function() {
      const cvs = document.getElementById('snow-canvas'), ctx = cvs.getContext('2d');
      let w = window.innerWidth, h = window.innerHeight;
      cvs.width = w; cvs.height = h;
      const max = w < 768 ? 20 : 50, flakes =[];
      for (let i=0; i<max; i++) flakes.push({ x: Math.random()*w, y: Math.random()*h, r: Math.random()*1.5+0.5, d: Math.random()*0.4+0.15, a: Math.random()*Math.PI*2, aStep: Math.random()*0.01+0.005, op: Math.random()*0.4+0.15 });

      function draw() {
        ctx.clearRect(0,0,w,h);
        for (let i=0; i<max; i++) {
          let f = flakes[i];
          if (f.op > 0) { ctx.beginPath(); ctx.fillStyle = `rgba(255,255,255,${f.op})`; ctx.arc(f.x,f.y,f.r,0,Math.PI*2,true); ctx.fill(); }
          f.y += f.d; f.a += f.aStep; f.x += Math.sin(f.a)*0.25;
          if (f.y > h) { f.y = -10; f.x = Math.random()*w; }
          if (f.x > w+10) f.x = -10; if (f.x < -10) f.x = w+10;
        }
        requestAnimationFrame(draw);
      }
      window.addEventListener('resize', () => { w = window.innerWidth; h = window.innerHeight; cvs.width = w; cvs.height = h; });
      draw();
    })();

    // Sidebar Logic
    const sb = document.getElementById('sidebar'), ov = document.getElementById('overlay');
    function hideSidebar() { sb.classList.remove('is-expanded'); ov.classList.remove('is-visible'); document.body.classList.remove('has-sidebar-open'); }
    document.getElementById('open-sidebar').addEventListener('click', () => { sb.classList.add('is-expanded'); ov.classList.add('is-visible'); document.body.classList.add('has-sidebar-open'); });
    document.getElementById('close-sidebar').addEventListener('click', hideSidebar);
    ov.addEventListener('click', hideSidebar);
    window.addEventListener('hideSidebar', hideSidebar);
  </script>
</body>
</html>
