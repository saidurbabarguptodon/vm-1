<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    /* ─────────────────────────── TOKENS ─────────────────────────── */
    :root {
      --kex-green:       #1ad76f;
      --kex-dark-green:  #0E713B;
      --kex-yellow:      #FBBF24;
      --kex-dark-yellow: #B45309;
      --kex-red:         #EF4444;
      --kex-dark-red:    #991B1B;
      --kex-blue:        #3B82F6;
      --kex-dark-blue:   #1E3A8A;
      --kex-white:       #F1F5F9;
      --kex-gray:        #94A3B8;

      /* Fluid spacing scale */
      --sp-xs:  clamp(8px,  1vw, 12px);
      --sp-sm:  clamp(12px, 1.5vw, 20px);
      --sp-md:  clamp(20px, 2.5vw, 36px);
      --sp-lg:  clamp(40px, 5vw,  80px);
      --sp-xl:  clamp(60px, 7vw,  120px);

      /* Fluid type scale */
      --fs-xs:   clamp(0.75rem,  1.2vw, 0.9rem);
      --fs-sm:   clamp(0.875rem, 1.4vw, 1rem);
      --fs-base: clamp(0.95rem,  1.5vw, 1.1rem);
      --fs-md:   clamp(1.1rem,   1.8vw, 1.3rem);
      --fs-lg:   clamp(1.3rem,   2.2vw, 1.7rem);
      --fs-xl:   clamp(1.8rem,   3.2vw, 2.6rem);
      --fs-2xl:  clamp(2.2rem,   4.5vw, 3.8rem);
      --fs-3xl:  clamp(2.8rem,   6vw,   5rem);

      /* Radii */
      --r-sm: clamp(10px, 1.2vw, 16px);
      --r-md: clamp(14px, 1.8vw, 22px);
      --r-lg: clamp(18px, 2.5vw, 28px);

      /* Grid column count per section */
      --cols: 1;
    }

    /* ─────────────────────────── RESET ─────────────────────────── */
    *, *::before, *::after {
      margin: 0; padding: 0; box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    /* ─────────────────────────── BASE ─────────────────────────── */
    body {
      width: 100%;
      overflow-x: hidden;
      font-family: 'Inter', sans-serif;
      background-color: #0A0A0F;
      color: var(--kex-white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      scroll-behavior: smooth;
      font-size: var(--fs-base);
    }
    body.has-sidebar-open { overflow: hidden; touch-action: none; }

    /* ─────────────────────────── CANVAS / AMBIENT ─────────────────────────── */
    #snow-canvas {
      position: fixed; top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none; z-index: 1;
    }
    .bg-ambient-glow {
      position: fixed;
      top: clamp(-100px, -12vw, -200px);
      left: clamp(-100px, -12vw, -200px);
      width: clamp(400px, 45vw, 700px);
      height: clamp(400px, 45vw, 700px);
      background: rgba(26, 215, 111, 0.22);
      border-radius: 50%;
      z-index: 0; pointer-events: none;
      filter: blur(clamp(80px, 10vw, 140px));
    }

    /* ─────────────────────────── CONTAINER ─────────────────────────── */
    .container {
      position: relative; z-index: 2;
      width: 100%;
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 clamp(16px, 4vw, 80px);
    }

    /* ─────────────────────────── REVEAL ANIMATION ─────────────────────────── */
    .reveal {
      opacity: 0; transform: translateY(28px);
      transition: opacity 0.6s ease-out, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.active { opacity: 1; transform: translateY(0); }

    /* ─────────────────────────── HEADER ─────────────────────────── */
    .header {
      width: calc(100% - clamp(16px, 2.5vw, 40px));
      max-width: 1400px;
      margin: clamp(8px, 1.2vw, 14px) auto 0;
      background: rgba(18, 18, 24, 0.65);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      position: sticky; top: clamp(8px, 1.2vw, 14px);
      z-index: 100;
      border: 1px solid rgba(26, 215, 111, 0.5);
      border-radius: var(--r-md);
      box-shadow:
        0 10px 40px -10px rgba(0,0,0,0.5),
        0 0 20px rgba(26,215,111,0.15);
    }
    .header .container { padding: 0 clamp(14px, 2.5vw, 40px); }

    .header__nav {
      display: flex; justify-content: space-between; align-items: center;
      padding: clamp(10px, 1.5vw, 18px) 0;
    }

    /* ─────────────────────────── TOGGLE / CLOSE ─────────────────────────── */
    .header__toggle, .sidebar__close {
      background: transparent; border: none;
      color: var(--kex-white); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      border-radius: var(--r-sm);
      transition: all 0.15s ease;
    }
    .header__toggle {
      font-size: clamp(1.4rem, 2.2vw, 1.8rem);
      width: clamp(36px, 4vw, 52px);
      height: clamp(36px, 4vw, 52px);
    }
    .header__toggle i { transition: transform 0.2s ease; }
    .sidebar__close {
      font-size: clamp(1.3rem, 2vw, 1.7rem);
      width: clamp(34px, 3.5vw, 48px);
      height: clamp(34px, 3.5vw, 48px);
      margin-right: -6px;
    }
    .sidebar.is-expanded .sidebar__close i { transform: rotate(90deg); }

    /* ─────────────────────────── BRAND ─────────────────────────── */
    .brand {
      display: flex; align-items: center; gap: clamp(8px, 1vw, 14px);
      transition: opacity 0.2s ease; text-decoration: none;
    }
    .brand--header { height: clamp(32px, 4vw, 48px); }
    .brand--sidebar { height: clamp(28px, 3.5vw, 42px); }

    .logoimg { height: 100%; width: auto; object-fit: contain; }
    .alticon, .alttext { color: var(--kex-green); text-shadow: 0 0 12px rgba(26,215,111,.45); }
    .alticon { font-size: clamp(1.4rem, 2.2vw, 2rem); display: inline-block; }
    .alttext {
      font-size: clamp(1.3rem, 2vw, 1.8rem);
      font-weight: 800; letter-spacing: -0.5px;
      font-family: 'Playfair Display', serif;
      color: #fff; text-shadow: none;
    }

    /* ─────────────────────────── OVERLAY ─────────────────────────── */
    .overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.6);
      backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
      opacity: 0; visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998; cursor: pointer;
    }
    .overlay.is-visible { opacity: 1; visibility: visible; }

    /* ─────────────────────────── SIDEBAR ─────────────────────────── */
    .sidebar {
      position: fixed; top: 0; bottom: 0; left: 0;
      height: 100vh; height: 100dvh;
      width: clamp(260px, 30vw, 340px); max-width: 85vw;
      background: rgba(15, 15, 20, 0.65);
      backdrop-filter: blur(28px) saturate(180%);
      -webkit-backdrop-filter: blur(28px) saturate(180%);
      z-index: 999;
      display: flex; flex-direction: column;
      border-radius: 0 clamp(18px, 2vw, 28px) clamp(18px, 2vw, 28px) 0;
      border-right: 1px solid rgba(255,255,255,0.08);
      box-shadow: 10px 0 30px rgba(0,0,0,0.5), inset -1px 0 0 rgba(255,255,255,0.03);
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
    }
    .sidebar.is-expanded { transform: translateX(0); }

    .sidebar__header, .sidebar__body, .sidebar__footer {
      opacity: 0; transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16,1,0.3,1);
    }
    .sidebar.is-expanded .sidebar__header { opacity:1; transform:translateY(0); transition-delay:0.1s; }
    .sidebar.is-expanded .sidebar__body   { opacity:1; transform:translateY(0); transition-delay:0.18s; }
    .sidebar.is-expanded .sidebar__footer { opacity:1; transform:translateY(0); transition-delay:0.26s; }

    .sidebar__header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0 clamp(18px, 2.5vw, 32px);
      border-bottom: 1px solid rgba(255,255,255,.08);
      height: clamp(64px, 8vw, 88px); flex-shrink: 0;
    }
    .sidebar__body {
      flex: 1;
      padding: clamp(12px, 1.5vw, 20px) clamp(8px, 1.2vw, 16px) clamp(16px, 2vw, 28px);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,.15) transparent;
    }
    .sidebar__body::-webkit-scrollbar { width: 5px; }
    .sidebar__body::-webkit-scrollbar-track { background: transparent; }
    .sidebar__body::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 10px; }

    .sidebar__footer {
      border-top: 1px solid rgba(255,255,255,.08);
      flex-shrink: 0; margin-top: auto;
      min-height: calc(clamp(64px, 8vw, 88px) + env(safe-area-inset-bottom));
      padding: clamp(12px, 1.5vw, 20px) clamp(18px, 2.5vw, 32px) calc(clamp(12px, 1.5vw, 20px) + env(safe-area-inset-bottom));
      display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,.15);
    }

    /* ─────────────────────────── NAV MENU ─────────────────────────── */
    .navmenu { display: flex; flex-direction: column; gap: clamp(4px, 0.6vw, 8px); }

    .navbutton {
      display: flex; align-items: center; gap: clamp(10px, 1.2vw, 16px);
      padding: clamp(12px, 1.5vw, 18px) clamp(12px, 1.5vw, 18px);
      min-height: clamp(50px, 6vw, 68px);
      color: #fff; text-decoration: none;
      border-radius: var(--r-sm);
      transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
      position: relative; overflow: hidden;
    }
    .navbutton i {
      font-size: clamp(1.1rem, 1.6vw, 1.4rem);
      width: clamp(24px, 3vw, 32px); text-align: center; flex-shrink: 0;
      color: var(--kex-green); transition: color 0.2s ease;
    }
    .navbutton.is-active { background: var(--kex-dark-green); color: #fff; }
    .navbutton.is-active i { color: var(--kex-green); }
    .navbutton.is-active .navbutton__text { color: #fff; font-weight: 700; }
    .navbutton__content { display: flex; flex-direction: column; justify-content: center; line-height: 1.3; }
    .navbutton__text { font-size: var(--fs-md); font-weight: 500; color: inherit; transition: color 0.2s ease; }

    /* ─────────────────────────── SOCIAL LINKS ─────────────────────────── */
    .sociallinks {
      display: flex; gap: clamp(10px, 1.2vw, 16px);
      flex-wrap: wrap; justify-content: center; width: 100%;
    }
    .sociallink {
      display: flex; align-items: center; justify-content: center;
      width: clamp(38px, 4vw, 52px); height: clamp(38px, 4vw, 52px);
      background-color: var(--kex-green);
      border: 1px solid var(--kex-green);
      color: #fff; border-radius: 50%;
      text-decoration: none;
      font-size: clamp(16px, 1.8vw, 22px);
      transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    }

    /* ─────────────────────────── HERO ─────────────────────────── */
    .hero {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding-top: clamp(70px, 10vw, 140px);
      padding-bottom: clamp(50px, 7vw, 100px);
      min-height: clamp(40vh, 55vh, 65vh);
      position: relative; scroll-margin-top: 80px;
    }
    .hero-title {
      font-size: var(--fs-2xl);
      font-weight: 800; line-height: 1.15; letter-spacing: -0.03em;
      color: var(--kex-white);
      margin-bottom: clamp(14px, 2vw, 28px);
      hyphens: auto;
      max-width: clamp(600px, 75vw, 1000px);
    }
    .hero-description {
      font-size: var(--fs-md);
      color: var(--kex-gray);
      margin-bottom: clamp(24px, 3.5vw, 48px);
      hyphens: auto;
      max-width: clamp(480px, 60vw, 800px);
      line-height: 1.7;
    }
    .hero-btn {
      display: inline-flex; align-items: center; justify-content: center; gap: clamp(6px, 0.8vw, 10px);
      background-color: var(--kex-green);
      color: #fff;
      font-weight: 600;
      font-size: var(--fs-base);
      padding: clamp(12px, 1.5vw, 20px) clamp(20px, 2.5vw, 36px);
      border-radius: 60px;
      text-decoration: none;
      transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
      box-shadow: 0 8px 20px -6px rgba(26,215,111,.5);
      margin-bottom: clamp(16px, 2vw, 28px);
      outline: none;
    }
    .hero-btn i { font-size: clamp(1.1rem, 1.6vw, 1.5rem); font-style: normal !important; }
    .hero-footer {
      font-size: var(--fs-sm); color: var(--kex-gray); opacity: 0.8;
    }

    /* ─────────────────────────── SECTION SHARED ─────────────────────────── */
    .section-header {
      text-align: center;
      margin-bottom: clamp(36px, 5vw, 72px);
    }
    .section-title {
      font-size: var(--fs-xl);
      font-weight: 800; color: var(--kex-white);
      margin-bottom: clamp(12px, 1.5vw, 20px);
      letter-spacing: -0.025em;
      line-height: 1.2;
    }
    .section-description {
      font-size: var(--fs-base);
      color: var(--kex-gray);
      max-width: clamp(500px, 60vw, 800px);
      margin: 0 auto;
      line-height: 1.7;
    }

    /* ─────────────────────────── CARDS SECTION ─────────────────────────── */
    .cards-section {
      padding-top: clamp(30px, 4vw, 60px);
      padding-bottom: clamp(60px, 9vw, 140px);
      position: relative; z-index: 2;
      scroll-margin-top: 85px;
    }
    /* alias classes to the shared patterns */
    .cards-header  { composes: section-header; }
    .cards-title   { composes: section-title; }
    .cards-description { composes: section-description; }

    /* CSS Grid — 1 → 2 → 3 columns fluidly */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(var(--cols, 1), 1fr);
      gap: clamp(16px, 2.5vw, 32px);
      width: 100%;
    }

    .card-bg {
      background: rgba(20, 20, 30, 0.45);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: var(--r-lg);
      padding: clamp(24px, 3vw, 44px);
      text-decoration: none;
      display: flex; flex-direction: column; align-items: flex-start;
      transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      position: relative; overflow: hidden; outline: none;
      height: 100%; /* ensures equal height rows */
    }

    /* Status badge */
    .card-status {
      position: absolute; top: clamp(16px, 2vw, 28px); right: clamp(16px, 2vw, 28px);
      display: flex; align-items: center; gap: 6px;
      padding: clamp(3px, 0.4vw, 6px) clamp(8px, 1vw, 12px);
      border-radius: 20px;
      font-size: clamp(0.58rem, 0.7vw, 0.72rem);
      font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
      pointer-events: none; transition: all 0.3s ease; border: 1px solid;
    }
    .status-dot {
      width: 6px; height: 6px; border-radius: 50%; position: relative; flex-shrink: 0;
    }
    .status-dot::after {
      content: ''; position: absolute; inset: 0;
      border-radius: 50%; animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%   { transform: scale(0.95); box-shadow: 0 0 0 0 var(--pulse-color); }
      70%  { transform: scale(1);    box-shadow: 0 0 0 4px transparent; }
      100% { transform: scale(0.95); box-shadow: 0 0 0 0 transparent; }
    }

    .status-online      { color: var(--kex-green);  border-color: rgba(26,215,111,.22);  background: rgba(26,215,111,.07); }
    .status-online      .status-dot { background: var(--kex-green);  --pulse-color: rgba(26,215,111,.7); }
    .status-maintenance { color: var(--kex-yellow); border-color: rgba(251,191,36,.22);  background: rgba(251,191,36,.07); }
    .status-maintenance .status-dot { background: var(--kex-yellow); --pulse-color: rgba(251,191,36,.7); }
    .status-offline     { color: var(--kex-red);    border-color: rgba(239,68,68,.22);   background: rgba(239,68,68,.07); }
    .status-offline     .status-dot { background: var(--kex-red);    --pulse-color: rgba(239,68,68,.7); }
    .status-soon        { color: var(--kex-blue);   border-color: rgba(59,130,246,.22);  background: rgba(59,130,246,.07); }
    .status-soon        .status-dot { background: var(--kex-blue);   --pulse-color: rgba(59,130,246,.7); }
    .status-default     { color: var(--kex-white);  border-color: rgba(255,255,255,.1);  background: rgba(255,255,255,.05); }
    .status-default     .status-dot { background: var(--kex-white);  --pulse-color: rgba(255,255,255,.7); }

    /* Card content */
    .card-icon {
      display: flex; align-items: center; justify-content: center;
      width: clamp(48px, 5.5vw, 72px); height: clamp(48px, 5.5vw, 72px);
      background: rgba(26,215,111,.1); color: var(--kex-green);
      border-radius: clamp(12px, 1.4vw, 18px);
      font-size: clamp(1.4rem, 2vw, 2rem);
      margin-bottom: clamp(18px, 2.5vw, 32px);
      transition: all 0.3s ease;
    }
    .card-title {
      font-size: var(--fs-lg);
      font-weight: 700; color: var(--kex-white);
      margin-bottom: clamp(8px, 1vw, 14px);
      line-height: 1.3; transition: color 0.3s ease;
    }
    .card-description {
      font-size: var(--fs-sm);
      color: var(--kex-gray); line-height: 1.65; flex-grow: 1;
    }

    /* Footer CTA */
    .cards-footer, .faqs-footer {
      display: flex; justify-content: center;
      width: 100%; margin-top: clamp(32px, 4.5vw, 64px);
    }
    .cards-footer .hero-btn, .faqs-footer .hero-btn { margin-bottom: 0; }

    /* ─────────────────────────── FAQs SECTION ─────────────────────────── */
    .faqs-section {
      padding-top: clamp(40px, 5.5vw, 90px);
      padding-bottom: clamp(60px, 9vw, 140px);
      position: relative; z-index: 2;
      scroll-margin-top: 85px;
    }

    .faqs-container {
      display: grid;
      grid-template-columns: repeat(var(--cols, 1), 1fr);
      gap: clamp(14px, 2vw, 28px);
      align-items: start;
      width: 100%;
    }

    .faq-item {
      background: rgba(20, 20, 30, 0.45);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: var(--r-md);
      overflow: hidden;
      transition: all 0.3s ease;
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    }
    .faq-question {
      width: 100%; text-align: left;
      background: transparent; border: none;
      padding: clamp(18px, 2.2vw, 30px);
      display: flex; justify-content: space-between; align-items: center;
      color: var(--kex-white);
      font-size: var(--fs-base);
      font-weight: 600; cursor: pointer;
      transition: color 0.3s ease; font-family: inherit; outline: none;
    }
    .faq-icon {
      color: var(--kex-green);
      font-size: clamp(1rem, 1.4vw, 1.4rem);
      transition: transform 0.3s ease; flex-shrink: 0;
      margin-left: clamp(12px, 1.5vw, 20px);
    }
    .faq-item.is-active .faq-icon { transform: rotate(45deg); }
    .faq-item.is-active {
      border-color: rgba(26,215,111,.3);
      background: rgba(20,20,30,.65);
    }
    .faq-answer {
      max-height: 0; overflow: hidden;
      transition: max-height 0.3s ease-out, padding 0.3s ease;
      padding: 0 clamp(18px, 2.2vw, 30px);
      color: var(--kex-gray); font-size: var(--fs-sm); line-height: 1.7;
    }

    /* ─────────────────────────── RESPONSIVE BREAKPOINTS ─────────────────────────── */

    /* 480px – 2-col layout begins for grids */
    @media (min-width: 480px) {
      :root { --cols: 1; }
    }

    /* 640px */
    @media (min-width: 640px) {
      :root { --cols: 2; }
    }

    /* 1024px – 3-col */
    @media (min-width: 1024px) {
      :root { --cols: 3; }
    }

    /* 1280px – boost spacing and type */
    @media (min-width: 1280px) {
      .hero { min-height: 58vh; }
    }

    /* 1600px – ultra-wide refinements */
    @media (min-width: 1600px) {
      :root {
        --fs-2xl: 4.2rem;
        --fs-xl:  2.8rem;
        --fs-lg:  1.9rem;
      }
      .container { padding: 0 100px; }
      .card-bg   { padding: 48px; }
    }

    /* ─────────────────────────── HOVER (pointer: fine only) ─────────────────────────── */
    @media (hover: hover) {
      .header__toggle:hover, .sidebar__close:hover { background: rgba(255,255,255,.06); color: #fff; }
      .brand:hover { opacity: 0.8; }
      .navbutton:hover { background: var(--kex-dark-green); transform: translateX(4px); color: #fff; }
      .navbutton:hover i { color: var(--kex-green); }
      .sociallink:hover {
        background-color: var(--kex-dark-green); border-color: var(--kex-dark-green);
        color: #fff; transform: translateY(-4px) scale(1.05);
        box-shadow: 0 10px 20px -5px rgba(26,215,111,.5);
      }
      .hero-btn:hover {
        background-color: var(--kex-dark-green);
        transform: translateY(-2px);
        box-shadow: 0 12px 24px -8px rgba(26,215,111,.6);
      }
      .card-bg:hover {
        transform: translateY(-8px);
        border-color: rgba(26,215,111,.4);
        box-shadow:
          0 20px 45px -12px rgba(0,0,0,.7),
          0 0 30px rgba(26,215,111,.1);
      }
      .card-bg:hover .card-icon {
        transform: scale(1.1) rotate(-5deg);
        background: var(--kex-green); color: #fff;
        box-shadow: 0 8px 20px -6px rgba(26,215,111,.5);
      }
      .card-bg:hover .card-title { color: var(--kex-green); }
      .faq-question:hover { color: var(--kex-green); }
    }

    /* ─────────────────────────── ACTIVE STATES ─────────────────────────── */
    .header__toggle:active i, .header__toggle.force-active i { transform: scale(0.85); }
    .sociallink:active, .sociallink.force-active {
      background-color: var(--kex-dark-green); border-color: var(--kex-dark-green); transform: scale(0.95);
    }
    .hero-btn:active, .hero-btn.force-active {
      background-color: var(--kex-dark-green); transform: scale(0.98);
    }
    .card-bg:active, .card-bg.force-active {
      transform: scale(0.98); border-color: rgba(26,215,111,.4);
    }
    .card-bg:active .card-icon, .card-bg.force-active .card-icon {
      transform: scale(1.1) rotate(-5deg);
      background: var(--kex-green); color: #fff;
      box-shadow: 0 8px 20px -6px rgba(26,215,111,.5);
    }
    .card-bg:active .card-title, .card-bg.force-active .card-title { color: var(--kex-green); }
  </style>
</head>
<body>
  <canvas id="snow-canvas"></canvas>
  <div class="bg-ambient-glow"></div>

  <!-- ═══════════════ HEADER ═══════════════ -->
  <header class="header">
    <div class="container">
      <nav class="header__nav">
        <a href="/" class="brand brand--header" id="brand-header">
          <% if (header.logourl) { %>
            <img src="<%= header.logourl %>" alt="<%= header.alttext %>" class="logoimg">
          <% } else { %>
            <% if (header.alticon) { %><i class="<%= header.alticon %> alticon"></i><% } %>
            <% if (header.alttext) { %><span class="alttext"><%= header.alttext %></span><% } %>
          <% } %>
        </a>
        <button class="header__toggle" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <div class="overlay" id="overlay"></div>

  <!-- ═══════════════ SIDEBAR ═══════════════ -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar__header">
      <a href="/" class="brand brand--sidebar" id="brand-sidebar">
        <% if (sidebar.header && sidebar.header.logourl) { %>
          <img src="<%= sidebar.header.logourl %>" alt="<%= sidebar.header.alttext %>" class="logoimg">
        <% } else { %>
          <% if (sidebar.header && sidebar.header.alticon) { %><i class="<%= sidebar.header.alticon %> alticon"></i><% } %>
          <% if (sidebar.header && sidebar.header.alttext) { %><span class="alttext"><%= sidebar.header.alttext %></span><% } %>
        <% } %>
      </a>
      <button class="sidebar__close" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <div class="sidebar__body">
      <nav class="navmenu" id="navmenu">
        <% if (sidebar.body && sidebar.body.length > 0) { %>
          <% sidebar.body.forEach(link => { %>
            <a href="<%= link.url || '#' %>" class="navbutton">
              <% if (link.icon) { %><i class="<%= link.icon %>"></i><% } %>
              <div class="navbutton__content">
                <span class="navbutton__text"><%= link.text || '' %></span>
              </div>
            </a>
          <% }) %>
        <% } %>
      </nav>
    </div>

    <div class="sidebar__footer">
      <div class="sociallinks" id="sociallinks">
        <% if (sidebar.footer && sidebar.footer.length > 0) { %>
          <% sidebar.footer.forEach(social => { %>
            <a href="<%= social.url || '#' %>" target="_blank" class="sociallink" rel="noopener">
              <% if (social.icon) { %><i class="<%= social.icon %>"></i><% } %>
            </a>
          <% }) %>
        <% } %>
      </div>
    </div>
  </aside>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero" id="home">
    <div class="container">
      <% if (hero.primarytext) { %>
        <h1 class="hero-title reveal"><%- fmt(hero.primarytext) %></h1>
      <% } %>
      <% if (hero.secondarytext) { %>
        <p class="hero-description reveal"><%- fmt(hero.secondarytext) %></p>
      <% } %>
      <% if (hero.buttonenabled === true || hero.buttonenabled === 'true') { %>
        <a href="<%= hero.buttonurl || '#' %>" class="hero-btn reveal" target="_blank" rel="noopener">
          <% if (hero.buttonicon) { %><i class="<%= hero.buttonicon %>"></i><% } %>
          <span><%= hero.buttontext || '' %></span>
        </a>
      <% } %>
      <% if (hero.footertext) { %>
        <div class="hero-footer reveal"><%- fmt(hero.footertext) %></div>
      <% } %>
    </div>
  </section>

  <!-- ═══════════════ CARDS ═══════════════ -->
  <section class="cards-section container" id="services">
    <% if (cards && cards.data && (cards.data.title || cards.data.description)) { %>
      <div class="cards-header section-header reveal">
        <% if (cards.data.title) { %>
          <h2 class="cards-title section-title"><%- fmt(cards.data.title) %></h2>
        <% } %>
        <% if (cards.data.description) { %>
          <p class="cards-description section-description"><%- fmt(cards.data.description) %></p>
        <% } %>
      </div>
    <% } %>

    <div class="cards-grid">
      <%
        let sortedCards = [];
        if (cards && cards.items && cards.items.length > 0) {
          sortedCards = cards.items.slice().sort((a, b) => (Number(b.rating) || 0) - (Number(a.rating) || 0));
        }
      %>
      <% if (sortedCards.length > 0) { %>
        <% sortedCards.slice(0, 6).forEach(card => { %>
          <a href="<%= card.url || '#' %>" class="card-bg reveal" target="_blank" rel="noopener">

            <% if (card.status && card.status.trim() !== '') {
              let statusClass = 'status-default';
              let statusText = card.status.trim().toLowerCase();
              if (statusText === 'online')      statusClass = 'status-online';
              else if (statusText === 'maintenance') statusClass = 'status-maintenance';
              else if (statusText === 'offline') statusClass = 'status-offline';
              else if (statusText === 'soon')    statusClass = 'status-soon';
            %>
              <div class="card-status <%= statusClass %>">
                <div class="status-dot"></div>
                <span><%= card.status %></span>
              </div>
            <% } %>

            <% if (card.icon) { %>
              <div class="card-icon"><i class="<%= card.icon %>"></i></div>
            <% } %>
            <h3 class="card-title"><%- fmt(card.title || '') %></h3>
            <p class="card-description"><%- fmt(card.description || '') %></p>
          </a>
        <% }) %>
      <% } %>
    </div>

    <% if (cards && cards.data && (cards.data.buttonenabled === true || cards.data.buttonenabled === 'true')) { %>
      <div class="cards-footer reveal">
        <a href="<%= cards.data.buttonurl || '#' %>" class="hero-btn" target="_blank" rel="noopener">
          <% if (cards.data.buttonicon) { %><i class="<%= cards.data.buttonicon %>"></i><% } %>
          <span><%= cards.data.buttontext || '' %></span>
        </a>
      </div>
    <% } %>
  </section>

  <!-- ═══════════════ FAQs ═══════════════ -->
  <section class="faqs-section container" id="faqs">
    <% if (faqs && faqs.data && (faqs.data.title || faqs.data.description)) { %>
      <div class="faqs-header section-header reveal">
        <% if (faqs.data.title) { %>
          <h2 class="faqs-title section-title"><%- fmt(faqs.data.title) %></h2>
        <% } %>
        <% if (faqs.data.description) { %>
          <p class="faqs-description section-description"><%- fmt(faqs.data.description) %></p>
        <% } %>
      </div>
    <% } %>

    <div class="faqs-container">
      <% if (faqs && faqs.items && faqs.items.length > 0) { %>
        <% faqs.items.forEach((faq, index) => { %>
          <div class="faq-item reveal">
            <button class="faq-question" aria-expanded="false">
              <span><%- fmt(faq.title || '') %></span>
              <i class="fa-solid fa-plus faq-icon"></i>
            </button>
            <div class="faq-answer">
              <%- fmt(faq.description || '') %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <% if (faqs && faqs.data && (faqs.data.buttonenabled === true || faqs.data.buttonenabled === 'true')) { %>
      <div class="faqs-footer reveal">
        <a href="<%= faqs.data.buttonurl || '#' %>" class="hero-btn" target="_blank" rel="noopener">
          <% if (faqs.data.buttonicon) { %><i class="<%= faqs.data.buttonicon %>"></i><% } %>
          <span><%= faqs.data.buttontext || '' %></span>
        </a>
      </div>
    <% } %>
  </section>

  <!-- ═══════════════ TEMPLATE HELPER ═══════════════ -->
  <% function fmt(t) {
    if (!t) return '';
    t = t.replace(/\[a url=([^\]]+)\](.*?)\[\/a\]/gi,
      '<a href="$1" target="_blank" rel="noopener" style="color:var(--kex-green);text-decoration:none;">$2</a>');
    t = t.replace(/\[icon\](.*?)\[\/icon\]/gi, '<i class="$1"></i>');
    t = t.replace(/\[color=#([0-9a-fA-F]{3,8})\](.*?)\[\/color\]/gi, '<span style="color:#$1;">$2</span>');
    t = t.replace(/\[b\](.*?)\[\/b\]/gi, '<b>$1</b>');
    t = t.replace(/\[i\](.*?)\[\/i\]/gi, '<i>$1</i>');
    t = t.replace(/\[u\](.*?)\[\/u\]/gi, '<u>$1</u>');
    t = t.replace(/\[br\]/gi, '<br>');
    t = t.replace(/\n/g, '<br>');
    return t;
  } %>

  <!-- ═══════════════ SCRIPTS ═══════════════ -->
  <script>
    /* ── Intersection Observer (reveal) ── */
    document.addEventListener("DOMContentLoaded", () => {
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            obs.unobserve(entry.target);
          }
        });
      }, { root: null, rootMargin: '0px', threshold: 0.08 });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    });

    /* ── Tactile feedback on click ── */
    document.querySelectorAll('.hero-btn, .card-bg, .sociallink').forEach(el => {
      el.addEventListener('click', function(e) {
        const href   = this.getAttribute('href');
        const target = this.getAttribute('target') || '_self';
        const go     = href && href !== '#' && !href.startsWith('#');
        if (go) e.preventDefault();
        this.classList.add('force-active');
        if (go) setTimeout(() => {
          target === '_blank' ? window.open(href, '_blank') : (window.location.href = href);
        }, 200);
        setTimeout(() => { this.classList.remove('force-active'); this.blur(); }, 2500);
      });
    });

    /* ── FAQ accordion ── */
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item   = btn.parentElement;
        const answer = item.querySelector('.faq-answer');
        const active = item.classList.contains('is-active');
        const pad    = parseInt(getComputedStyle(item.querySelector('.faq-question')).paddingBottom) || 24;
        if (!active) {
          item.classList.add('is-active');
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight    = answer.scrollHeight + pad + 'px';
          answer.style.paddingBottom = pad + 'px';
        } else {
          item.classList.remove('is-active');
          btn.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight    = null;
          answer.style.paddingBottom = '0';
        }
      });
    });

    /* ── Scroll-spy + nav ── */
    (function() {
      const navButtons    = document.querySelectorAll('.navbutton');
      const sections      = Array.from(document.querySelectorAll('section[id]'));
      const HEADER_H      = 90;
      let isNavigating    = false;
      let navTimeout      = null;
      let lastActive      = '';

      function setActive(id) {
        navButtons.forEach(btn => {
          const href = btn.getAttribute('href');
          const match = (id === 'home' && (href === '/' || href === '#home')) || href === '#' + id;
          btn.classList.toggle('is-active', match);
        });
      }

      function scrollTop() {
        isNavigating = true;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        history.pushState(null, null, window.location.pathname);
        setActive('home'); lastActive = 'home';
        clearTimeout(navTimeout);
        navTimeout = setTimeout(() => { isNavigating = false; }, 900);
      }

      document.querySelectorAll('.brand').forEach(b => {
        b.addEventListener('click', e => { e.preventDefault(); scrollTop(); window.dispatchEvent(new Event('hideSidebar')); });
      });

      navButtons.forEach(btn => {
        btn.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          if (href === '/' || href === '#home') {
            e.preventDefault(); scrollTop(); window.dispatchEvent(new Event('hideSidebar'));
          } else if (href && href.startsWith('#')) {
            e.preventDefault();
            const el = document.getElementById(href.slice(1));
            if (el) {
              isNavigating = true;
              el.scrollIntoView({ behavior: 'smooth' });
              history.pushState(null, null, href);
              setActive(href.slice(1)); lastActive = href.slice(1);
              window.dispatchEvent(new Event('hideSidebar'));
              clearTimeout(navTimeout);
              navTimeout = setTimeout(() => { isNavigating = false; }, 900);
            }
          }
        });
      });

      let ticking = false;
      function spyUpdate() {
        if (isNavigating) return;
        const sy  = window.scrollY;
        const mid = HEADER_H + window.innerHeight / 3;
        let cur   = null;
        if ((window.innerHeight + sy) >= document.body.offsetHeight - 10) {
          cur = sections[sections.length - 1].id;
        } else if (sy < 50) {
          cur = 'home';
        } else {
          sections.forEach(s => {
            const r = s.getBoundingClientRect();
            if (r.top <= mid && r.bottom >= mid) cur = s.id;
          });
        }
        if (!cur && sections.length) cur = sections[0].id;
        if (cur !== lastActive) {
          lastActive = cur;
          setActive(cur);
          const base = window.location.pathname;
          const url  = cur === 'home' ? base : base + '#' + cur;
          if (window.location.pathname + window.location.hash !== url)
            history.replaceState(null, null, url);
        }
      }
      window.addEventListener('scroll', () => {
        if (!ticking) { window.requestAnimationFrame(() => { spyUpdate(); ticking = false; }); ticking = true; }
      }, { passive: true });

      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      window.addEventListener('load', () => {
        if (window.location.hash) history.replaceState(null, null, window.location.pathname);
        window.scrollTo(0, 0);
        setActive('home'); lastActive = 'home'; spyUpdate();
      });
    })();

    /* ── Snow canvas ── */
    (function() {
      const canvas = document.getElementById('snow-canvas');
      const ctx    = canvas.getContext('2d');
      let W = canvas.width  = window.innerWidth;
      let H = canvas.height = window.innerHeight;

      const COUNT  = W < 768 ? 20 : W > 1400 ? 70 : 50;
      const flakes = Array.from({ length: COUNT }, () => ({
        x: Math.random() * W, y: Math.random() * H,
        r: Math.random() * 1.6 + 0.5,
        d: Math.random() * 0.4 + 0.12,
        a: Math.random() * Math.PI * 2,
        as: Math.random() * 0.01 + 0.005,
        o: Math.random() * 0.4 + 0.12
      }));

      function draw() {
        ctx.clearRect(0, 0, W, H);
        flakes.forEach(f => {
          if (f.o <= 0) return;
          ctx.beginPath();
          ctx.fillStyle = `rgba(255,255,255,${f.o})`;
          ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2, true);
          ctx.fill();
          f.y += f.d; f.a += f.as; f.x += Math.sin(f.a) * 0.28;
          if (f.y > H)      { f.y = -10; f.x = Math.random() * W; }
          if (f.x > W + 10) f.x = -10;
          if (f.x < -10)    f.x = W + 10;
        });
        requestAnimationFrame(draw);
      }
      draw();

      window.addEventListener('resize', () => {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
      });

      /* ── Sidebar ── */
      const openBtn  = document.getElementById('open-sidebar');
      const closeBtn = document.getElementById('close-sidebar');
      const sidebar  = document.getElementById('sidebar');
      const overlay  = document.getElementById('overlay');
      const show = () => { sidebar.classList.add('is-expanded');    overlay.classList.add('is-visible');    document.body.classList.add('has-sidebar-open'); };
      const hide = () => { sidebar.classList.remove('is-expanded'); overlay.classList.remove('is-visible'); document.body.classList.remove('has-sidebar-open'); };
      openBtn.addEventListener('click', show);
      closeBtn.addEventListener('click', hide);
      overlay.addEventListener('click', hide);
      window.addEventListener('hideSidebar', hide);
    })();
  </script>
</body>
</html>
