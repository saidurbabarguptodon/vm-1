<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Tailwind CSS Integration -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            kex: {
              green: '#1ad76f',
              darkGreen: '#0E713B',
              yellow: '#FBBF24',
              darkYellow: '#B45309',
              red: '#EF4444',
              darkRed: '#991B1B',
              blue: '#3B82F6',
              darkBlue: '#1E3A8A',
              white: '#F1F5F9',
              gray: '#94A3B8',
              bg: '#0A0A0F'
            }
          },
          fontFamily: {
            inter: ['Inter', 'sans-serif'],
            playfair:['Playfair Display', 'serif'],
          }
        }
      }
    }
  </script>

  <style type="text/tailwindcss">
    @layer utilities {
      /* Dynamic classes handled by JS to prevent bloated HTML */
      .force-active { @apply scale-95 border-kex-green/40; }
      .navbutton.is-active { @apply bg-kex-darkGreen text-white font-bold; }
      .navbutton.is-active i { @apply text-kex-green; }
      .faq-item.is-active { @apply border-kex-green/30 bg-[#14141E]/60; }
      .faq-item.is-active .faq-icon { @apply rotate-45; }
      
      .reveal { @apply opacity-0 translate-y-[30px] transition-all duration-700 ease-out; }
      .reveal.active { @apply opacity-100 translate-y-0; }
    }

    body.has-sidebar-open { @apply overflow-hidden touch-none; }

    /* Custom Pulse Animation */
    @keyframes pulse-ring {
      0% { transform: scale(0.95); box-shadow: 0 0 0 0 var(--pulse-color); }
      70% { transform: scale(1); box-shadow: 0 0 0 4px transparent; }
      100% { transform: scale(0.95); box-shadow: 0 0 0 0 transparent; }
    }
    .status-dot-anim::after {
      content: '';
      @apply absolute inset-0 rounded-full;
      animation: pulse-ring 2s infinite;
    }

    /* Sidebar Smooth Component Logic */
    .sidebar-panel {
      @apply fixed top-0 bottom-0 left-0 h-[100dvh] w-[80vw] max-w-[280px] bg-[#0F0F14]/65 backdrop-blur-2xl backdrop-saturate-150 z-[999] flex flex-col rounded-r-[24px] border-r border-white/5 shadow-[10px_0_30px_rgba(0,0,0,0.5),inset_-1px_0_0_rgba(255,255,255,0.03)] -translate-x-full transition-transform duration-500 ease-out;
    }
    .sidebar-panel.is-expanded { @apply translate-x-0; }
    
    .sidebar-panel > div { @apply opacity-0 translate-y-[15px] transition-all duration-500; }
    .sidebar-panel.is-expanded > div { @apply opacity-100 translate-y-0; }
    .sidebar-panel.is-expanded .sidebar__header { transition-delay: 100ms; }
    .sidebar-panel.is-expanded .sidebar__body   { transition-delay: 180ms; }
    .sidebar-panel.is-expanded .sidebar__footer { transition-delay: 260ms; }
    
    .sidebar-panel.is-expanded #close-sidebar i { @apply rotate-90; }

    /* Custom Scrollbar for sidebar */
    .sidebar__body::-webkit-scrollbar { width: 5px; }
    .sidebar__body::-webkit-scrollbar-track { background: transparent; }
    .sidebar__body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 10px; }

    /* Faq structural JS targets */
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out, padding 0.3s ease;
    }
  </style>
</head>
<body class="bg-kex-bg text-kex-white font-inter overflow-x-hidden antialiased break-words scroll-smooth">
  
  <canvas id="snow-canvas" class="fixed inset-0 w-full h-full pointer-events-none z-[1]"></canvas>
  <div class="fixed top-[-150px] left-[-150px] w-[500px] h-[500px] bg-kex-green/25 rounded-full z-0 pointer-events-none blur-[100px]"></div>

  <header class="w-[calc(100%-6vw)] sm:w-[calc(100%-16px)] max-w-[1240px] mx-auto mt-[2vw] sm:mt-[10px] bg-[#121218]/65 backdrop-blur-xl backdrop-saturate-150 sticky top-[2vw] sm:top-[10px] z-[100] border border-kex-green/50 rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5),0_0_20px_rgba(26,215,111,0.15)]">
    <div class="relative w-full max-w-[1280px] mx-auto px-[4vw] sm:px-4">
      <nav class="flex justify-between items-center py-[2.5vw] sm:py-3">
        <a href="/" class="brand brand-link flex items-center gap-2.5 h-[8vw] sm:h-[36px] transition-opacity duration-200 no-underline hover:opacity-80" id="brand-header">
          <% if (header.logourl) { %>
            <img src="<%= header.logourl %>" alt="<%= header.alttext %>" class="h-full w-auto object-contain">
          <% } else { %>
            <% if (header.alticon) { %><i class="<%= header.alticon %> text-[clamp(1.4rem,5vw,1.6rem)] inline-block text-kex-green drop-shadow-[0_0_12px_rgba(26,215,111,0.45)]"></i><% } %>
            <% if (header.alttext) { %><span class="text-[clamp(1.3rem,4.5vw,1.5rem)] font-extrabold tracking-tight font-playfair text-white"><%= header.alttext %></span><% } %>
          <% } %>
        </a>
        <button class="flex items-center justify-center w-[10vw] h-[10vw] sm:w-10 sm:h-10 bg-transparent border-none text-kex-white cursor-pointer rounded-lg transition-all duration-150 hover:bg-white/5 active:scale-90 outline-none" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars text-[clamp(1.4rem,5vw,1.6rem)] transition-transform duration-200"></i>
        </button>
      </nav>
    </div>
  </header>

  <div class="fixed inset-0 bg-black/60 backdrop-blur-sm opacity-0 invisible transition-all duration-300 z-[998] cursor-pointer" id="overlay"></div>

  <aside class="sidebar-panel" id="sidebar">
    <div class="sidebar__header flex justify-between items-center px-[6vw] sm:px-6 border-b border-white/5 h-[73px] shrink-0">
      <a href="/" class="brand brand-link flex items-center gap-2 h-[32px] transition-opacity duration-200 no-underline hover:opacity-80" id="brand-sidebar">
        <% if (sidebar.header && sidebar.header.logourl) { %>
          <img src="<%= sidebar.header.logourl %>" alt="<%= sidebar.header.alttext %>" class="h-full w-auto object-contain">
        <% } else { %>
          <% if (sidebar.header && sidebar.header.alticon) { %><i class="<%= sidebar.header.alticon %> text-[1.4rem] inline-block text-kex-green drop-shadow-[0_0_12px_rgba(26,215,111,0.45)]"></i><% } %>
          <% if (sidebar.header && sidebar.header.alttext) { %><span class="text-[1.3rem] font-extrabold tracking-tight font-playfair text-white"><%= sidebar.header.alttext %></span><% } %>
        <% } %>
      </a>
      <button class="flex items-center justify-center w-9 h-9 bg-transparent border-none text-kex-white cursor-pointer rounded-lg transition-all duration-150 hover:bg-white/5 active:scale-90 -mr-2" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark text-[1.5rem] transition-transform duration-200"></i>
      </button>
    </div>

    <div class="sidebar__body flex-1 p-[4vw] sm:p-4 pb-5 overflow-y-auto">
      <nav class="flex flex-col gap-1.5" id="navmenu">
        <% if (sidebar.body && sidebar.body.length > 0) { %>
          <% sidebar.body.forEach(link => { %>
            <a href="<%= link.url || '#' %>" class="navbutton flex items-center gap-3 p-3.5 min-h-[56px] text-white no-underline rounded-xl transition-all duration-300 overflow-hidden hover:bg-kex-darkGreen hover:translate-x-1 hover:text-white group">
              <% if (link.icon) { %><i class="<%= link.icon %> text-[1.25rem] w-7 text-center shrink-0 text-kex-green group-hover:text-kex-green transition-colors"></i><% } %>
              <div class="flex flex-col justify-center leading-snug">
                <span class="text-[clamp(1rem,4vw,1.05rem)] font-medium text-inherit transition-colors"><%= link.text || '' %></span>
              </div>
            </a>
          <% }) %>
        <% } %>
      </nav>
    </div>

    <div class="sidebar__footer border-t border-white/5 shrink-0 mt-auto min-h-[calc(73px+env(safe-area-inset-bottom))] px-[6vw] sm:px-6 py-[4vw] sm:py-[15px] pb-[calc(4vw+env(safe-area-inset-bottom))] sm:pb-[calc(15px+env(safe-area-inset-bottom))] flex items-center justify-center bg-black/15">
      <div class="flex flex-wrap justify-center gap-[3vw] sm:gap-3 w-full" id="sociallinks">
        <% if (sidebar.footer && sidebar.footer.length > 0) { %>
          <% sidebar.footer.forEach(social => { %>
            <a href="<%= social.url || '#' %>" target="_blank" class="sociallink flex items-center justify-center w-[11vw] h-[11vw] sm:w-[42px] sm:h-[42px] bg-kex-green border border-kex-green text-white rounded-full no-underline text-[5vw] sm:text-[19px] transition-all duration-300 hover:bg-kex-darkGreen hover:border-kex-darkGreen hover:-translate-y-1 hover:scale-105 hover:shadow-[0_10px_20px_-5px_rgba(26,215,111,0.5)] active:bg-kex-darkGreen active:scale-95" rel="noopener">
              <% if (social.icon) { %><i class="<%= social.icon %>"></i><% } %>
            </a>
          <% }) %>
        <% } %>
      </div>
    </div>
  </aside>

  <section class="relative z-10 w-full max-w-[1280px] mx-auto px-[5vw] sm:px-[20px] pt-[20vw] sm:pt-[100px] pb-[15vw] sm:pb-[80px] flex flex-col items-center justify-center text-center min-h-[50vh] scroll-mt-[80px]" id="home">
    <% if (hero.primarytext) { %>
      <h1 class="text-[clamp(1.8rem,7vw,2.8rem)] font-extrabold leading-[1.15] tracking-tight text-kex-white mb-[4vw] sm:mb-5 reveal"><%- fmt(hero.primarytext) %></h1>
    <% } %>
    <% if (hero.secondarytext) { %>
      <p class="text-[clamp(1.05rem,4.5vw,1.4rem)] text-kex-gray mb-[8vw] sm:mb-8 max-w-[800px] reveal"><%- fmt(hero.secondarytext) %></p>
    <% } %>
    <% if (hero.buttonenabled === true || hero.buttonenabled === 'true') { %>
      <a href="<%= hero.buttonurl || '#' %>" class="hero-btn reveal inline-flex items-center justify-center gap-2 bg-kex-green text-white font-semibold text-[clamp(1rem,4vw,1.1rem)] py-[3.5vw] px-[7vw] sm:py-3.5 sm:px-6 rounded-full no-underline transition-all duration-300 shadow-[0_8px_20px_-6px_rgba(26,215,111,0.5)] mb-[6vw] sm:mb-6 hover:bg-kex-darkGreen hover:-translate-y-0.5 hover:shadow-[0_12px_24px_-8px_rgba(26,215,111,0.6)] active:bg-kex-darkGreen active:scale-95 outline-none" target="_blank" rel="noopener">
        <% if (hero.buttonicon) { %><i class="<%= hero.buttonicon %> text-[1.3rem] not-italic"></i><% } %>
        <span><%= hero.buttontext || '' %></span>
      </a>
    <% } %>
    <% if (hero.footertext) { %>
      <div class="text-[clamp(0.85rem,3.5vw,0.95rem)] text-kex-gray opacity-80 reveal"><%- fmt(hero.footertext) %></div>
    <% } %>
  </section>

  <section class="relative z-10 w-full max-w-[1280px] mx-auto px-[5vw] sm:px-[20px] pt-[10vw] pb-[20vw] sm:pt-[40px] sm:pb-[100px] scroll-mt-[85px]" id="services">
    <% if (cards && cards.data && (cards.data.title || cards.data.description)) { %>
      <div class="text-center mb-[10vw] sm:mb-[50px] reveal">
        <% if (cards.data.title) { %>
          <h2 class="text-[clamp(1.8rem,6vw,2.4rem)] font-extrabold text-kex-white mb-4 tracking-tight"><%- fmt(cards.data.title) %></h2>
        <% } %>
        <% if (cards.data.description) { %>
          <p class="text-[clamp(1rem,4vw,1.15rem)] text-kex-gray max-w-[650px] mx-auto leading-relaxed"><%- fmt(cards.data.description) %></p>
        <% } %>
      </div>
    <% } %>

    <div class="flex flex-wrap justify-center gap-[5vw] sm:gap-6 w-full">
      <% 
        let sortedCards =[];
        if (cards && cards.items && cards.items.length > 0) {
          sortedCards = cards.items.slice().sort((a, b) => (Number(b.rating) || 0) - (Number(a.rating) || 0));
        }
      %>
      <% if (sortedCards.length > 0) { %>
        <% sortedCards.slice(0, 6).forEach(card => { %>
          <a href="<%= card.url || '#' %>" class="card-bg reveal group flex-1 basis-[100%] sm:basis-[320px] max-w-full sm:max-w-[400px] min-w-[min(100%,280px)] bg-[#14141E]/40 border border-white/5 rounded-[5vw] sm:rounded-2xl p-[6vw] sm:p-7 flex flex-col items-start transition-all duration-300 backdrop-blur-md relative overflow-hidden outline-none hover:-translate-y-2 hover:border-kex-green/40 hover:shadow-[0_15px_35px_-10px_rgba(0,0,0,0.6),0_0_25px_rgba(26,215,111,0.08)] active:scale-[0.98] active:border-kex-green/40" target="_blank" rel="noopener">
            
            <% if (card.status && card.status.trim() !== '') { 
              let statusColorText = 'text-kex-white';
              let statusBorder = 'border-kex-white/10';
              let statusBg = 'bg-kex-white/5';
              let dotBg = 'bg-kex-white';
              let pulseColor = 'rgba(255,255,255,0.7)';
              
              let statusText = card.status.trim().toLowerCase();
              if (statusText === 'online') { 
                statusColorText = 'text-kex-green'; statusBorder = 'border-kex-green/20'; statusBg = 'bg-kex-green/5'; dotBg = 'bg-kex-green'; pulseColor = 'rgba(26,215,111,0.7)';
              } else if (statusText === 'maintenance') { 
                statusColorText = 'text-kex-yellow'; statusBorder = 'border-kex-yellow/20'; statusBg = 'bg-kex-yellow/5'; dotBg = 'bg-kex-yellow'; pulseColor = 'rgba(251,191,36,0.7)';
              } else if (statusText === 'offline') { 
                statusColorText = 'text-kex-red'; statusBorder = 'border-kex-red/20'; statusBg = 'bg-kex-red/5'; dotBg = 'bg-kex-red'; pulseColor = 'rgba(239,68,68,0.7)';
              } else if (statusText === 'soon') { 
                statusColorText = 'text-kex-blue'; statusBorder = 'border-kex-blue/20'; statusBg = 'bg-kex-blue/5'; dotBg = 'bg-kex-blue'; pulseColor = 'rgba(59,130,246,0.7)';
              }
            %>
              <div class="absolute top-[4vw] sm:top-6 right-[4vw] sm:right-6 flex items-center gap-1.5 py-1 px-2.5 rounded-full text-[0.65rem] font-bold tracking-wider uppercase border pointer-events-none transition-all duration-300 <%= statusColorText %> <%= statusBorder %> <%= statusBg %>">
                <div class="w-1.5 h-1.5 rounded-full relative status-dot-anim <%= dotBg %>" style="--pulse-color: <%= pulseColor %>"></div>
                <span><%= card.status %></span>
              </div>
            <% } %>

            <% if (card.icon) { %>
              <div class="card-icon flex items-center justify-center w-[12vw] h-[12vw] sm:w-14 sm:h-14 bg-kex-green/10 text-kex-green rounded-2xl text-[1.6rem] mb-[5vw] sm:mb-6 transition-all duration-300 group-hover:scale-110 group-hover:-rotate-3 group-hover:bg-kex-green group-hover:text-white group-hover:shadow-[0_8px_20px_-6px_rgba(26,215,111,0.5)] group-active:scale-110 group-active:-rotate-3 group-active:bg-kex-green group-active:text-white group-active:shadow-[0_8px_20px_-6px_rgba(26,215,111,0.5)]">
                <i class="<%= card.icon %>"></i>
              </div>
            <% } %>
            <h3 class="text-[clamp(1.2rem,4.5vw,1.3rem)] font-bold text-kex-white mb-3 leading-snug transition-colors duration-300 group-hover:text-kex-green group-active:text-kex-green"><%- fmt(card.title || '') %></h3>
            <p class="text-[clamp(0.9rem,3.5vw,0.95rem)] text-kex-gray leading-relaxed flex-grow"><%- fmt(card.description || '') %></p>
          </a>
        <% }) %>
      <% } %>
    </div>

    <% if (cards && cards.data && (cards.data.buttonenabled === true || cards.data.buttonenabled === 'true')) { %>
      <div class="flex justify-center w-full mt-[10vw] sm:mt-[48px] reveal">
        <a href="<%= cards.data.buttonurl || '#' %>" class="hero-btn inline-flex items-center justify-center gap-2 bg-kex-green text-white font-semibold text-[clamp(1rem,4vw,1.1rem)] py-[3.5vw] px-[7vw] sm:py-3.5 sm:px-6 rounded-full no-underline transition-all duration-300 shadow-[0_8px_20px_-6px_rgba(26,215,111,0.5)] hover:bg-kex-darkGreen hover:-translate-y-0.5 hover:shadow-[0_12px_24px_-8px_rgba(26,215,111,0.6)] active:bg-kex-darkGreen active:scale-95 outline-none" target="_blank" rel="noopener">
          <% if (cards.data.buttonicon) { %><i class="<%= cards.data.buttonicon %>"></i><% } %>
          <span><%= cards.data.buttontext || '' %></span>
        </a>
      </div>
    <% } %>
  </section>

  <section class="relative z-10 w-full max-w-[1280px] mx-auto px-[5vw] sm:px-[20px] pt-[15vw] pb-[20vw] sm:pt-[60px] sm:pb-[100px] scroll-mt-[85px]" id="faqs">
    <% if (faqs && faqs.data && (faqs.data.title || faqs.data.description)) { %>
      <div class="text-center mb-[10vw] sm:mb-[50px] reveal">
        <% if (faqs.data.title) { %>
          <h2 class="text-[clamp(1.8rem,6vw,2.4rem)] font-extrabold text-kex-white mb-4 tracking-tight"><%- fmt(faqs.data.title) %></h2>
        <% } %>
        <% if (faqs.data.description) { %>
          <p class="text-[clamp(1rem,4vw,1.15rem)] text-kex-gray max-w-[650px] mx-auto leading-relaxed"><%- fmt(faqs.data.description) %></p>
        <% } %>
      </div>
    <% } %>

    <div class="flex flex-wrap justify-center items-start gap-[5vw] sm:gap-6 w-full">
      <% if (faqs && faqs.items && faqs.items.length > 0) { %>
        <% faqs.items.forEach((faq, index) => { %>
          <div class="faq-item reveal flex-1 basis-[100%] sm:basis-[320px] max-w-full sm:max-w-[400px] min-w-[min(100%,280px)] bg-[#14141E]/40 border border-white/5 rounded-2xl overflow-hidden transition-all duration-300 backdrop-blur-md">
            <button class="faq-question w-full text-left bg-transparent border-none p-[5vw] sm:p-6 flex justify-between items-center text-kex-white text-[clamp(1rem,4vw,1.1rem)] font-semibold cursor-pointer transition-colors duration-300 outline-none hover:text-kex-green">
              <span><%- fmt(faq.title || '') %></span>
              <i class="fa-solid fa-plus faq-icon text-kex-green text-xl shrink-0 ml-4 transition-transform duration-300"></i>
            </button>
            <div class="faq-answer px-[5vw] sm:px-6 text-kex-gray text-[clamp(0.9rem,3.5vw,0.95rem)] leading-relaxed">
              <%- fmt(faq.description || '') %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <% if (faqs && faqs.data && (faqs.data.buttonenabled === true || faqs.data.buttonenabled === 'true')) { %>
      <div class="flex justify-center w-full mt-[10vw] sm:mt-[48px] reveal">
        <a href="<%= faqs.data.buttonurl || '#' %>" class="hero-btn inline-flex items-center justify-center gap-2 bg-kex-green text-white font-semibold text-[clamp(1rem,4vw,1.1rem)] py-[3.5vw] px-[7vw] sm:py-3.5 sm:px-6 rounded-full no-underline transition-all duration-300 shadow-[0_8px_20px_-6px_rgba(26,215,111,0.5)] hover:bg-kex-darkGreen hover:-translate-y-0.5 hover:shadow-[0_12px_24px_-8px_rgba(26,215,111,0.6)] active:bg-kex-darkGreen active:scale-95 outline-none" target="_blank" rel="noopener">
          <% if (faqs.data.buttonicon) { %><i class="<%= faqs.data.buttonicon %>"></i><% } %>
          <span><%= faqs.data.buttontext || '' %></span>
        </a>
      </div>
    <% } %>
  </section>

  <% function fmt(t) {
    if (!t) return '';
    
    t = t.replace(/\[a url=([^\]]+)\](.*?)\[\/a\]/gi, '<a href="$1" target="_blank" rel="noopener" class="text-kex-green no-underline hover:underline">$2</a>');
    t = t.replace(/\[icon\](.*?)\[\/icon\]/gi, '<i class="$1"></i>');
    t = t.replace(/\[color=#([0-9a-fA-F]{3,8})\](.*?)\[\/color\]/gi, '<span style="color: #$1;">$2</span>');
    t = t.replace(/\[b\](.*?)\[\/b\]/gi, '<b class="font-extrabold">$1</b>');
    t = t.replace(/\[i\](.*?)\[\/i\]/gi, '<i class="italic">$1</i>');
    t = t.replace(/\[u\](.*?)\[\/u\]/gi, '<u class="underline">$1</u>');
    t = t.replace(/\[br\]/gi, '<br>');
    /* Flexibly collapsing break tags ensuring mobile users aren't zoomed out due to giant unbreaking strings */
    t = t.replace(/\n/g, ' <br class="hidden sm:block"> ');
    return t;
  } %>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };
      const observer = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    });

    document.querySelectorAll('.hero-btn, .card-bg, .sociallink').forEach(el => {
      el.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        const target = this.getAttribute('target') || '_self';
        const isActionable = href && href !== '#' && !href.startsWith('#');

        if (isActionable) {
          e.preventDefault();
        }

        this.classList.add('force-active');

        if (isActionable) {
          setTimeout(() => {
            if (target === '_blank') {
              window.open(href, '_blank');
            } else {
              window.location.href = href;
            }
          }, 200);
        }

        setTimeout(() => {
          this.classList.remove('force-active');
          this.blur();
        }, 2500);
      });
    });

    document.querySelectorAll('.faq-question').forEach(button => {
      button.addEventListener('click', () => {
        const faqItem = button.parentElement;
        const answer = faqItem.querySelector('.faq-answer');
        const isActive = faqItem.classList.contains('is-active');

        if (!isActive) {
          faqItem.classList.add('is-active');
          button.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 24 + "px";
          answer.style.paddingBottom = "24px";
        } else {
          faqItem.classList.remove('is-active');
          button.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = null;
          answer.style.paddingBottom = "0";
        }
      });
    });

    (function() {
      const navButtons = document.querySelectorAll('.navbutton');
      const sections = Array.from(document.querySelectorAll('section[id]'));
      const headerHeight = 85; 
      
      let isNavigating = false;
      let navTimeout = null;
      let lastActiveSection = '';

      function setNavActive(sectionId) {
        navButtons.forEach(btn => {
          const href = btn.getAttribute('href');
          if ((sectionId === 'home' && (href === '/' || href === '#home')) || href === `#${sectionId}`) {
            btn.classList.add('is-active');
          } else {
            btn.classList.remove('is-active');
          }
        });
      }

      function scrollToTop() {
        isNavigating = true;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        history.pushState(null, null, window.location.pathname);
        setNavActive('home');
        lastActiveSection = 'home';
        
        clearTimeout(navTimeout);
        navTimeout = setTimeout(() => { isNavigating = false; }, 800); 
      }

      document.querySelectorAll('.brand-link').forEach(brand => {
        brand.addEventListener('click', function(e) {
          e.preventDefault();
          scrollToTop();
          window.dispatchEvent(new Event('hideSidebar'));
        });
      });

      navButtons.forEach(btn => {
        btn.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          
          if (href === '/' || href === '#home') {
            e.preventDefault();
            scrollToTop();
            window.dispatchEvent(new Event('hideSidebar'));
          } else if (href && href.startsWith('#')) {
            e.preventDefault();
            const targetId = href.substring(1);
            const target = document.getElementById(targetId);
            
            if (target) {
              isNavigating = true; 
              target.scrollIntoView({ behavior: 'smooth' });
              
              history.pushState(null, null, href);
              setNavActive(targetId);
              lastActiveSection = targetId;
              
              window.dispatchEvent(new Event('hideSidebar'));
              clearTimeout(navTimeout);
              navTimeout = setTimeout(() => { isNavigating = false; }, 800); 
            }
          }
        });
      });

      let isScrolling = false;

      function updateScrollSpy() {
        if (isNavigating) return; 
        
        const scrollPosition = window.scrollY || document.documentElement.scrollTop;
        let currentSection = null;

        const viewportMiddle = headerHeight + (window.innerHeight / 3);

        if ((window.innerHeight + scrollPosition) >= document.body.offsetHeight - 10) {
          currentSection = sections[sections.length - 1].id;
        } 
        else if (scrollPosition < 50) {
          currentSection = 'home';
        } 
        else {
          sections.forEach(sec => {
            const rect = sec.getBoundingClientRect();
            if (rect.top <= viewportMiddle && rect.bottom >= viewportMiddle) {
              currentSection = sec.id;
            }
          });
        }

        if (!currentSection && sections.length) {
          currentSection = sections[0].id;
        }

        if (currentSection !== lastActiveSection) {
          lastActiveSection = currentSection;
          setNavActive(currentSection);
          
          const basePath = window.location.pathname;
          const newUrl = currentSection === 'home' ? basePath : basePath + '#' + currentSection;
          
          if (window.location.pathname + window.location.hash !== newUrl) {
            history.replaceState(null, null, newUrl);
          }
        }
      }

      window.addEventListener('scroll', () => {
        if (!isScrolling) {
          window.requestAnimationFrame(() => {
            updateScrollSpy();
            isScrolling = false;
          });
          isScrolling = true;
        }
      }, { passive: true });

      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }

      window.addEventListener('load', () => {
        if (window.location.hash) {
          history.replaceState(null, null, window.location.pathname);
        }
        window.scrollTo(0, 0);

        setNavActive('home');
        lastActiveSection = 'home';
        updateScrollSpy(); 
      });
    })();

    (function() {
      const canvas = document.getElementById('snow-canvas');
      const ctx = canvas.getContext('2d');
      let width = window.innerWidth;
      let height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
      
      const maxFlakes = width < 768 ? 20 : 50; 
      const flakes =[];

      for (let i = 0; i < maxFlakes; i++) {
        flakes.push({
          x: Math.random() * width,
          y: Math.random() * height,
          r: Math.random() * 1.5 + 0.5,
          d: Math.random() * 0.4 + 0.15, 
          a: Math.random() * Math.PI * 2,
          aStep: Math.random() * 0.01 + 0.005,
          opacity: Math.random() * 0.4 + 0.15
        });
      }

      function drawSnow() {
        ctx.clearRect(0, 0, width, height);

        for (let i = 0; i < maxFlakes; i++) {
          let f = flakes[i];

          if (f.opacity > 0) {
            ctx.beginPath();
            ctx.fillStyle = `rgba(255, 255, 255, ${f.opacity})`;
            ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2, true);
            ctx.fill();
          }
        }
        
        moveSnow();
        requestAnimationFrame(drawSnow);
      }

      function moveSnow() {
        for (let i = 0; i < maxFlakes; i++) {
          let f = flakes[i];
          f.y += f.d;
          f.a += f.aStep;
          f.x += Math.sin(f.a) * 0.25; 

          if (f.y > height) { 
            f.y = -10; 
            f.x = Math.random() * width; 
          }
          if (f.x > width + 10) f.x = -10;
          if (f.x < -10) f.x = width + 10;
        }
      }

      window.addEventListener('resize', () => {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
      });
      
      drawSnow();

      const openBtn   = document.getElementById('open-sidebar');
      const closeBtn  = document.getElementById('close-sidebar');
      const sidebarEl = document.getElementById('sidebar');
      const overlay   = document.getElementById('overlay');

      function showSidebar() {
        sidebarEl.classList.add('is-expanded');
        overlay.classList.add('is-visible');
        document.body.classList.add('has-sidebar-open');
      }
      function hideSidebar() {
        sidebarEl.classList.remove('is-expanded');
        overlay.classList.remove('is-visible');
        document.body.classList.remove('has-sidebar-open');
      }

      openBtn.addEventListener('click', showSidebar);
      closeBtn.addEventListener('click', hideSidebar);
      overlay.addEventListener('click', hideSidebar);
      window.addEventListener('hideSidebar', hideSidebar);
    })();
  </script>
</body>
</html>
