<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Dynamic Header & Sidebar</title>
  <!-- Added Playfair Display to the Google Fonts link -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --kex-green: #1ad76f;
      --kex-dark-green: #0E713B;
      --kex-white: #F1F5F9;
      --kex-gray: #94A3B8;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    body {
      max-width: 100vw;
      overflow-x: hidden;
      font-family: 'Inter', sans-serif;
      background-color: #0A0A0F;
      color: var(--kex-white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      scroll-behavior: smooth;
    }
    body.has-sidebar-open { overflow: hidden; touch-action: none; }

    #snow-canvas {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    /* Lamp glow – enhanced for a softer, brighter focus */
    .glow {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 380px;
      background: 
        radial-gradient(ellipse 50% 70% at 50% 0%, rgba(26,215,111, 0.45) 0%, rgba(26,215,111, 0.2) 30%, rgba(26,215,111, 0.05) 65%, transparent 100%),
        radial-gradient(ellipse 30% 50% at 50% 0%, rgba(255,255,255,0.15) 0%, transparent 60%);
      z-index: 0;
      pointer-events: none;
      filter: blur(2px);
    }

    .container { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; padding: 0 24px; }

    .header {
      width: 100%;
      background: rgba(15,15,20,.75);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      position: sticky; top: 0; z-index: 100;
      border-bottom: 1px solid rgba(255,255,255,.08);
      box-shadow: 0 10px 30px -8px rgba(0,0,0,.6);
    }
    .header__nav { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; }

    .header__toggle, .sidebar__close {
      background: transparent;
      border: none;
      color: var(--kex-gray);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      border-radius: 8px;
      transition: all 0.15s ease;
      margin-right: -8px;
    }
    .header__toggle { font-size: 1.6rem; width: 44px; height: 44px; }
    .header__toggle i { transition: transform 0.2s ease; }
    .header__toggle:hover, .sidebar__close:hover { background: rgba(255,255,255,.06); color: #fff; }
    .header__toggle:active i { transform: scale(0.85); }
    .sidebar__close { font-size: 1.5rem; width: 36px; height: 36px; }
    .sidebar.is-expanded .sidebar__close i { transform: rotate(90deg); }

    .brand { display: flex; align-items: center; gap: 10px; transition: opacity 0.2s ease; text-decoration: none; }
    .brand:hover { opacity: 0.8; }
    .brand--header { height: 40px; margin-left: -12px; }
    .brand--sidebar { height: 32px; }

    .logoimg { height: 100%; width: auto; object-fit: contain; }
    .alticon, .alttext { 
      color: var(--kex-green); 
      text-shadow: 0 0 12px rgba(26,215,111,.45); 
    }
    .alticon { font-size: 1.6rem; display: inline-block; }
    
    /* Applied Playfair Display font here */
    .alttext { 
      font-size: 1.7rem; 
      font-weight: 800; 
      letter-spacing: -0.5px; 
      font-family: 'Playfair Display', serif; 
    }

    .overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.6);
      backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
      opacity: 0; visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998; cursor: pointer;
    }
    .overlay.is-visible { opacity: 1; visibility: visible; }

    .sidebar {
      position: fixed; top: 0; bottom: 0; left: 0;
      height: 100vh; height: 100dvh;
      width: 280px; max-width: 80vw;
      background: rgba(15,15,20,.85);
      backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
      z-index: 999;
      display: flex; flex-direction: column;
      border-radius: 0 24px 24px 0;
      border-right: 1px solid rgba(255,255,255,.08);
      box-shadow: 10px 0 30px rgba(0,0,0,.5);
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
    }
    .sidebar.is-expanded { transform: translateX(0); }

    .sidebar__header, .sidebar__body, .sidebar__footer {
      opacity: 0; transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16,1,0.3,1);
    }
    .sidebar.is-expanded .sidebar__header,
    .sidebar.is-expanded .sidebar__body,
    .sidebar.is-expanded .sidebar__footer { opacity: 1; transform: translateY(0); }
    .sidebar.is-expanded .sidebar__header { transition-delay: 0.1s; }
    .sidebar.is-expanded .sidebar__body   { transition-delay: 0.18s; }
    .sidebar.is-expanded .sidebar__footer { transition-delay: 0.26s; }

    .sidebar__header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0 24px;
      border-bottom: 1px solid rgba(255,255,255,.08);
      height: 73px; flex-shrink: 0;
    }
    .sidebar__body {
      flex: 1;
      padding: 16px 12px 20px;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,.15) transparent;
    }
    .sidebar__body::-webkit-scrollbar { width: 5px; }
    .sidebar__body::-webkit-scrollbar-track { background: transparent; }
    .sidebar__body::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 10px; }
    .sidebar__footer {
      border-top: 1px solid rgba(255,255,255,.08);
      flex-shrink: 0; margin-top: auto;
      min-height: calc(73px + env(safe-area-inset-bottom));
      padding: 15px 24px calc(15px + env(safe-area-inset-bottom));
      display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,.15);
    }

    .navmenu { display: flex; flex-direction: column; gap: 6px; }
    .navbutton {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 15px; min-height: 56px;
      color: #fff; text-decoration: none;
      border-radius: 12px;
      transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
      position: relative; overflow: hidden;
    }
    .navbutton i { 
      font-size: 1.25rem; width: 28px; text-align: center; flex-shrink: 0; 
      color: var(--kex-green); transition: color 0.2s ease; 
    }
    .navbutton:hover { 
      background: var(--kex-dark-green); 
      transform: translateX(4px); 
      color: #fff; 
    }
    .navbutton:hover i { color: var(--kex-green); }
    .navbutton.is-active { 
      background: var(--kex-dark-green); 
      color: #fff; 
    }
    .navbutton.is-active i { color: var(--kex-green); }
    .navbutton.is-active .navbutton__text { color: #fff; font-weight: 700; }
    .navbutton__content { display: flex; flex-direction: column; justify-content: center; line-height: 1.3; }
    .navbutton__text { font-size: 1.05rem; font-weight: 500; color: inherit; transition: color 0.2s ease; }

    .sociallinks { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; width: 100%; }
    .sociallink {
      display: flex; align-items: center; justify-content: center;
      width: 42px; height: 42px;
      background-color: var(--kex-green);
      border: 1px solid var(--kex-green);
      color: #fff; border-radius: 50%;
      text-decoration: none; font-size: 19px;
      transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    }
    .sociallink:hover {
      background-color: var(--kex-dark-green);
      border-color: var(--kex-dark-green);
      color: #fff;
      transform: translateY(-4px) scale(1.05);
      box-shadow: 0 10px 20px -5px rgba(26,215,111,.5);
    }
    .sociallink:active {
      background-color: var(--kex-dark-green);
      border-color: var(--kex-dark-green);
    }

    .herobtn {
      display: inline-flex; align-items: center; gap: 8px;
      background-color: var(--kex-green); 
      color: #fff;
      font-weight: 600; font-size: 1.1rem;
      padding: 14px 24px; border-radius: 60px;
      text-decoration: none;
      transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
      box-shadow: 0 8px 20px -6px rgba(26,215,111,.5);
      margin-bottom: 40px;
    }
    .herobtn i { font-size: 1.3rem; font-style: normal !important; }
    .herobtn:hover { 
      background-color: var(--kex-dark-green); 
      transform: translateY(-2px); 
      box-shadow: 0 12px 24px -8px rgba(26,215,111,.6); 
    }

    .hero { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 80px 24px 60px; position: relative; }
    .primarytext {
      font-size: clamp(1.8rem,5vw,2.8rem);
      font-weight: 800; line-height: 1.2; letter-spacing: -0.02em;
      color: var(--kex-white); text-shadow: none;
      margin-bottom: 20px; hyphens: auto;
    }
    .secondarytext {
      font-size: clamp(1.1rem,4vw,1.4rem);
      color: var(--kex-gray); margin-bottom: 32px; hyphens: auto;
    }
    .footertext { font-size: 0.95rem; color: var(--kex-gray); opacity: 0.8; }

    /* ========================================= */
    /* CARDS SECTION STYLES                      */
    /* ========================================= */
    .cards-section {
      padding: 60px 24px 100px;
      position: relative;
      z-index: 2;
    }
    .section-header {
      text-align: center;
      margin-bottom: 48px;
    }
    .section-title {
      font-size: clamp(1.8rem, 4vw, 2.4rem);
      font-weight: 800;
      color: var(--kex-white);
      margin-bottom: 16px;
      letter-spacing: -0.02em;
    }
    .section-desc {
      font-size: clamp(1rem, 3vw, 1.15rem);
      color: var(--kex-gray);
      max-width: 650px;
      margin: 0 auto;
      line-height: 1.6;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      width: 100%;
    }
    .card {
      background: rgba(20, 20, 30, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 20px;
      padding: 32px 28px;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      position: relative;
      overflow: hidden;
    }
    .card:hover {
      transform: translateY(-8px);
      /* Removed the hover background change to keep the card consistent */
      border-color: rgba(26, 215, 111, 0.4);
      box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.6), 0 0 25px rgba(26, 215, 111, 0.08);
    }
    .card__icon-wrapper {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      background: rgba(26, 215, 111, 0.1);
      color: var(--kex-green);
      border-radius: 14px;
      font-size: 1.6rem;
      margin-bottom: 24px;
      transition: all 0.3s ease;
    }
    .card:hover .card__icon-wrapper {
      transform: scale(1.1) rotate(-5deg);
      background: var(--kex-green);
      color: #fff;
      box-shadow: 0 8px 20px -6px rgba(26, 215, 111, 0.5);
    }
    .card__title {
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--kex-white);
      margin-bottom: 12px;
      line-height: 1.3;
      transition: color 0.3s ease;
    }
    .card__desc {
      font-size: 0.95rem;
      color: var(--kex-gray);
      line-height: 1.6;
    }
    .card:hover .card__title {
      color: var(--kex-green);
    }
  </style>
</head>
<body>
  <canvas id="snow-canvas"></canvas>
  <div class="glow"></div>

  <header class="header">
    <div class="container">
      <nav class="header__nav">
        <a href="/" class="brand brand--header" id="brand-header">
          <% if (header.logourl) { %>
            <img src="<%= header.logourl %>" alt="<%= header.alttext %>" class="logoimg">
          <% } else { %>
            <% if (header.alticon) { %><i class="<%= header.alticon %> alticon"></i><% } %>
            <% if (header.alttext) { %><span class="alttext"><%= header.alttext %></span><% } %>
          <% } %>
        </a>
        <button class="header__toggle" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <div class="overlay" id="overlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar__header">
      <a href="/" class="brand brand--sidebar" id="brand-sidebar">
        <% if (sidebar.header && sidebar.header.logourl) { %>
          <img src="<%= sidebar.header.logourl %>" alt="<%= sidebar.header.alttext %>" class="logoimg">
        <% } else { %>
          <% if (sidebar.header && sidebar.header.alticon) { %><i class="<%= sidebar.header.alticon %> alticon"></i><% } %>
          <% if (sidebar.header && sidebar.header.alttext) { %><span class="alttext"><%= sidebar.header.alttext %></span><% } %>
        <% } %>
      </a>
      <button class="sidebar__close" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <div class="sidebar__body">
      <nav class="navmenu" id="navmenu">
        <% if (sidebar.body && sidebar.body.length > 0) { %>
          <% sidebar.body.forEach(link => { %>
            <a href="<%= link.url || '#' %>" class="navbutton">
              <% if (link.icon) { %><i class="<%= link.icon %>"></i><% } %>
              <div class="navbutton__content">
                <span class="navbutton__text"><%= link.text || '' %></span>
              </div>
            </a>
          <% }) %>
        <% } %>
      </nav>
    </div>

    <div class="sidebar__footer">
      <div class="sociallinks" id="sociallinks">
        <% if (sidebar.footer && sidebar.footer.length > 0) { %>
          <% sidebar.footer.forEach(social => { %>
            <a href="<%= social.url || '#' %>" target="_blank" class="sociallink" rel="noopener">
              <% if (social.icon) { %><i class="<%= social.icon %>"></i><% } %>
            </a>
          <% }) %>
        <% } %>
      </div>
    </div>
  </aside>

  <!-- HERO SECTION -->
  <section class="hero" id="home">
    <div class="container" style="padding: 0; width: 100%; max-width: 100%;">
      <% if (hero.primarytext) { %>
        <h1 class="primarytext"><%- fmt(hero.primarytext) %></h1>
      <% } %>
      <% if (hero.secondarytext) { %>
        <p class="secondarytext"><%- fmt(hero.secondarytext) %></p>
      <% } %>
      <% if (hero.buttonenabled === true || hero.buttonenabled === 'true') { %>
        <a href="<%= hero.buttonurl || '#' %>" class="herobtn">
          <% if (hero.buttonicon) { %><i class="<%= hero.buttonicon %>"></i><% } %>
          <span><%= hero.buttontext || '' %></span>
        </a>
      <% } %>
      <% if (hero.footertext) { %>
        <div class="footertext"><%- fmt(hero.footertext) %></div>
      <% } %>
    </div>
  </section>

  <!-- CARDS SECTION -->
  <section class="cards-section container" id="services">
    <% if (cards && cards.data && (cards.data.title || cards.data.description)) { %>
      <div class="section-header">
        <% if (cards.data.title) { %>
          <h2 class="section-title"><%- fmt(cards.data.title) %></h2>
        <% } %>
        <% if (cards.data.description) { %>
          <p class="section-desc"><%- fmt(cards.data.description) %></p>
        <% } %>
      </div>
    <% } %>

    <div class="cards-grid">
      <% if (cards && cards.items && cards.items.length > 0) { %>
        <% cards.items.forEach(card => { %>
          <a href="<%= card.url || '#' %>" class="card">
            <% if (card.icon) { %>
              <div class="card__icon-wrapper">
                <i class="<%= card.icon %>"></i>
              </div>
            <% } %>
            <h3 class="card__title"><%- fmt(card.title || '') %></h3>
            <p class="card__desc"><%- fmt(card.description || '') %></p>
          </a>
        <% }) %>
      <% } %>
    </div>
  </section>

  <!-- TEXT FORMATTING UTILITY FUNCTION -->
  <% function fmt(t) {
    if (!t) return '';
    t = t.replace(/\[color=#([0-9a-fA-F]{3,8})\](.*?)\[\/color\]/gi, '<span style="color: #$1;">$2</span>');
    t = t.replace(/\[b\](.*?)\[\/b\]/gi, '<b>$1</b>');
    t = t.replace(/\[i\](.*?)\[\/i\]/gi, '<i>$1</i>');
    t = t.replace(/\[u\](.*?)\[\/u\]/gi, '<u>$1</u>');
    t = t.replace(/\[br\]/gi, '<br>');
    t = t.replace(/\n/g, '<br>');
    return t;
  } %>

  <!-- SCRIPTS -->
  <script>
    (function() {
      const navButtons = document.querySelectorAll('.navbutton');
      const hashLinks = Array.from(navButtons).map(b => b.getAttribute('href')).filter(h => h && h.startsWith('#'));
      const homeSection = document.getElementById('home');

      function setNavActive(currentHash) {
        navButtons.forEach(btn => {
          if (btn.getAttribute('href') === currentHash) btn.classList.add('is-active');
          else btn.classList.remove('is-active');
        });
      }

      function scrollToHome() {
        if (homeSection) {
          homeSection.scrollIntoView({ behavior: 'smooth' });
        }
        history.pushState(null, null, '#home');
        setNavActive('#home');
      }

      document.querySelectorAll('.brand').forEach(brand => {
        brand.addEventListener('click', function(e) {
          e.preventDefault();
          scrollToHome();
          window.dispatchEvent(new Event('hideSidebar'));
        });
      });

      navButtons.forEach(btn => {
        btn.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          if (href && href.startsWith('#')) {
            e.preventDefault();
            const target = document.querySelector(href);
            if (target) {
              target.scrollIntoView({ behavior: 'smooth' });
              history.pushState(null, null, href);
              setNavActive(href);
              window.dispatchEvent(new Event('hideSidebar'));
            }
          }
        });
      });

      const navObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const hash = `#${entry.target.id}`;
            if (hashLinks.includes(hash)) {
              history.replaceState(null, null, hash);
              setNavActive(hash);
            }
          }
        });
      }, { rootMargin: '-20% 0px -60% 0px' });

      document.querySelectorAll('section[id], div[id]').forEach(sec => {
        if (hashLinks.includes(`#${sec.id}`)) navObserver.observe(sec);
      });

      if (!window.location.hash || window.location.hash === '#home') {
        setNavActive('#home');
        if (!window.location.hash) {
          history.replaceState(null, null, '#home');
        }
      } else {
        setNavActive(window.location.hash);
        if (homeSection && window.location.hash === '#home') {
          homeSection.scrollIntoView({ behavior: 'smooth' });
        }
      }
    })();

    (function() {
      const canvas = document.getElementById('snow-canvas');
      const ctx = canvas.getContext('2d');
      let width = window.innerWidth;
      let height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
      
      const maxFlakes = width < 768 ? 12 : 30; 
      const flakes =[];
      const heroSection = document.getElementById('home');
      const initMaxY = Math.min(height, heroSection ? heroSection.getBoundingClientRect().bottom : height);

      for (let i = 0; i < maxFlakes; i++) {
        flakes.push({
          x: Math.random() * width,
          y: Math.random() * initMaxY,
          r: Math.random() * 1.5 + 0.5,
          d: Math.random() * 0.4 + 0.15, 
          a: Math.random() * Math.PI * 2,
          aStep: Math.random() * 0.01 + 0.005,
          opacity: Math.random() * 0.4 + 0.15
        });
      }

      function drawSnow() {
        ctx.clearRect(0, 0, width, height);
        
        // Find bottom boundary dynamically
        const heroBottom = heroSection ? heroSection.getBoundingClientRect().bottom : height;
        const fadeDistance = 120; // How many pixels before the end it should start fading out
        const fadeStart = heroBottom - fadeDistance;

        for (let i = 0; i < maxFlakes; i++) {
          let f = flakes[i];
          let currentOpacity = f.opacity;

          if (f.y > fadeStart) {
            let ratio = (heroBottom - f.y) / fadeDistance;
            currentOpacity = f.opacity * Math.max(0, Math.min(1, ratio));
          }

          if (currentOpacity > 0) {
            ctx.beginPath();
            ctx.fillStyle = `rgba(255, 255, 255, ${currentOpacity})`;
            ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2, true);
            ctx.fill();
          }
        }
        
        moveSnow(heroBottom);
        requestAnimationFrame(drawSnow);
      }

      function moveSnow(heroBottom) {
        // Prevent flakes from falling beyond the hero section bound or screen
        const maxY = Math.min(height, heroBottom);
        
        for (let i = 0; i < maxFlakes; i++) {
          let f = flakes[i];
          f.y += f.d;
          f.a += f.aStep;
          f.x += Math.sin(f.a) * 0.25; 

          // Loop them back to the top once they fade entirely
          if (f.y > maxY) { 
            f.y = -10; 
            f.x = Math.random() * width; 
          }
          if (f.x > width + 10) f.x = -10;
          if (f.x < -10) f.x = width + 10;
        }
      }

      window.addEventListener('resize', () => {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
      });
      drawSnow();

      const openBtn   = document.getElementById('open-sidebar');
      const closeBtn  = document.getElementById('close-sidebar');
      const sidebarEl = document.getElementById('sidebar');
      const overlay   = document.getElementById('overlay');

      function showSidebar() {
        sidebarEl.classList.add('is-expanded');
        overlay.classList.add('is-visible');
        document.body.classList.add('has-sidebar-open');
      }
      function hideSidebar() {
        sidebarEl.classList.remove('is-expanded');
        overlay.classList.remove('is-visible');
        document.body.classList.remove('has-sidebar-open');
      }

      openBtn.addEventListener('click', showSidebar);
      closeBtn.addEventListener('click', hideSidebar);
      overlay.addEventListener('click', hideSidebar);
      window.addEventListener('hideSidebar', hideSidebar);
    })();
  </script>
</body>
</html>
