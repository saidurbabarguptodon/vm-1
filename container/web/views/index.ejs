<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    :root {
      --kex-green: #1ad76f;
      --kex-dark-green: #0E713B;
      --kex-yellow: #FBBF24;
      --kex-dark-yellow: #B45309;
      --kex-red: #EF4444;
      --kex-dark-red: #991B1B;
      --kex-blue: #3B82F6;
      --kex-dark-blue: #1E3A8A;
      --kex-white: #F1F5F9;
      --kex-gray: #94A3B8;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      width: 100%;
      overflow-x: hidden;
      font-family: 'Inter', sans-serif;
      background-color: #0A0A0F;
      color: var(--kex-white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    body.has-sidebar-open { overflow: hidden; }

    #snow-canvas {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    .bg-ambient-glow {
      position: fixed;
      top: -15vw;
      left: -15vw;
      width: 50vw;
      height: 50vw;
      background: rgba(26, 215, 111, 0.22);
      border-radius: 50%;
      z-index: 0;
      pointer-events: none;
      filter: blur(120px);
      max-width: 900px;
      max-height: 900px;
    }

    .container {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 1380px;
      margin: 0 auto;
      padding: 0 5vw;
    }

    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: all 0.7s cubic-bezier(0.25, 0.1, 0.25, 1);
    }
    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    /* ==================== HEADER ==================== */
    .header {
      width: calc(100% - 20px);
      max-width: 1320px;
      margin: 12px auto 0;
      background: rgba(18, 18, 24, 0.8);
      backdrop-filter: blur(24px) saturate(180%);
      position: sticky;
      top: 12px;
      z-index: 100;
      border: 1px solid rgba(26, 215, 111, 0.45);
      border-radius: 18px;
      box-shadow: 0 12px 50px -12px rgba(0,0,0,0.6);
    }

    .header__nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 20px;
    }

    .header__toggle {
      background: transparent;
      border: none;
      color: white;
      font-size: 1.8rem;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      cursor: pointer;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      height: 42px;
    }
    .brand--sidebar { height: 38px; }

    .logoimg { height: 100%; width: auto; }
    .alticon { font-size: 1.85rem; color: var(--kex-green); }
    .alttext {
      font-size: clamp(1.45rem, 4.5vw, 1.85rem);
      font-weight: 800;
      font-family: 'Playfair Display', serif;
      color: #fff;
    }

    /* ==================== SIDEBAR ==================== */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(8px);
      opacity: 0;
      visibility: hidden;
      transition: 0.4s ease;
      z-index: 998;
    }
    .overlay.is-visible { opacity: 1; visibility: visible; }

    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      height: 100dvh;
      width: 290px;
      max-width: 88vw;
      background: rgba(15, 15, 20, 0.95);
      backdrop-filter: blur(32px);
      z-index: 999;
      border-radius: 0 28px 28px 0;
      transform: translateX(-100%);
      transition: transform 0.45s cubic-bezier(0.32, 0.72, 0, 1);
      display: flex;
      flex-direction: column;
    }
    .sidebar.is-expanded { transform: translateX(0); }

    .navmenu { display: flex; flex-direction: column; gap: 8px; padding: 20px 16px; }
    .navbutton {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 20px;
      color: white;
      text-decoration: none;
      border-radius: 16px;
      transition: all 0.3s ease;
    }
    .navbutton i { font-size: 1.4rem; width: 32px; color: var(--kex-green); }
    .navbutton.is-active { background: var(--kex-dark-green); }

    .sociallinks {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
      padding: 20px;
    }
    .sociallink {
      width: 52px;
      height: 52px;
      background: var(--kex-green);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      transition: all 0.3s ease;
    }

    /* ==================== HERO ==================== */
    .hero {
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 140px 0 100px;
    }

    .hero-title {
      font-size: clamp(2.4rem, 8vw, 4.2rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.04em;
      margin-bottom: 24px;
    }
    .hero-description {
      font-size: clamp(1.15rem, 4.2vw, 1.5rem);
      color: var(--kex-gray);
      max-width: 760px;
      margin-bottom: 40px;
    }
    .hero-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: var(--kex-green);
      color: white;
      font-size: clamp(1.1rem, 3vw, 1.25rem);
      font-weight: 600;
      padding: 18px 36px;
      border-radius: 9999px;
      text-decoration: none;
      box-shadow: 0 10px 30px -8px rgba(26,215,111,0.6);
      transition: all 0.3s ease;
    }

    /* ==================== SECTIONS ==================== */
    .cards-section, .faqs-section {
      padding: 100px 0;
    }

    .section-header {
      text-align: center;
      margin-bottom: 70px;
    }
    .section-title {
      font-size: clamp(2.1rem, 6vw, 3rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 18px;
    }
    .section-description {
      font-size: clamp(1.05rem, 3.5vw, 1.25rem);
      color: var(--kex-gray);
      max-width: 720px;
      margin: 0 auto;
    }

    .cards-grid, .faqs-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 32px;
    }

    .card-bg {
      background: rgba(22, 22, 32, 0.6);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 24px;
      padding: 40px 32px;
      display: flex;
      flex-direction: column;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(16px);
      height: 100%;
      position: relative;
    }

    .card-icon {
      width: 70px;
      height: 70px;
      background: rgba(26, 215, 111, 0.1);
      color: var(--kex-green);
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.2rem;
      margin-bottom: 28px;
      transition: all 0.4s ease;
    }

    .card-title {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .card-description {
      color: var(--kex-gray);
      flex-grow: 1;
    }

    .card-status {
      position: absolute;
      top: 28px;
      right: 28px;
      padding: 6px 16px;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* FAQ */
    .faq-item {
      background: rgba(22, 22, 32, 0.6);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px;
      overflow: hidden;
      backdrop-filter: blur(12px);
    }
    .faq-question {
      width: 100%;
      padding: 32px;
      background: none;
      border: none;
      text-align: left;
      font-size: 1.2rem;
      font-weight: 600;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
    }
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      padding: 0 32px;
      color: var(--kex-gray);
      transition: all 0.4s ease;
    }

    .cards-footer, .faqs-footer {
      margin-top: 70px;
      text-align: center;
    }

    /* Hover Effects */
    @media (hover: hover) {
      .card-bg:hover {
        transform: translateY(-14px);
        border-color: rgba(26, 215, 111, 0.5);
        box-shadow: 0 25px 50px -15px rgba(0,0,0,0.7);
      }
      .card-bg:hover .card-icon {
        background: var(--kex-green);
        color: white;
        transform: scale(1.15) rotate(-10deg);
      }
      .hero-btn:hover {
        background: var(--kex-dark-green);
        transform: translateY(-4px);
      }
      .sociallink:hover {
        transform: scale(1.1) translateY(-4px);
      }
    }

    /* Responsive Adjustments */
    @media (max-width: 640px) {
      .container { padding: 0 6vw; }
      .cards-grid, .faqs-container { gap: 24px; }
    }

    @media (min-width: 1280px) {
      .container { padding: 0 40px; }
    }
  </style>
</head>
<body>
  <canvas id="snow-canvas"></canvas>
  <div class="bg-ambient-glow"></div>

  <!-- Header -->
  <header class="header">
    <div class="container">
      <nav class="header__nav">
        <a href="/" class="brand" id="brand-header">
          <% if (header.logourl) { %>
            <img src="<%= header.logourl %>" alt="<%= header.alttext %>" class="logoimg">
          <% } else { %>
            <% if (header.alticon) { %><i class="<%= header.alticon %> alticon"></i><% } %>
            <% if (header.alttext) { %><span class="alttext"><%= header.alttext %></span><% } %>
          <% } %>
        </a>
        <button class="header__toggle" id="open-sidebar">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <div class="overlay" id="overlay"></div>

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar__header">
      <a href="/" class="brand brand--sidebar" id="brand-sidebar">
        <% if (sidebar.header && sidebar.header.logourl) { %>
          <img src="<%= sidebar.header.logourl %>" alt="<%= sidebar.header.alttext %>" class="logoimg">
        <% } else { %>
          <% if (sidebar.header && sidebar.header.alticon) { %><i class="<%= sidebar.header.alticon %> alticon"></i><% } %>
          <% if (sidebar.header && sidebar.header.alttext) { %><span class="alttext"><%= sidebar.header.alttext %></span><% } %>
        <% } %>
      </a>
      <button class="header__toggle" id="close-sidebar">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <div class="sidebar__body">
      <nav class="navmenu" id="navmenu">
        <% if (sidebar.body && sidebar.body.length > 0) { %>
          <% sidebar.body.forEach(link => { %>
            <a href="<%= link.url || '#' %>" class="navbutton">
              <% if (link.icon) { %><i class="<%= link.icon %>"></i><% } %>
              <span><%= link.text || '' %></span>
            </a>
          <% }) %>
        <% } %>
      </nav>
    </div>

    <div class="sociallinks">
      <% if (sidebar.footer && sidebar.footer.length > 0) { %>
        <% sidebar.footer.forEach(social => { %>
          <a href="<%= social.url || '#' %>" target="_blank" class="sociallink">
            <% if (social.icon) { %><i class="<%= social.icon %>"></i><% } %>
          </a>
        <% }) %>
      <% } %>
    </div>
  </aside>

  <!-- Hero -->
  <section class="hero" id="home">
    <div class="container">
      <% if (hero.primarytext) { %>
        <h1 class="hero-title reveal"><%- fmt(hero.primarytext) %></h1>
      <% } %>
      <% if (hero.secondarytext) { %>
        <p class="hero-description reveal"><%- fmt(hero.secondarytext) %></p>
      <% } %>
      <% if (hero.buttonenabled) { %>
        <a href="<%= hero.buttonurl || '#' %>" class="hero-btn reveal" target="_blank">
          <% if (hero.buttonicon) { %><i class="<%= hero.buttonicon %>"></i><% } %>
          <%= hero.buttontext || 'Get Started' %>
        </a>
      <% } %>
    </div>
  </section>

  <!-- Services / Cards -->
  <section class="cards-section container" id="services">
    <% if (cards?.data) { %>
      <div class="section-header reveal">
        <% if (cards.data.title) { %><h2 class="section-title"><%- fmt(cards.data.title) %></h2><% } %>
        <% if (cards.data.description) { %><p class="section-description"><%- fmt(cards.data.description) %></p><% } %>
      </div>
    <% } %>

    <div class="cards-grid">
      <% 
        let sortedCards = cards?.items ? cards.items.slice().sort((a,b) => (b.rating||0) - (a.rating||0)) : [];
        sortedCards.slice(0,6).forEach(card => { 
      %>
        <a href="<%= card.url || '#' %>" class="card-bg reveal" target="_blank" rel="noopener">
          <% if (card.status) { 
            let cls = card.status.toLowerCase() === 'online' ? 'status-online' : 
                     card.status.toLowerCase() === 'maintenance' ? 'status-maintenance' : 'status-default';
          %>
            <div class="card-status <%= cls %>"><%= card.status %></div>
          <% } %>

          <% if (card.icon) { %>
            <div class="card-icon"><i class="<%= card.icon %>"></i></div>
          <% } %>
          <h3 class="card-title"><%- fmt(card.title) %></h3>
          <p class="card-description"><%- fmt(card.description) %></p>
        </a>
      <% }) %>
    </div>

    <% if (cards?.data?.buttonenabled) { %>
      <div class="cards-footer reveal">
        <a href="<%= cards.data.buttonurl %>" class="hero-btn"><%= cards.data.buttontext %></a>
      </div>
    <% } %>
  </section>

  <!-- FAQ -->
  <section class="faqs-section container" id="faqs">
    <% if (faqs?.data) { %>
      <div class="section-header reveal">
        <% if (faqs.data.title) { %><h2 class="section-title"><%- fmt(faqs.data.title) %></h2><% } %>
        <% if (faqs.data.description) { %><p class="section-description"><%- fmt(faqs.data.description) %></p><% } %>
      </div>
    <% } %>

    <div class="faqs-container">
      <% if (faqs?.items) { %>
        <% faqs.items.forEach(faq => { %>
          <div class="faq-item reveal">
            <button class="faq-question">
              <span><%- fmt(faq.title) %></span>
              <i class="fa-solid fa-plus"></i>
            </button>
            <div class="faq-answer">
              <%- fmt(faq.description) %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </section>

  <% function fmt(t) {
    if (!t) return '';
    t = t.replace(/\[a url=([^\]]+)\](.*?)\[\/a\]/gi, '<a href="$1" target="_blank" style="color:var(--kex-green)">$2</a>');
    t = t.replace(/\[icon\](.*?)\[\/icon\]/gi, '<i class="$1"></i>');
    t = t.replace(/\n/g, '<br>');
    return t;
  } %>

  <script>
    // Snow Effect
    const canvas = document.getElementById('snow-canvas');
    const ctx = canvas.getContext('2d');
    let w = canvas.width = window.innerWidth;
    let h = canvas.height = window.innerHeight;
    const flakes = [];

    for (let i = 0; i < 80; i++) {
      flakes.push({
        x: Math.random() * w,
        y: Math.random() * h,
        r: Math.random() * 2.5 + 0.5,
        d: Math.random() * 0.8 + 0.2,
        a: Math.random() * Math.PI * 2,
        speed: Math.random() * 0.8 + 0.4
      });
    }

    function drawSnow() {
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = "rgba(255,255,255,0.85)";
      flakes.forEach(f => {
        ctx.beginPath();
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
        ctx.fill();
        f.y += f.d;
        f.x += Math.sin(f.a) * 0.6;
        f.a += 0.015;
        if (f.y > h) f.y = -10;
      });
      requestAnimationFrame(drawSnow);
    }
    window.addEventListener('resize', () => {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    });
    drawSnow();

    // Sidebar
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('overlay');
    document.getElementById('open-sidebar').addEventListener('click', () => {
      sidebar.classList.add('is-expanded');
      overlay.classList.add('is-visible');
      document.body.classList.add('has-sidebar-open');
    });
    document.getElementById('close-sidebar').addEventListener('click', () => {
      sidebar.classList.remove('is-expanded');
      overlay.classList.remove('is-visible');
      document.body.classList.remove('has-sidebar-open');
    });
    overlay.addEventListener('click', () => {
      sidebar.classList.remove('is-expanded');
      overlay.classList.remove('is-visible');
      document.body.classList.remove('has-sidebar-open');
    });

    // FAQ Accordion
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.parentElement;
        const answer = item.querySelector('.faq-answer');
        const isOpen = item.classList.contains('is-active');

        document.querySelectorAll('.faq-item').forEach(i => {
          i.classList.remove('is-active');
          i.querySelector('.faq-answer').style.maxHeight = null;
        });

        if (!isOpen) {
          item.classList.add('is-active');
          answer.style.maxHeight = answer.scrollHeight + "px";
        }
      });
    });

    // Reveal on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
