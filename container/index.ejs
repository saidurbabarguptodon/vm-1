<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minecraft Bot Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-5">

    <!-- HOME VIEW -->
    <% if (view === 'home') { %>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Minecraft Bots Manager</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">+ Create Bot</button>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Bot Name</th>
                            <th>Status</th>
                            <th>Address</th>
                            <th>Uptime</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (bots.length === 0) { %>
                            <tr><td colspan="6" class="text-center py-4">No bots created yet. Click "Create Bot" to start.</td></tr>
                        <% } %>
                        <% for (let i = 0; i < bots.length; i++) { let b = bots[i]; %>
                            <tr>
                                <td class="fw-bold"><%= b.id %></td>
                                <td><%= b.name %> <br><small class="text-muted"><%= b.username %></small></td>
                                <td>
                                    <% let badgeClass = b.status === 'Online' ? 'success' : (b.status === 'Connecting' ? 'warning text-dark' : 'secondary'); %>
                                    <span class="badge bg-<%= badgeClass %>"><%= b.status %></span>
                                </td>
                                <td><%= b.address %></td>
                                <td><%= b.uptime %></td>
                                <td><a href="/<%= b.id %>" class="btn btn-sm btn-info text-white">Manage</a></td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Create Bot Modal -->
        <div class="modal fade" id="createModal" tabindex="-1">
            <div class="modal-dialog">
                <form action="/create" method="POST" class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Create New Bot</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3"><label class="form-label">Bot Name</label><input type="text" name="name" class="form-control" required></div>
                        <div class="mb-3"><label class="form-label">Bot Username</label><input type="text" name="username" class="form-control" required></div>
                        <div class="mb-3"><label class="form-label">Server Address (e.g. localhost:25565)</label><input type="text" name="address" class="form-control" required></div>
                        
                        <div class="mb-3">
                            <label class="form-label">Minecraft Version (Optional)</label>
                            <input type="text" name="version" class="form-control" placeholder="Leave blank for Auto (e.g. 1.20.4)">
                            <div class="form-text">Specify this if the bot instantly gets kicked for movement/physics!</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Join Message (Optional)</label>
                            <input type="text" name="joinMessage" class="form-control" placeholder="e.g. Hello! or /login pass">
                            <div class="form-text">Sent 2 seconds after the bot spawns.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Create Bot</button>
                    </div>
                </form>
            </div>
        </div>
    <% } %>

    <!-- MANAGE BOT VIEW -->
    <% if (view === 'manage') { %>
        <div class="mb-4 d-flex justify-content-between align-items-center">
            <h2>Managing Bot: <span class="text-primary"><%= bot.name %></span></h2>
            <a href="/" class="btn btn-secondary">← Back to Dashboard</a>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="card mb-3 shadow-sm">
                    <div class="card-header bg-dark text-white fw-bold">Bot Information</div>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>Bot Name:</strong> <%= bot.name %></li>
                        <li class="list-group-item"><strong>Bot Username:</strong> <%= bot.username %></li>
                        <li class="list-group-item"><strong>Address:</strong> <%= bot.address %></li>
                        <li class="list-group-item"><strong>Version:</strong> <%= bot.version || 'Auto-Detect' %></li>
                        <li class="list-group-item"><strong>Join Message:</strong> <span class="text-muted"><%= bot.joinMessage || 'None' %></span></li>
                        
                        <li class="list-group-item">
                            <strong>Auto Reconnect:</strong> 
                            <span class="badge bg-<%= bot.autoReconnect !== false ? 'success' : 'secondary' %>">
                                <%= bot.autoReconnect !== false ? 'Enabled' : 'Disabled' %>
                            </span>
                            <% if (bot.autoReconnect !== false) { %>
                                <div class="text-muted small">Delay: <%= bot.autoReconnectDelay || 15 %>s</div>
                            <% } %>
                        </li>
                        <li class="list-group-item">
                            <strong>Smart Rejoin:</strong> 
                            <% if (bot.smartRejoin) { %>
                                <span class="badge bg-primary">Active</span>
                                <div class="text-muted small mt-1">
                                    Looping <%= bot.smartRejoinCount %> accounts<br>
                                    Rejoin delay: <%= bot.smartRejoinDelay || 5 %>s<br>
                                    Rotation interval: <%= bot.smartRejoinIntervalSec || 300 %>s
                                </div>
                            <% } else { %>
                                <span class="badge bg-secondary">Disabled</span>
                            <% } %>
                        </li>

                        <% let badgeClass = status === 'Online' ? 'success' : (status === 'Connecting' ? 'warning text-dark' : 'secondary'); %>
                        <li class="list-group-item"><strong>Status:</strong> <span class="badge bg-<%= badgeClass %>" id="statusBadge"><%= status %></span></li>
                        <li class="list-group-item"><strong>Uptime:</strong> <span id="uptimeSpan" class="fw-bold"><%= uptime %></span></li>
                    </ul>
                    <div class="card-body bg-light d-flex flex-wrap gap-2">
                        <form action="/<%= bot.id %>/start" method="POST"><button class="btn btn-success btn-sm">Start</button></form>
                        <form action="/<%= bot.id %>/stop" method="POST"><button class="btn btn-warning btn-sm">Stop</button></form>
                        <form action="/<%= bot.id %>/restart" method="POST"><button class="btn btn-primary btn-sm">Restart</button></form>
                        <button class="btn btn-info btn-sm text-white" data-bs-toggle="modal" data-bs-target="#editModal">Settings</button>
                        <form action="/<%= bot.id %>/delete" method="POST" onsubmit="return confirm('WARNING: Are you sure you want to completely delete this bot?');" class="ms-auto">
                            <button class="btn btn-danger btn-sm">Delete Bot</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
                        <span>Live Console</span>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-secondary py-0 px-2" id="copyLogsBtn" onclick="copyLogs()">Copy Logs</button>
                            <form action="/<%= bot.id %>/clear-logs" method="POST" class="m-0">
                                <button type="submit" class="btn btn-sm btn-danger py-0 px-2" onclick="return confirm('Clear all logs for this bot?');">Clear Logs</button>
                            </form>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div id="consoleBox" style="height: 440px; overflow-y: auto; background-color: #1e1e1e; color: #00ff00; padding: 15px; font-family: monospace; font-size: 14px;">
                            Loading console logs...
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Settings Modal -->
        <div class="modal fade" id="editModal" tabindex="-1">
            <div class="modal-dialog">
                <form action="/<%= bot.id %>/edit" method="POST" class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Bot Settings</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                    <div class="modal-body">
                        <div class="mb-3"><label class="form-label">Bot Name</label><input type="text" name="name" class="form-control" required value="<%= bot.name %>"></div>
                        <div class="mb-3"><label class="form-label">Bot Username</label><input type="text" name="username" class="form-control" required value="<%= bot.username %>"></div>
                        <div class="mb-3"><label class="form-label">Server Address</label><input type="text" name="address" class="form-control" required value="<%= bot.address %>"></div>
                        
                        <div class="mb-3">
                            <label class="form-label">Minecraft Version</label>
                            <input type="text" name="version" class="form-control" placeholder="Leave blank for Auto (e.g. 1.20.4)" value="<%= bot.version || '' %>">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Join Message</label>
                            <input type="text" name="joinMessage" class="form-control" placeholder="e.g. Hello! or /login pass" value="<%= bot.joinMessage || '' %>">
                            <div class="form-text">You can also use commands to auto-login.</div>
                        </div>

                        <hr>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" name="autoReconnect" id="autoReconnect" <%= bot.autoReconnect !== false ? 'checked' : '' %> onchange="document.getElementById('autoReconnectDiv').style.display = this.checked ? 'block' : 'none'">
                            <label class="form-check-label" for="autoReconnect">Auto Reconnect</label>
                        </div>
                        <div id="autoReconnectDiv" style="display: <%= bot.autoReconnect !== false ? 'block' : 'none' %>; background: #f8f9fa; padding: 10px; border-radius: 5px; margin-bottom: 15px;">
                            <label class="form-label">Reconnect delay (seconds)</label>
                            <input type="number" name="autoReconnectDelay" class="form-control" min="1" value="<%= bot.autoReconnectDelay || 15 %>">
                        </div>

                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" name="smartRejoin" id="smartRejoin" <%= bot.smartRejoin ? 'checked' : '' %> onchange="document.getElementById('smartRejoinDiv').style.display = this.checked ? 'block' : 'none'">
                            <label class="form-check-label text-primary fw-bold" for="smartRejoin">Smart Rejoin</label>
                            <div class="form-text">Instantly rejoins with next account on disconnect or after rotation interval.</div>
                        </div>
                        <div id="smartRejoinDiv" style="display: <%= bot.smartRejoin ? 'block' : 'none' %>; background: #f8f9fa; padding: 10px; border-radius: 5px;">
                            <div class="mb-3">
                                <label class="form-label">Number of accounts to loop</label>
                                <input type="number" name="smartRejoinCount" class="form-control" min="2" max="100" value="<%= bot.smartRejoinCount || 2 %>">
                                <div class="form-text">Example: "3" loops between Username, Username_2, Username_3.</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Rejoin delay after disconnect (seconds)</label>
                                <input type="number" name="smartRejoinDelay" class="form-control" min="1" value="<%= bot.smartRejoinDelay || 5 %>">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Rotation interval (seconds)</label>
                                <input type="number" name="smartRejoinIntervalSec" class="form-control" min="0" value="<%= bot.smartRejoinIntervalSec || 300 %>">
                                <div class="form-text">Bot will forcefully disconnect and rotate after this many seconds. Set to 0 to only rotate on disconnect.</div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer"><button type="submit" class="btn btn-primary">Save Changes</button></div>
                </form>
            </div>
        </div>

        <script>
            var consoleBox = document.getElementById('consoleBox');
            var uptimeSpan = document.getElementById('uptimeSpan');
            var statusBadge = document.getElementById('statusBadge');
            var botId = "<%= bot.id %>";
            
            function fetchLogs() {
                fetch('/' + botId + '/logs')
                    .then(function(res) { return res.json(); })
                    .then(function(data) {
                        uptimeSpan.innerText = data.uptime;
                        statusBadge.innerText = data.status;
                        
                        if(data.status === 'Online') {
                            statusBadge.className = 'badge bg-success';
                        } else if(data.status === 'Connecting') {
                            statusBadge.className = 'badge bg-warning text-dark';
                        } else {
                            statusBadge.className = 'badge bg-secondary';
                        }

                        if (data.logs.length === 0) {
                            consoleBox.innerHTML = '<span style="color:#888;">No logs available.</span>';
                        } else {
                            var newHTML = data.logs.join('<br>');
                            if (consoleBox.innerHTML !== newHTML) {
                                consoleBox.innerHTML = newHTML;
                                consoleBox.scrollTop = consoleBox.scrollHeight;
                            }
                        }
                    })
                    .catch(function(err) {});
            }
            setInterval(fetchLogs, 1000); fetchLogs();

            function copyLogs() {
                var btn = document.getElementById('copyLogsBtn');
                var textToCopy = consoleBox.innerText;

                if(textToCopy === 'Loading console logs...' || textToCopy === 'No logs available.') {
                    textToCopy = ''; 
                }

                navigator.clipboard.writeText(textToCopy).then(function() {
                    var originalText = btn.innerText;
                    btn.innerText = 'Copied!';
                    btn.classList.remove('btn-secondary');
                    btn.classList.add('btn-success');
                    
                    setTimeout(function() {
                        btn.innerText = originalText;
                        btn.classList.remove('btn-success');
                        btn.classList.add('btn-secondary');
                    }, 2000);
                }).catch(function(err) {
                    alert('Failed to copy logs to clipboard.');
                });
            }
        </script>
    <% } %>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
