<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Dynamic Header & Sidebar</title>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icon CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    /* ✦ DARK GRAY COLOR PALETTE — Clean & Neutral ✦ */
    :root {
      --bg-dark: #0A0A0F;
      
      /* Sleek dark gray for Header and Sidebar */
      --header-bg: rgba(39, 39, 42, 0.85); /* Slightly transparent gray for glassmorphism */
      --sidebar-bg: #27272A; /* Solid dark gray */
      
      --accent-gray: #6B7280;
      --accent-light: #9CA3AF;
      
      --text-light: #F1F5F9;
      --text-muted: #94A3B8;
      
      /* ✦ THEME: MCServerHost Green (#22C55E) ✦ */
      --single-glow-color: #22C55E; 
      --single-glow-hover: #16a34a; /* Slightly darker green for hover effects */
      
      --border-light: rgba(255, 255, 255, 0.06);
      --shadow-soft: 0 10px 20px -8px rgba(0, 0, 0, 0.5);
    }

    /* RESET & TYPOGRAPHY */
    * { 
      margin: 0; 
      padding: 0; 
      box-sizing: border-box; 
      -webkit-tap-highlight-color: transparent; 
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* ✦ SNOWFALL CANVAS ✦ */
    #snow-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none; /* Ensures you can click through the snow */
      z-index: 1; /* Stays behind the header and sidebar */
    }

    /* LAYOUT */
    .container {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0; 
    }

    /* ✦ HEADER ✦ */
    .header {
      width: 100%;
      background: var(--header-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--border-light);
      box-shadow: var(--shadow-soft);
    }

    /* ✦ GREEN AURORA GLOW ✦ */
    .header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 240px; 
      background: radial-gradient(
        ellipse 80% 100% at 50% 0%,
        rgba(34, 197, 94, 0.20) 0%,   /* Bright Lime/Emerald Green */
        rgba(16, 185, 129, 0.08) 55%, /* Darker Emerald Edge */
        transparent 100%
      );
      z-index: -1;
      pointer-events: none;
    }

    /* ✦ LOGO STYLING ✦ */
    .header-logo, .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      transition: opacity 0.2s ease;
      text-decoration: none;
    }
    .header-logo { height: 40px; margin-left: -12px; }
    .sidebar-logo { height: 32px; }
    .header-logo:hover, .sidebar-logo:hover { opacity: 0.8; }
    
    .header-logo img, .sidebar-logo img {
      height: 100%;
      width: auto; 
      object-fit: contain;
    }

    /* ✦ MAIN HEADER LOGO (GREEN GLOW) ✦ */
    .header-alticon {
      font-size: 1.6rem; 
      color: var(--single-glow-color);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.45); /* True Green Glow */
      display: inline-block; 
    }
    .header-alttext {
      font-size: 1.7rem; 
      font-weight: 800;
      color: var(--single-glow-color);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.45); /* True Green Glow */
      letter-spacing: -0.5px;
    }

    /* ✦ SIDEBAR HEADER LOGO (SOLID WHITE) ✦ */
    .sidebar-alticon {
      font-size: 1.6rem; 
      color: #FFFFFF; /* Pure white */
      display: inline-block; 
    }
    .sidebar-alttext {
      font-size: 1.7rem; 
      font-weight: 800;
      color: #FFFFFF; /* Pure white */
      letter-spacing: -0.5px;
    }

    /* ✦ MENU TOGGLE BUTTON ✦ */
    .menu-toggle-btn {
      background: transparent;
      border: none;
      color: var(--text-light); /* Adjusted to stand out on gray */
      font-size: 1.6rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px; 
      height: 44px; 
      border-radius: 8px;
      transition: all 0.15s ease;
      margin-right: -8px; 
    }
    .menu-toggle-btn i { transition: transform 0.2s ease; }
    .menu-toggle-btn:hover { background: rgba(255, 255, 255, 0.1); color: #FFFFFF; }
    .menu-toggle-btn:active i { transform: scale(0.85); }

    /* ✦ SIDEBAR OVERLAY ✦ */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6); 
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998; 
      cursor: pointer; 
    }
    .sidebar-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    /* ✦ SIDEBAR ✦ */
    .sidebar {
      position: fixed;
      top: 0;
      bottom: 0; 
      left: 0;
      height: 100vh; 
      height: 100dvh; 
      width: 260px; 
      max-width: 80vw; 
      background: var(--sidebar-bg); /* Solid Gray */
      z-index: 999;
      display: flex;
      flex-direction: column;
      
      /* Very thin green divider tracing the exposed sides perfectly */
      border: 1px solid var(--single-glow-color); 
      border-left: none; /* No border where it touches the screen edge */
      
      border-top-right-radius: 24px;
      border-bottom-right-radius: 24px;
      
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sidebar.active {
      transform: translateX(0);
    }

    /* ✦ SIDEBAR SECTIONS ✦ */
    .sidebar-header {
      display: flex;
      justify-content: space-between; 
      align-items: center;
      padding: 0 24px;
      border-bottom: 1px solid var(--border-light);
      height: 73px; /* Exact height for Header */
      flex-shrink: 0; 
    }

    .sidebar-body {
      flex: 1; 
      padding: 24px 16px; /* Optimized padding for link hover effects */
      overflow-y: auto; 
    }

    /* ✦ SIDEBAR NAVIGATION LINKS (THE DYNAMIC DATA) ✦ */
    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .sidebar-nav-link {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 16px;
      color: #FFFFFF; /* Solid white text */
      text-decoration: none;
      font-size: 1.05rem;
      font-weight: 500;
      border-radius: 12px;
      transition: all 0.2s ease;
    }

    .sidebar-nav-link i {
      font-size: 1.2rem;
      width: 24px;
      text-align: center;
      color: var(--single-glow-color); /* Icons are green */
      transition: all 0.2s ease;
    }

    .sidebar-nav-link:hover {
      background: rgba(255, 255, 255, 0.08); /* Brighter hover background to contrast with gray base */
      transform: translateX(4px); /* Slight bump to the right on hover */
    }

    .sidebar-nav-link:hover i {
      text-shadow: 0 0 10px rgba(34, 197, 94, 0.5); /* Adds a green glow on hover */
    }

    /* ✦ RESPONSIVE SIDEBAR FOOTER ✦ */
    .sidebar-footer {
      border-top: 1px solid var(--border-light);
      flex-shrink: 0;
      min-height: calc(73px + env(safe-area-inset-bottom)); 
      padding: 15px 24px;
      padding-bottom: calc(15px + env(safe-area-inset-bottom));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: auto; 
    }

    .social-links {
      display: flex;
      gap: 12px; 
      flex-wrap: wrap; /* Allows wrapping to the next line smoothly */
      justify-content: center;
      align-items: center;
      width: 100%;
    }

    /* Round Green Social Buttons */
    .social-icon {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 42px; 
      height: 42px;
      background-color: var(--single-glow-color); /* Matches MCServerHost theme */
      color: #ffffff;
      border-radius: 50%; /* Perfect Circle */
      text-decoration: none;
      font-size: 19px; 
      transition: background-color 0.3s ease, transform 0.3s ease;
    }

    .social-icon:hover {
      background-color: var(--single-glow-hover);
      color: #ffffff;
      transform: translateY(-3px); /* Subtle jump effect */
    }

    /* ✦ ANIMATIONS ✦ */
    .sidebar-header, .sidebar-body, .sidebar-footer {
      opacity: 0;
      transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sidebar.active .sidebar-header { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
    .sidebar.active .sidebar-body { opacity: 1; transform: translateY(0); transition-delay: 0.18s; }
    .sidebar.active .sidebar-footer { opacity: 1; transform: translateY(0); transition-delay: 0.26s; }
    
    /* ✦ CLOSE BUTTON ✦ */
    .sidebar-close-btn {
      background: transparent;
      border: none;
      color: var(--text-light); /* Adjusted to show up on gray */
      font-size: 1.5rem;
      cursor: pointer;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
      margin-right: -8px; 
    }
    .sidebar-close-btn i { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .sidebar.active .sidebar-close-btn i { transform: rotate(90deg); }
    .sidebar-close-btn:hover { background: rgba(255, 255, 255, 0.1); color: #FFFFFF; }
    
    body.menu-open { overflow: hidden; touch-action: none; }

    .demo-content { padding: 60px 0; text-align: center; color: var(--text-muted); }
  </style>
</head>
<body>

  <!-- NATURAL SNOWFALL CANVAS -->
  <canvas id="snow-canvas"></canvas>

  <!-- HEADER -->
  <header class="header">
    <div class="container">
      <nav class="navbar">
        <!-- MAIN LOGO -->
        <a href="/" class="header-logo" id="header-logo-container">
          <% if (header.logourl && header.logourl !== "") { %>
            <img 
              src="<%= header.logourl %>" 
              alt="Logo" 
              id="header-logo-img"
              onerror="this.onerror=null; fallbackHeaderToIconMode()"
            >
          <% } else { %>
            <% if (header.alticon && header.alticon !== "") { %>
              <i class="<%= header.alticon %> header-alticon" id="header-alticon"></i>
            <% } %>
            <% if (header.alttext && header.alttext !== "") { %>
              <span class="header-alttext" id="header-alttext"><%= header.alttext %></span>
            <% } %>
          <% } %>
        </a>

        <button class="menu-toggle-btn" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <!-- SIDEBAR OVERLAY -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <!-- SIDEBAR MENU -->
  <aside class="sidebar" id="sidebar">
    
    <!-- SECTION 1: HEADER -->
    <div class="sidebar-header">
      <a href="/" class="sidebar-logo" id="sidebar-logo-container">
        <% if (sidebar.header && sidebar.header.logourl && sidebar.header.logourl !== "") { %>
          <img 
            src="<%= sidebar.header.logourl %>" 
            alt="Sidebar Logo" 
            id="sidebar-logo-img"
            onerror="this.onerror=null; fallbackSidebarToIconMode()"
          >
        <% } else if (sidebar.header) { %>
          <% if (sidebar.header.alticon && sidebar.header.alticon !== "") { %>
            <i class="<%= sidebar.header.alticon %> sidebar-alticon" id="sidebar-alticon"></i>
          <% } %>
          <% if (sidebar.header.alttext && sidebar.header.alttext !== "") { %>
            <span class="sidebar-alttext" id="sidebar-alttext"><%= sidebar.header.alttext %></span>
          <% } %>
        <% } %>
      </a>

      <button class="sidebar-close-btn" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <!-- SECTION 2: BODY (DYNAMIC NAVIGATION LINKS) -->
    <div class="sidebar-body">
      <!-- Loop through Firestore Navigation Documents (navbutton-1, navbutton-2, etc.) -->
      <% if (sidebar.body && sidebar.body.length > 0) { %>
        <nav class="sidebar-nav">
          <% sidebar.body.forEach(function(link) { %>
            <a href="<%= link.url || '#' %>" class="sidebar-nav-link">
              <!-- Render icon if available -->
              <% if (link.icon) { %>
                <i class="<%= link.icon %>"></i>
              <% } %>
              
              <!-- Render text -->
              <span><%= link.text || 'Untitled Link' %></span>
            </a>
          <% }); %>
        </nav>
      <% } else { %>
        <!-- Fallback if database collection is empty -->
        <p style="text-align: center; color: var(--text-muted); font-size: 13px; margin-top: 20px;">
          No navigation links yet
        </p>
      <% } %>
    </div>

    <!-- SECTION 3: FOOTER (DYNAMIC SOCIAL LINKS) -->
    <div class="sidebar-footer">
      <!-- Loop through Firestore Social Documents (social-1, social-2, etc.) -->
      <% if (sidebar.footer && sidebar.footer.length > 0) { %>
        <div class="social-links">
          <% sidebar.footer.forEach(function(social) { %>
            <a href="<%= social.url %>" target="_blank" class="social-icon">
              <i class="<%= social.icon %>"></i>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <p style="text-align: center; color: var(--text-muted); font-size: 13px; width: 100%; margin: 0;">No socials yet</p>
      <% } %>
    </div>
  </aside>

  <div class="container demo-content">
    <p style="opacity:0.5;">— Gray Header & Sidebar + Thin Green Border Theme —</p>
  </div>

  <script>
    // ==========================================
    // ✦ NATURAL SNOWFALL CANVAS EFFECT ✦
    // ==========================================
    const canvas = document.getElementById('snow-canvas');
    const ctx = canvas.getContext('2d');
    
    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    const maxFlakes = width < 768 ? 25 : 60; // Responsive flake count
    const flakes = [];

    // Create random snowflakes
    for (let i = 0; i < maxFlakes; i++) {
      flakes.push({
        x: Math.random() * width,
        y: Math.random() * height,
        r: Math.random() * 2.0 + 0.5, 
        d: Math.random() * 1.0 + 0.3, 
        a: Math.random() * Math.PI * 2, 
        aStep: Math.random() * 0.015 + 0.005, 
        opacity: Math.random() * 0.4 + 0.1 
      });
    }

    function drawSnow() {
      ctx.clearRect(0, 0, width, height);
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        ctx.beginPath();
        ctx.fillStyle = `rgba(255, 255, 255, ${f.opacity})`;
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2, true);
        ctx.fill();
      }
      moveSnow();
      requestAnimationFrame(drawSnow);
    }

    function moveSnow() {
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        f.y += f.d; // Move down
        f.a += f.aStep; 
        f.x += Math.sin(f.a) * 0.5; // Natural horizontal sway

        // If snow falls off screen, reset it to the top
        if (f.y > height) {
          f.y = -10;
          f.x = Math.random() * width;
        }
        // Wrap around left/right edges
        if (f.x > width + 10) f.x = -10;
        if (f.x < -10) f.x = width + 10;
      }
    }

    // Handle Window Resize
    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    });

    drawSnow();

    // ==========================================
    // ✦ HEADER & SIDEBAR LOGIC ✦
    // ==========================================

    // Main header fallback if image fails to load
    function fallbackHeaderToIconMode() {
      const container = document.getElementById('header-logo-container');
      if (!container) return;
      const alticon = '<%= header.alticon && header.alticon !== "" ? header.alticon : "" %>';
      const alttext = '<%= header.alttext && header.alttext !== "" ? header.alttext : "" %>';
      const iconHtml = alticon !== "" ? `<i class="${alticon} header-alticon"></i>` : "";
      const textHtml = alttext !== "" ? `<span class="header-alttext">${alttext}</span>` : "";
      container.innerHTML = iconHtml + textHtml;
    }

    // Sidebar fallback if image fails to load
    function fallbackSidebarToIconMode() {
      const container = document.getElementById('sidebar-logo-container');
      if (!container) return;
      const alticon = '<%= sidebar.header && sidebar.header.alticon !== "" ? sidebar.header.alticon : "" %>';
      const alttext = '<%= sidebar.header && sidebar.header.alttext !== "" ? sidebar.header.alttext : "" %>';
      const iconHtml = alticon !== "" ? `<i class="${alticon} sidebar-alticon"></i>` : "";
      const textHtml = alttext !== "" ? `<span class="sidebar-alttext">${alttext}</span>` : "";
      container.innerHTML = iconHtml + textHtml;
    }

    // Toggle Sidebar Logic
    const openBtn = document.getElementById('open-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    const sidebarElement = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebarElement.classList.add('active');
      overlay.classList.add('active');
      document.body.classList.add('menu-open'); 
    }

    function closeSidebar() {
      sidebarElement.classList.remove('active');
      overlay.classList.remove('active');
      document.body.classList.remove('menu-open'); 
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
  </script>

</body>
</html>
