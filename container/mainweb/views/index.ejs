<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Dynamic Header & Sidebar</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --bg-deep: #0A0A0F;
      --header-glass: rgba(15, 15, 20, 0.75);
      --sidebar-glass: rgba(15, 15, 20, 0.85);
      --accent-muted: #6B7280;
      --accent-soft: #9CA3AF;
      --text-primary: #F1F5F9;
      --text-secondary: #94A3B8;
      --text-muted: #94A3B8;
      --glow-primary: #22C55E;
      --glow-deep: #16a34a;
      --border-subtle: rgba(255, 255, 255, 0.08);
      --shadow-elevated: 0 10px 30px -8px rgba(0, 0, 0, 0.6);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-deep);
      color: var(--text-primary);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    #snow-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    .content-wrapper {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ---------- HEADER ---------- */
    .app-header {
      width: 100%;
      background: var(--header-glass);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--border-subtle);
      box-shadow: var(--shadow-elevated);
    }

    .app-header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 240px;
      background: radial-gradient(
        ellipse 80% 100% at 50% 0%,
        rgba(34, 197, 94, 0.20) 0%,
        rgba(16, 185, 129, 0.08) 55%,
        transparent 100%
      );
      z-index: -1;
      pointer-events: none;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      transition: opacity 0.2s ease;
      text-decoration: none;
    }

    .brand--header { height: 40px; margin-left: -12px; }
    .brand--sidebar { height: 32px; }
    .brand:hover { opacity: 0.8; }

    .brand__image {
      height: 100%;
      width: auto;
      object-fit: contain;
    }

    .brand__icon {
      font-size: 1.6rem;
      color: var(--glow-primary);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.45);
      display: inline-block;
    }

    .brand__text {
      font-size: 1.7rem;
      font-weight: 800;
      color: var(--glow-primary);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.45);
      letter-spacing: -0.5px;
    }

    .menu-toggle {
      background: transparent;
      border: none;
      color: var(--text-secondary);
      font-size: 1.6rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 8px;
      transition: all 0.15s ease;
      margin-right: -8px;
    }

    .menu-toggle i { transition: transform 0.2s ease; }
    .menu-toggle:hover { background: rgba(255, 255, 255, 0.06); color: #FFFFFF; }
    .menu-toggle:active i { transform: scale(0.85); }

    /* ---------- REFINED SIDEBAR ---------- */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998;
      cursor: pointer;
    }

    .sidebar-overlay.is-visible {
      opacity: 1;
      visibility: visible;
    }

    .app-sidebar {
      position: fixed;
      top: 0;
      bottom: 0;
      left: 0;
      height: 100vh;
      height: 100dvh;
      width: 280px;
      max-width: 80vw;
      background: var(--sidebar-glass);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      z-index: 999;
      display: flex;
      flex-direction: column;
      border-top-right-radius: 24px;
      border-bottom-right-radius: 24px;
      border-right: 1px solid var(--border-subtle);
      box-shadow: 10px 0 30px rgba(0, 0, 0, 0.5);
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .app-sidebar.is-expanded {
      transform: translateX(0);
    }

    .sidebar__header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 24px;
      border-bottom: 1px solid var(--border-subtle);
      height: 73px;
      flex-shrink: 0;
    }

    .sidebar__body {
      flex: 1;
      padding: 16px 12px 20px 12px;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.15) transparent;
    }
    
    .sidebar__body::-webkit-scrollbar { width: 5px; }
    .sidebar__body::-webkit-scrollbar-track { background: transparent; }
    .sidebar__body::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.15);
      border-radius: 10px;
    }
    .sidebar__body::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.3); }

    .nav-menu {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 15px 14px 11px;
      min-height: 56px;
      color: var(--text-secondary);
      text-decoration: none;
      border-radius: 12px;
      border-left: 4px solid transparent;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    .nav-link i {
      font-size: 1.25rem;
      width: 28px;
      text-align: center;
      flex-shrink: 0;
      color: var(--text-secondary);
      transition: color 0.2s ease;
    }

    .nav-link__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      line-height: 1.3;
    }

    .nav-link__title {
      font-size: 1.05rem;
      font-weight: 500;
      color: inherit;
      transition: color 0.2s ease;
    }

    .nav-link:hover {
      background: rgba(255, 255, 255, 0.04);
      transform: translateX(4px);
      color: var(--text-primary);
    }
    .nav-link:hover i { color: var(--text-primary); }

    .nav-link.is-active {
      background: linear-gradient(90deg, rgba(34, 197, 94, 0.12) 0%, transparent 100%);
      border-left-color: var(--glow-primary);
      color: var(--text-primary);
    }

    .nav-link.is-active i {
      color: var(--glow-primary);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.4);
    }

    .nav-link.is-active .nav-link__title {
      font-weight: 600;
      color: #ffffff;
    }

    .sidebar__footer {
      border-top: 1px solid var(--border-subtle);
      flex-shrink: 0;
      min-height: calc(73px + env(safe-area-inset-bottom));
      padding: 15px 24px;
      padding-bottom: calc(15px + env(safe-area-inset-bottom));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: auto;
      background: rgba(0, 0, 0, 0.15);
    }

    .social-list {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      width: 100%;
    }

    .social-link {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 42px;
      height: 42px;
      background-color: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: var(--text-primary);
      border-radius: 50%;
      text-decoration: none;
      font-size: 19px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .social-link:hover {
      background-color: var(--glow-primary);
      border-color: var(--glow-primary);
      color: #ffffff;
      transform: translateY(-4px) scale(1.05);
      box-shadow: 0 10px 20px -5px rgba(34, 197, 94, 0.5);
    }

    .sidebar__close {
      background: transparent;
      border: none;
      color: var(--text-secondary);
      font-size: 1.5rem;
      cursor: pointer;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
      margin-right: -8px;
    }

    .sidebar__close i { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .app-sidebar.is-expanded .sidebar__close i { transform: rotate(90deg); }
    .sidebar__close:hover { background: rgba(255, 255, 255, 0.06); color: #FFFFFF; }

    .sidebar__header, .sidebar__body, .sidebar__footer {
      opacity: 0;
      transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .app-sidebar.is-expanded .sidebar__header { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
    .app-sidebar.is-expanded .sidebar__body { opacity: 1; transform: translateY(0); transition-delay: 0.18s; }
    .app-sidebar.is-expanded .sidebar__footer { opacity: 1; transform: translateY(0); transition-delay: 0.26s; }

    body.has-menu-open {
      overflow: hidden;
      touch-action: none;
    }

    /* ---------- HERO SECTION ---------- */
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 80px 24px 60px;
      position: relative;
    }

    .hero__primary {
      font-size: clamp(2.8rem, 8vw, 4.5rem);
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      text-shadow: 0 0 30px rgba(34, 197, 94, 0.3);
      margin-bottom: 20px;
    }
    
    /* Ensure elements collapse if totally empty */
    .hero__primary:empty, .hero__secondary:empty {
      margin-bottom: 0;
      display: none;
    }

    .hero__secondary {
      font-size: clamp(1.1rem, 4vw, 1.4rem);
      font-weight: 400;
      color: var(--text-secondary);
      max-width: 600px;
      margin-bottom: 32px;
    }

    .hero b, .hero strong { font-weight: 900; color: #ffffff; }
    .hero u {
      text-decoration: underline;
      text-decoration-color: var(--glow-primary);
      text-decoration-thickness: 0.1em;
      text-underline-offset: 6px;
    }

    .hero__cta {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background-color: var(--glow-primary);
      color: #ffffff;
      font-weight: 600;
      font-size: 1.1rem;
      padding: 14px 32px;
      border-radius: 60px;
      text-decoration: none;
      transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
      box-shadow: 0 8px 20px -6px rgba(34, 197, 94, 0.5);
      margin-bottom: 40px;
    }

    .hero__cta i { font-size: 1.1rem; }
    .hero__cta:hover {
      background-color: var(--glow-deep);
      transform: translateY(-2px);
      box-shadow: 0 12px 24px -8px rgba(34, 197, 94, 0.6);
    }

    .hero__footer {
      font-size: 0.95rem;
      color: var(--text-muted);
      opacity: 0.8;
    }
  </style>
</head>
<body>

<canvas id="snow-canvas"></canvas>

<header class="app-header">
  <div class="content-wrapper">
    <nav class="navbar">
      <a href="/" class="brand brand--header" id="header-brand"></a>
      <button class="menu-toggle" id="open-sidebar" aria-label="Open Menu">
        <i class="fa-solid fa-bars"></i>
      </button>
    </nav>
  </div>
</header>

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<aside class="app-sidebar" id="app-sidebar">
  <div class="sidebar__header">
    <a href="/" class="brand brand--sidebar" id="sidebar-brand"></a>
    <button class="sidebar__close" id="close-sidebar" aria-label="Close Menu">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <div class="sidebar__body">
    <nav class="nav-menu" id="sidebar-navigation"></nav>
  </div>

  <div class="sidebar__footer">
    <div class="social-list" id="social-links"></div>
  </div>
</aside>

<!-- HERO SECTION (Empty Initial State) -->
<section class="hero">
  <div class="content-wrapper" style="padding: 0;">
    <h1 class="hero__primary" id="hero-primary"></h1>
    <p class="hero__secondary" id="hero-secondary"></p>
    <a href="#" class="hero__cta" id="hero-cta" style="display: none;">
      <i style="display: none;"></i>
      <span id="hero-cta-text"></span>
    </a>
    <div class="hero__footer" id="hero-footer" style="display: none;"></div>
  </div>
</section>

<script>
  window.__FALLBACK_DATA = {
    header: {
      alticon: <%- JSON.stringify(header.alticon || "") %>,
      alttext: <%- JSON.stringify(header.alttext || "") %>
    },
    sidebar: {
      alticon: <%- JSON.stringify(sidebar.header?.alticon || "") %>,
      alttext: <%- JSON.stringify(sidebar.header?.alttext || "") %>
    },
    hero: <%- JSON.stringify(hero || {}) %>
  };
</script>

<script>
  (function() {
    // ---------- HEADER & SIDEBAR BRAND ----------
    const headerBrand = document.getElementById('header-brand');
    const sidebarBrand = document.getElementById('sidebar-brand');

    function renderBrand(container, logourl, alticon, alttext, context) {
      if (logourl && logourl.trim() !== '') {
        const img = document.createElement('img');
        img.src = logourl;
        img.alt = alttext || '';
        img.className = 'brand__image';
        img.dataset.fallback = context;
        img.onerror = function() {
          this.onerror = null;
          const parent = this.parentNode;
          if (!parent) return;
          const fallback = window.__FALLBACK_DATA?.[context] || { alticon: '', alttext: '' };
          let html = '';
          if (fallback.alticon) html += `<i class="${fallback.alticon} brand__icon"></i>`;
          if (fallback.alttext) html += `<span class="brand__text">${fallback.alttext}</span>`;
          parent.innerHTML = html || '';
        };
        container.innerHTML = '';
        container.appendChild(img);
      } else {
        let html = '';
        if (alticon) html += `<i class="${alticon} brand__icon"></i>`;
        if (alttext) html += `<span class="brand__text">${alttext}</span>`;
        container.innerHTML = html;
      }
    }

    renderBrand(
      headerBrand,
      <%- JSON.stringify(header.logourl || "") %>,
      <%- JSON.stringify(header.alticon || "") %>,
      <%- JSON.stringify(header.alttext || "") %>,
      'header'
    );

    renderBrand(
      sidebarBrand,
      <%- JSON.stringify(sidebar.header?.logourl || "") %>,
      <%- JSON.stringify(sidebar.header?.alticon || "") %>,
      <%- JSON.stringify(sidebar.header?.alttext || "") %>,
      'sidebar'
    );

    // ---------- SIDEBAR NAVIGATION ----------
    const navContainer = document.getElementById('sidebar-navigation');
    const bodyLinks = <%- JSON.stringify(sidebar.body ||[]) %>;
    
    function renderNavLinks() {
      if (bodyLinks && bodyLinks.length > 0) {
        navContainer.innerHTML = bodyLinks.map(link => `
          <a href="${link.url || '#'}" class="nav-link">
            ${link.icon ? `<i class="${link.icon}"></i>` : ''}
            <div class="nav-link__content">
              <span class="nav-link__title">${link.text || ''}</span>
            </div>
          </a>
        `).join('');
        
        const navLinks = navContainer.querySelectorAll('.nav-link');
        
        navLinks.forEach(link => {
          link.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            const isHashLink = href && href.startsWith('#');
            if (!isHashLink) e.preventDefault();
            
            if (this.classList.contains('is-active')) {
              this.classList.remove('is-active');
            } else {
              navLinks.forEach(l => l.classList.remove('is-active'));
              this.classList.add('is-active');
            }
          });
        });
        
        const currentPath = window.location.pathname;
        navLinks.forEach(link => {
           if (link.getAttribute('href') === currentPath && currentPath !== '/') {
               link.classList.add('is-active');
           }
        });
      } else {
        navContainer.innerHTML = '';
      }
    }
    
    renderNavLinks();

    // ---------- SIDEBAR SOCIAL LINKS ----------
    const socialContainer = document.getElementById('social-links');
    const socialLinks = <%- JSON.stringify(sidebar.footer ||[]) %>;
    
    if (socialLinks && socialLinks.length > 0) {
      socialContainer.innerHTML = socialLinks.map(social => `
        <a href="${social.url || '#'}" target="_blank" class="social-link" rel="noopener">
          ${social.icon ? `<i class="${social.icon}"></i>` : ''}
        </a>
      `).join('');
    } else {
      socialContainer.innerHTML = '';
    }

    // ---------- HERO SECTION ----------
    const heroData = window.__FALLBACK_DATA.hero || {};
    
    function formatHeroText(text) {
      if (!text) return '';
      return text
        .replace(/\[color=(#[0-9a-fA-F]{3,8})\](.*?)\[\/color\]/gi, '<span style="color: $1;">$2</span>')
        .replace(/\[b\](.*?)\[\/b\]/gi, '<b>$1</b>')
        .replace(/\[u\](.*?)\[\/u\]/gi, '<u>$1</u>');
    }
    
    document.getElementById('hero-primary').innerHTML = formatHeroText(heroData.primarytext || '');
    document.getElementById('hero-secondary').innerHTML = formatHeroText(heroData.secondarytext || '');
    
    const footerEl = document.getElementById('hero-footer');
    if (heroData.footertext) {
      footerEl.innerHTML = formatHeroText(heroData.footertext);
      footerEl.style.display = 'block';
    } else {
      footerEl.style.display = 'none';
    }
    
    const ctaBtn = document.getElementById('hero-cta');
    const ctaText = document.getElementById('hero-cta-text');
    const buttonEnabled = heroData.buttonenabled === true || heroData.buttonenabled === 'true';
    
    if (buttonEnabled) {
      ctaBtn.style.display = 'inline-flex';
      ctaBtn.href = heroData.buttonurl || '#';
      ctaText.textContent = heroData.buttontext || '';
      
      const iconElement = ctaBtn.querySelector('i');
      if (heroData.buttonicon) {
        iconElement.className = heroData.buttonicon;
        iconElement.style.display = 'inline-block';
      } else {
        iconElement.className = '';
        iconElement.style.display = 'none';
      }
    } else {
      ctaBtn.style.display = 'none';
    }
  })();
</script>

<script>
  (function() {
    // Canvas Snow Effect
    const canvas = document.getElementById('snow-canvas');
    const ctx = canvas.getContext('2d');

    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    const maxFlakes = width < 768 ? 25 : 60;
    const flakes =[];

    for (let i = 0; i < maxFlakes; i++) {
      flakes.push({
        x: Math.random() * width,
        y: Math.random() * height,
        r: Math.random() * 2.0 + 0.5,
        d: Math.random() * 1.0 + 0.3,
        a: Math.random() * Math.PI * 2,
        aStep: Math.random() * 0.015 + 0.005,
        opacity: Math.random() * 0.4 + 0.1
      });
    }

    function drawSnow() {
      ctx.clearRect(0, 0, width, height);
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        ctx.beginPath();
        ctx.fillStyle = `rgba(255, 255, 255, ${f.opacity})`;
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2, true);
        ctx.fill();
      }
      moveSnow();
      requestAnimationFrame(drawSnow);
    }

    function moveSnow() {
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        f.y += f.d;
        f.a += f.aStep;
        f.x += Math.sin(f.a) * 0.5;
        if (f.y > height) {
          f.y = -10;
          f.x = Math.random() * width;
        }
        if (f.x > width + 10) f.x = -10;
        if (f.x < -10) f.x = width + 10;
      }
    }

    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    });

    drawSnow();

    // Sidebar Interactions
    const openBtn = document.getElementById('open-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    const sidebarEl = document.getElementById('app-sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebarEl.classList.add('is-expanded');
      overlay.classList.add('is-visible');
      document.body.classList.add('has-menu-open');
    }

    function closeSidebar() {
      sidebarEl.classList.remove('is-expanded');
      overlay.classList.remove('is-visible');
      document.body.classList.remove('has-menu-open');
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
  })();
</script>
</body>
</html>
