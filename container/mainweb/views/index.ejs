<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Dynamic Header & Sidebar</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --bg-deep: #0A0A0F;
      --header-glass: rgba(15, 15, 20, 0.75);
      --sidebar-surface: #121218;
      --accent-muted: #6B7280;
      --accent-soft: #9CA3AF;
      --text-primary: #F1F5F9;
      --text-secondary: #94A3B8;
      --glow-primary: #22C55E;
      --glow-deep: #16a34a;
      --border-subtle: rgba(255, 255, 255, 0.06);
      --shadow-elevated: 0 10px 20px -8px rgba(0, 0, 0, 0.5);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-deep);
      color: var(--text-primary);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    #snow-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    .content-wrapper {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .app-header {
      width: 100%;
      background: var(--header-glass);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--border-subtle);
      box-shadow: var(--shadow-elevated);
    }

    .app-header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 240px;
      background: radial-gradient(
        ellipse 80% 100% at 50% 0%,
        rgba(34, 197, 94, 0.20) 0%,
        rgba(16, 185, 129, 0.08) 55%,
        transparent 100%
      );
      z-index: -1;
      pointer-events: none;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      transition: opacity 0.2s ease;
      text-decoration: none;
    }

    .brand--header {
      height: 40px;
      margin-left: -12px;
    }

    .brand--sidebar {
      height: 32px;
    }

    .brand:hover {
      opacity: 0.8;
    }

    .brand__image {
      height: 100%;
      width: auto;
      object-fit: contain;
    }

    .brand__icon {
      font-size: 1.6rem;
      color: var(--glow-primary);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.45);
      display: inline-block;
    }

    .brand__text {
      font-size: 1.7rem;
      font-weight: 800;
      color: var(--glow-primary);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.45);
      letter-spacing: -0.5px;
    }

    .menu-toggle {
      background: transparent;
      border: none;
      color: var(--text-secondary);
      font-size: 1.6rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 8px;
      transition: all 0.15s ease;
      margin-right: -8px;
    }

    .menu-toggle i {
      transition: transform 0.2s ease;
    }

    .menu-toggle:hover {
      background: rgba(255, 255, 255, 0.06);
      color: #FFFFFF;
    }

    .menu-toggle:active i {
      transform: scale(0.85);
    }

    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998;
      cursor: pointer;
    }

    .sidebar-overlay.is-visible {
      opacity: 1;
      visibility: visible;
    }

    .app-sidebar {
      position: fixed;
      top: 0;
      bottom: 0;
      left: 0;
      height: 100vh;
      height: 100dvh;
      width: 280px;
      max-width: 80vw;
      background: var(--sidebar-surface);
      z-index: 999;
      display: flex;
      flex-direction: column;
      border-top-right-radius: 24px;
      border-bottom-right-radius: 24px;
      border-right: 1px solid var(--border-subtle);
      box-shadow: 4px 0 12px rgba(0, 0, 0, 0.4);
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .app-sidebar.is-expanded {
      transform: translateX(0);
    }

    .sidebar__header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 24px;
      border-bottom: 1px solid var(--border-subtle);
      height: 73px;
      flex-shrink: 0;
    }

    .sidebar__body {
      flex: 1;
      padding: 12px 8px 20px 8px;
      overflow-y: auto;
    }

    .nav-menu {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 15px;
      min-height: 64px;
      color: var(--text-secondary);
      text-decoration: none;
      border-radius: 12px;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .nav-link i {
      font-size: 1.4rem;
      width: 30px;
      text-align: center;
      flex-shrink: 0;
      color: var(--glow-primary);
      transition: color 0.2s ease;
    }

    .nav-link__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      line-height: 1.3;
    }

    .nav-link__title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    .nav-link:hover {
      background: rgba(255, 255, 255, 0.04);
    }

    .nav-link.is-active {
      background: var(--glow-primary);
    }

    .nav-link.is-active i {
      color: #ffffff;
    }

    .nav-link.is-active .nav-link__title {
      color: #ffffff;
    }

    .sidebar__footer {
      border-top: 1px solid var(--border-subtle);
      flex-shrink: 0;
      min-height: calc(73px + env(safe-area-inset-bottom));
      padding: 15px 24px;
      padding-bottom: calc(15px + env(safe-area-inset-bottom));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: auto;
    }

    .social-list {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      width: 100%;
    }

    .social-link {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 42px;
      height: 42px;
      background-color: var(--glow-primary);
      color: #ffffff;
      border-radius: 50%;
      text-decoration: none;
      font-size: 19px;
      transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    }

    .social-link:hover {
      background-color: var(--glow-deep);
      color: #ffffff;
      transform: translateY(-3px);
      box-shadow: 0 8px 16px -4px rgba(34, 197, 94, 0.4);
    }

    .sidebar__close {
      background: transparent;
      border: none;
      color: var(--text-secondary);
      font-size: 1.5rem;
      cursor: pointer;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
      margin-right: -8px;
    }

    .sidebar__close i {
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .app-sidebar.is-expanded .sidebar__close i {
      transform: rotate(90deg);
    }

    .sidebar__close:hover {
      background: rgba(255, 255, 255, 0.06);
      color: #FFFFFF;
    }

    .sidebar__header,
    .sidebar__body,
    .sidebar__footer {
      opacity: 0;
      transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .app-sidebar.is-expanded .sidebar__header {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.1s;
    }

    .app-sidebar.is-expanded .sidebar__body {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.18s;
    }

    .app-sidebar.is-expanded .sidebar__footer {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.26s;
    }

    body.has-menu-open {
      overflow: hidden;
      touch-action: none;
    }

    .demo-placeholder {
      padding: 60px 0;
      text-align: center;
      color: var(--text-secondary);
    }
  </style>
</head>
<body>

<canvas id="snow-canvas"></canvas>

<header class="app-header">
  <div class="content-wrapper">
    <nav class="navbar">
      <a href="/" class="brand brand--header" id="header-brand"></a>
      <button class="menu-toggle" id="open-sidebar" aria-label="Open Menu">
        <i class="fa-solid fa-bars"></i>
      </button>
    </nav>
  </div>
</header>

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<aside class="app-sidebar" id="app-sidebar">
  <div class="sidebar__header">
    <a href="/" class="brand brand--sidebar" id="sidebar-brand"></a>
    <button class="sidebar__close" id="close-sidebar" aria-label="Close Menu">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <div class="sidebar__body">
    <nav class="nav-menu" id="sidebar-navigation"></nav>
  </div>

  <div class="sidebar__footer">
    <div class="social-list" id="social-links"></div>
  </div>
</aside>

<div class="content-wrapper demo-placeholder">
  <p style="opacity:0.5;">— Dark Gray Header + Green Gaming Theme —</p>
</div>

<script>
  window.__FALLBACK_DATA = {
    header: {
      alticon: <%- JSON.stringify(header.alticon || "") %>,
      alttext: <%- JSON.stringify(header.alttext || "") %>
    },
    sidebar: {
      alticon: <%- JSON.stringify(sidebar.header?.alticon || "") %>,
      alttext: <%- JSON.stringify(sidebar.header?.alttext || "") %>
    }
  };
</script>

<script>
  (function() {
    const headerBrand = document.getElementById('header-brand');
    const sidebarBrand = document.getElementById('sidebar-brand');

    function renderBrand(container, logourl, alticon, alttext, context) {
      if (logourl && logourl.trim() !== '') {
        const img = document.createElement('img');
        img.src = logourl;
        img.alt = alttext || 'Logo';
        img.className = 'brand__image';
        img.dataset.fallback = context;
        img.onerror = function() {
          this.onerror = null;
          const parent = this.parentNode;
          if (!parent) return;
          const fallback = window.__FALLBACK_DATA?.[context] || { alticon: '', alttext: '' };
          let html = '';
          if (fallback.alticon) html += `<i class="${fallback.alticon} brand__icon"></i>`;
          if (fallback.alttext) html += `<span class="brand__text">${fallback.alttext}</span>`;
          parent.innerHTML = html || '';
        };
        container.innerHTML = '';
        container.appendChild(img);
      } else {
        let html = '';
        if (alticon) html += `<i class="${alticon} brand__icon"></i>`;
        if (alttext) html += `<span class="brand__text">${alttext}</span>`;
        container.innerHTML = html;
      }
    }

    renderBrand(
      headerBrand,
      <%- JSON.stringify(header.logourl || "") %>,
      <%- JSON.stringify(header.alticon || "") %>,
      <%- JSON.stringify(header.alttext || "") %>,
      'header'
    );

    renderBrand(
      sidebarBrand,
      <%- JSON.stringify(sidebar.header?.logourl || "") %>,
      <%- JSON.stringify(sidebar.header?.alticon || "") %>,
      <%- JSON.stringify(sidebar.header?.alttext || "") %>,
      'sidebar'
    );

    const navContainer = document.getElementById('sidebar-navigation');
    const bodyLinks = <%- JSON.stringify(sidebar.body || []) %>;
    
    function renderNavLinks() {
      if (bodyLinks.length > 0) {
        navContainer.innerHTML = bodyLinks.map(link => `
          <a href="${link.url || '#'}" class="nav-link">
            ${link.icon ? `<i class="${link.icon}"></i>` : ''}
            <div class="nav-link__content">
              <span class="nav-link__title">${link.text || 'Untitled Link'}</span>
            </div>
          </a>
        `).join('');
        
        const navLinks = navContainer.querySelectorAll('.nav-link');
        
        function setActiveLink(clickedLink) {
          navLinks.forEach(link => link.classList.remove('is-active'));
          clickedLink.classList.add('is-active');
        }
        
        navLinks.forEach(link => {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            setActiveLink(this);
          });
        });
        
        // No default active state – user must click to activate
      } else {
        navContainer.innerHTML = '<p style="text-align:center;color:var(--text-secondary);font-size:13px;margin-top:20px;">No navigation links yet</p>';
      }
    }
    
    renderNavLinks();

    const socialContainer = document.getElementById('social-links');
    const socialLinks = <%- JSON.stringify(sidebar.footer || []) %>;
    if (socialLinks.length > 0) {
      socialContainer.innerHTML = socialLinks.map(social => `
        <a href="${social.url}" target="_blank" class="social-link" rel="noopener">
          <i class="${social.icon}"></i>
        </a>
      `).join('');
    } else {
      socialContainer.innerHTML = '<p style="text-align:center;color:var(--text-secondary);font-size:13px;width:100%;margin:0;">No socials yet</p>';
    }
  })();
</script>

<script>
  (function() {
    const canvas = document.getElementById('snow-canvas');
    const ctx = canvas.getContext('2d');

    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    const maxFlakes = width < 768 ? 25 : 60;
    const flakes = [];

    for (let i = 0; i < maxFlakes; i++) {
      flakes.push({
        x: Math.random() * width,
        y: Math.random() * height,
        r: Math.random() * 2.0 + 0.5,
        d: Math.random() * 1.0 + 0.3,
        a: Math.random() * Math.PI * 2,
        aStep: Math.random() * 0.015 + 0.005,
        opacity: Math.random() * 0.4 + 0.1
      });
    }

    function drawSnow() {
      ctx.clearRect(0, 0, width, height);
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        ctx.beginPath();
        ctx.fillStyle = `rgba(255, 255, 255, ${f.opacity})`;
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2, true);
        ctx.fill();
      }
      moveSnow();
      requestAnimationFrame(drawSnow);
    }

    function moveSnow() {
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        f.y += f.d;
        f.a += f.aStep;
        f.x += Math.sin(f.a) * 0.5;
        if (f.y > height) {
          f.y = -10;
          f.x = Math.random() * width;
        }
        if (f.x > width + 10) f.x = -10;
        if (f.x < -10) f.x = width + 10;
      }
    }

    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    });

    drawSnow();

    const openBtn = document.getElementById('open-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    const sidebarEl = document.getElementById('app-sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebarEl.classList.add('is-expanded');
      overlay.classList.add('is-visible');
      document.body.classList.add('has-menu-open');
    }

    function closeSidebar() {
      sidebarEl.classList.remove('is-expanded');
      overlay.classList.remove('is-visible');
      document.body.classList.remove('has-menu-open');
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
  })();
</script>
</body>
</html>
