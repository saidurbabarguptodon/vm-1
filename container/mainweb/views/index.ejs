<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Dynamic Header & Sidebar</title>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icon CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    /* ✦ DARK GRAY COLOR PALETTE — Clean & Neutral ✦ */
    :root {
      --bg-dark: #0A0A0F;
      --header-bg: rgba(15, 15, 20, 0.75);
      --sidebar-bg: #121218;
      
      --accent-gray: #6B7280;
      --accent-light: #9CA3AF;
      
      --text-light: #F1F5F9;
      --text-muted: #94A3B8;
      
      --gradient-logo: linear-gradient(135deg, #E2E8F0 0%, #94A3B8 100%);
      --gradient-glow: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 100%);
      
      --border-light: rgba(255, 255, 255, 0.06);
      --shadow-soft: 0 10px 20px -8px rgba(0, 0, 0, 0.5);
    }

    /* RESET & TYPOGRAPHY */
    * { 
      margin: 0; 
      padding: 0; 
      box-sizing: border-box; 
      -webkit-tap-highlight-color: transparent; 
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* LAYOUT */
    .container {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0; 
    }

    /* ✦ HEADER ✦ */
    .header {
      width: 100%;
      background: var(--header-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--border-light);
      box-shadow: var(--shadow-soft);
    }

    /* ✦ PURPLE AURORA GLOW ✦ */
    .header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 240px; 
      background: radial-gradient(
        ellipse 80% 100% at 50% 0%,
        rgba(139, 92, 246, 0.22) 0%, 
        rgba(59, 130, 246, 0.08) 55%, 
        transparent 100%
      );
      z-index: -1;
      pointer-events: none;
    }

    /* ✦ LOGO STYLING ✦ */
    .header-logo, .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      transition: opacity 0.2s ease;
      text-decoration: none;
    }
    .header-logo { height: 40px; margin-left: -12px; }
    .sidebar-logo { height: 32px; }
    .header-logo:hover, .sidebar-logo:hover { opacity: 0.8; }
    
    .header-logo img, .sidebar-logo img {
      height: 100%;
      width: auto; 
      object-fit: contain;
    }

    /* ✦ GLOW GRADIENT FOR ICON & TEXT ✦ */
    .header-alticon, .sidebar-alticon {
      font-size: 1.6rem; 
      background: var(--gradient-glow);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      display: inline-block; 
    }
    .header-alttext, .sidebar-alttext {
      font-size: 1.7rem; 
      font-weight: 800;
      background: var(--gradient-glow);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
    }

    /* ✦ MENU TOGGLE BUTTON ✦ */
    .menu-toggle-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 1.3rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      transition: all 0.15s ease;
      margin-right: -4px;
    }
    .menu-toggle-btn i { transition: transform 0.2s ease; }
    .menu-toggle-btn:hover { background: rgba(255, 255, 255, 0.06); color: #FFFFFF; }
    .menu-toggle-btn:active i { transform: scale(0.85); }

    /* ✦ SIDEBAR OVERLAY ✦ */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6); 
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998; 
      cursor: pointer; 
    }
    .sidebar-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    /* ✦ SIDEBAR ✦ */
    .sidebar {
      position: fixed;
      top: 0;
      bottom: 0; 
      left: 0;
      height: 100vh; 
      height: 100dvh; 
      width: 320px;
      max-width: 85vw; 
      background: var(--sidebar-bg);
      z-index: 999;
      display: flex;
      flex-direction: column;
      border-top-right-radius: 24px;
      border-bottom-right-radius: 24px;
      border-right: 1px solid var(--border-light);
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sidebar.active {
      transform: translateX(0);
    }

    /* ✦ SIDEBAR SECTIONS ✦ */
    .sidebar-header {
      display: flex;
      justify-content: space-between; 
      align-items: center;
      padding: 20px 24px;
      border-bottom: 1px solid var(--border-light);
      height: 73px; 
      flex-shrink: 0; 
    }

    .sidebar-body {
      flex: 1; 
      padding: 24px;
      overflow-y: auto; 
    }

    .sidebar-footer {
      padding: 24px;
      padding-bottom: calc(24px + env(safe-area-inset-bottom)); 
      border-top: 1px solid var(--border-light);
      flex-shrink: 0;
    }

    /* ✦ ANIMATIONS ✦ */
    .sidebar-header, .sidebar-body, .sidebar-footer {
      opacity: 0;
      transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sidebar.active .sidebar-header { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
    .sidebar.active .sidebar-body { opacity: 1; transform: translateY(0); transition-delay: 0.18s; }
    .sidebar.active .sidebar-footer { opacity: 1; transform: translateY(0); transition-delay: 0.26s; }
    
    /* ✦ CLOSE BUTTON ✦ */
    .sidebar-close-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 1.5rem;
      cursor: pointer;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
      margin-right: -8px; 
    }
    .sidebar-close-btn i { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .sidebar.active .sidebar-close-btn i { transform: rotate(90deg); }
    .sidebar-close-btn:hover { background: rgba(255, 255, 255, 0.06); color: #FFFFFF; }
    
    body.menu-open { overflow: hidden; touch-action: none; }

    .demo-content { padding: 60px 0; text-align: center; color: var(--text-muted); }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <div class="container">
      <nav class="navbar">
        <!-- MAIN LOGO -->
        <a href="/" class="header-logo" id="header-logo-container">
          <% if (header.logourl && header.logourl !== "") { %>
            <img 
              src="<%= header.logourl %>" 
              alt="Logo" 
              id="header-logo-img"
              onerror="this.onerror=null; fallbackHeaderToIconMode()"
            >
          <% } else { %>
            <% if (header.alticon && header.alticon !== "") { %>
              <i class="<%= header.alticon %> header-alticon" id="header-alticon"></i>
            <% } %>
            <% if (header.alttext && header.alttext !== "") { %>
              <span class="header-alttext" id="header-alttext"><%= header.alttext %></span>
            <% } %>
          <% } %>
        </a>

        <button class="menu-toggle-btn" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <!-- SIDEBAR OVERLAY -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <!-- SIDEBAR MENU -->
  <aside class="sidebar" id="sidebar">
    
    <!-- SECTION 1: HEADER -->
    <div class="sidebar-header">
      <a href="/" class="sidebar-logo" id="sidebar-logo-container">
        <!-- UPDATED FROM hamburger TO sidebar -->
        <% if (sidebar.logourl && sidebar.logourl !== "") { %>
          <img 
            src="<%= sidebar.logourl %>" 
            alt="Sidebar Logo" 
            id="sidebar-logo-img"
            onerror="this.onerror=null; fallbackSidebarToIconMode()"
          >
        <% } else { %>
          <% if (sidebar.alticon && sidebar.alticon !== "") { %>
            <i class="<%= sidebar.alticon %> sidebar-alticon" id="sidebar-alticon"></i>
          <% } %>
          <% if (sidebar.alttext && sidebar.alttext !== "") { %>
            <span class="sidebar-alttext" id="sidebar-alttext"><%= sidebar.alttext %></span>
          <% } %>
        <% } %>
      </a>

      <button class="sidebar-close-btn" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <!-- SECTION 2: BODY -->
    <div class="sidebar-body">
      <!-- Navigation links go here -->
    </div>

    <!-- SECTION 3: FOOTER -->
    <div class="sidebar-footer">
      <!-- Social icons / buttons go here -->
    </div>
  </aside>

  <div class="container demo-content">
    <p style="opacity:0.5;">— Dark Gray Header + Sidebar with Dynamic Logos —</p>
  </div>

  <script>
    // Main header fallback
    function fallbackHeaderToIconMode() {
      const container = document.getElementById('header-logo-container');
      if (!container) return;
      const alticon = '<%= header.alticon && header.alticon !== "" ? header.alticon : "" %>';
      const alttext = '<%= header.alttext && header.alttext !== "" ? header.alttext : "" %>';
      const iconHtml = alticon !== "" ? `<i class="${alticon} header-alticon"></i>` : "";
      const textHtml = alttext !== "" ? `<span class="header-alttext">${alttext}</span>` : "";
      container.innerHTML = iconHtml + textHtml;
    }

    // Sidebar fallback (Updated from hamburger to sidebar)
    function fallbackSidebarToIconMode() {
      const container = document.getElementById('sidebar-logo-container');
      if (!container) return;
      const alticon = '<%= sidebar.alticon && sidebar.alticon !== "" ? sidebar.alticon : "" %>';
      const alttext = '<%= sidebar.alttext && sidebar.alttext !== "" ? sidebar.alttext : "" %>';
      const iconHtml = alticon !== "" ? `<i class="${alticon} sidebar-alticon"></i>` : "";
      const textHtml = alttext !== "" ? `<span class="sidebar-alttext">${alttext}</span>` : "";
      container.innerHTML = iconHtml + textHtml;
    }

    // Toggle Logic
    const openBtn = document.getElementById('open-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    const sidebarElement = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebarElement.classList.add('active');
      overlay.classList.add('active');
      document.body.classList.add('menu-open'); 
    }

    function closeSidebar() {
      sidebarElement.classList.remove('active');
      overlay.classList.remove('active');
      document.body.classList.remove('menu-open'); 
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
  </script>

</body>
</html>
