<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Premium Dark Header & Menu</title>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icon CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    /* ✦ PREMIUM COLOR PALETTE: "Midnight Aurora" ✦ */
    :root {
      --bg-dark: #05050A; 
      --header-bg: rgba(5, 5, 10, 0.65); 
      --sidebar-bg: #0A0A14; 
      --header-border: rgba(139, 92, 246, 0.15); 
      
      --accent-violet: #8B5CF6; 
      --accent-blue: #3B82F6;   
      
      --text-light: #F8FAFC;
      --text-muted: #94A3B8; /* Premium Slate Gray used for elements */
      
      --gradient-logo: linear-gradient(135deg, #A855F7 0%, #3B82F6 100%);
    }

    /* RESET & TYPOGRAPHY */
    * { 
      margin: 0; 
      padding: 0; 
      box-sizing: border-box; 
      -webkit-tap-highlight-color: transparent; 
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* LAYOUT */
    .container {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0; 
    }

    /* ✦ HEADER GLASS ✦ */
    .header {
      width: 100%;
      background: var(--header-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--header-border);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    /* ✦ MULTI-COLOR AURORA GLOW ✦ */
    .header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      width: 100vw; 
      max-width: 800px; 
      height: 350px; 
      background: radial-gradient(
        50% 100% at 50% 0%, 
        rgba(139, 92, 246, 0.22) 0%,   
        rgba(59, 130, 246, 0.08) 45%,  
        transparent 100%               
      );
      z-index: -1;
      pointer-events: none;
    }

    /* ✦ LOGO STYLING ✦ */
    .header-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      height: 40px; 
      margin-left: -12px; 
      transition: opacity 0.2s ease;
      text-decoration: none;
    }
    .header-logo:hover { opacity: 0.85; }
    .header-logo img {
      height: 100%;
      width: auto; 
      object-fit: contain;
      filter: drop-shadow(0 4px 12px rgba(139, 92, 246, 0.3)); 
    }
    .header-alticon {
      font-size: 1.6rem; 
      color: var(--accent-violet);
      filter: drop-shadow(0 2px 8px rgba(139, 92, 246, 0.5)); 
    }
    .header-alttext {
      font-size: 1.7rem; 
      font-weight: 800;
      background: var(--gradient-logo);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
    }

    /* ✦ HAMBURGER BUTTON (OPEN) ✦ */
    .menu-toggle-btn {
      background: transparent;
      border: none;
      /* Set to gray */
      color: var(--text-muted); 
      font-size: 1.4rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 8px;
      transition: all 0.2s ease;
      margin-right: -8px; 
    }
    .menu-toggle-btn:hover {
      background: rgba(255, 255, 255, 0.08);
      /* Brightens up nicely on hover */
      color: var(--text-light); 
    }

    /* ✦ SIDEBAR OVERLAY ✦ */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998; 
    }
    .sidebar-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    /* ✦ SIDEBAR MENU (LEFT TO RIGHT SLIDE) ✦ */
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      width: 320px;
      max-width: 85vw; 
      background: var(--sidebar-bg);
      border-right: 1px solid var(--header-border);
      box-shadow: 10px 0 30px rgba(0, 0, 0, 0.5);
      z-index: 999;
      display: flex;
      flex-direction: column;
      
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); 
    }
    .sidebar.active {
      transform: translateX(0);
    }

    /* SIDEBAR SECTIONS */
    .sidebar-header {
      display: flex;
      justify-content: flex-end; 
      align-items: center;
      padding: 20px 24px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      height: 73px; 
    }
    
    /* ✦ HAMBURGER BUTTON (CLOSE) ✦ */
    .sidebar-close-btn {
      background: transparent;
      border: none;
      /* Set to gray */
      color: var(--text-muted); 
      font-size: 1.5rem;
      cursor: pointer;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }
    .sidebar-close-btn:hover {
      background: rgba(255, 255, 255, 0.08);
      /* Brightens up nicely on hover */
      color: var(--text-light); 
    }

    .sidebar-body {
      flex: 1; 
      padding: 24px;
      overflow-y: auto; 
    }

    .sidebar-footer {
      padding: 24px;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <div class="container">
      <nav class="navbar">
        <!-- LOGO (Left) -->
        <a href="/" class="header-logo" id="header-logo-container">
          <% if (header.logourl && header.logourl !== "") { %>
            <img 
              src="<%= header.logourl %>" 
              alt="Logo" 
              id="header-logo-img"
              onerror="this.onerror=null; fallbackToIconMode()"
            >
          <% } else { %>
            <% if (header.alticon && header.alticon !== "") { %>
              <i class="<%= header.alticon %> header-alticon" id="header-alticon"></i>
            <% } %>
            <% if (header.alttext && header.alttext !== "") { %>
              <span class="header-alttext" id="header-alttext"><%= header.alttext %></span>
            <% } %>
          <% } %>
        </a>

        <!-- HAMBURGER BUTTON (Right) -->
        <button class="menu-toggle-btn" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <!-- SIDEBAR OVERLAY -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <!-- SIDEBAR MENU -->
  <aside class="sidebar" id="sidebar">
    <!-- SECTION 1: HEADER -->
    <div class="sidebar-header">
      <button class="sidebar-close-btn" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <!-- SECTION 2: BODY -->
    <div class="sidebar-body">
      <!-- Empty for now, ready for navigation links -->
    </div>

    <!-- SECTION 3: FOOTER -->
    <div class="sidebar-footer">
      <!-- Empty for now, ready for socials/buttons -->
    </div>
  </aside>

  <script>
    /* ✦ LOGO FALLBACK LOGIC ✦ */
    function fallbackToIconMode() {
      const container = document.getElementById('header-logo-container');
      if (!container) return;
      
      const alticon = '<%= header.alticon && header.alticon !== "" ? header.alticon : "" %>';
      const alttext = '<%= header.alttext && header.alttext !== "" ? header.alttext : "" %>';
      
      const iconHtml = alticon !== "" ? `<i class="${alticon} header-alticon"></i>` : "";
      const textHtml = alttext !== "" ? `<span class="header-alttext">${alttext}</span>` : "";
      
      container.innerHTML = iconHtml + textHtml;
    }

    /* ✦ SIDEBAR MENU LOGIC ✦ */
    const openBtn = document.getElementById('open-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    // Function to open sidebar
    function openSidebar() {
      sidebar.classList.add('active');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden'; 
    }

    // Function to close sidebar
    function closeSidebar() {
      sidebar.classList.remove('active');
      overlay.classList.remove('active');
      document.body.style.overflow = ''; 
    }

    // Event Listeners
    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar); 
  </script>

</body>
</html>
