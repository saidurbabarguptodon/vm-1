<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Dynamic Header & Sidebar</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    :root {
      --bg-dark: #0A0A0F;
      --header-bg: rgba(15, 15, 20, 0.75);
      --sidebar-bg: #121218;
      --accent-gray: #6B7280;
      --accent-light: #9CA3AF;
      --text-light: #F1F5F9;
      --text-muted: #94A3B8;
      --single-glow-color: #22C55E;
      --single-glow-hover: #16a34a;
      --border-light: rgba(255, 255, 255, 0.06);
      --shadow-soft: 0 10px 20px -8px rgba(0, 0, 0, 0.5);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    #snow-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    .container {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
    }

    .header {
      width: 100%;
      background: var(--header-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--border-light);
      box-shadow: var(--shadow-soft);
    }

    .header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 240px;
      background: radial-gradient(
        ellipse 80% 100% at 50% 0%,
        rgba(34, 197, 94, 0.20) 0%,
        rgba(16, 185, 129, 0.08) 55%,
        transparent 100%
      );
      z-index: -1;
      pointer-events: none;
    }

    .header-logo, .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      transition: opacity 0.2s ease;
      text-decoration: none;
    }

    .header-logo { height: 40px; margin-left: -12px; }
    .sidebar-logo { height: 32px; }

    .header-logo:hover, .sidebar-logo:hover { opacity: 0.8; }

    .header-logo img, .sidebar-logo img {
      height: 100%;
      width: auto;
      object-fit: contain;
    }

    .header-alticon, .sidebar-alticon {
      font-size: 1.6rem;
      color: var(--single-glow-color);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.45);
      display: inline-block;
    }

    .header-alttext, .sidebar-alttext {
      font-size: 1.7rem;
      font-weight: 800;
      color: var(--single-glow-color);
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.45);
      letter-spacing: -0.5px;
    }

    .menu-toggle-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 1.6rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 8px;
      transition: all 0.15s ease;
      margin-right: -8px;
    }

    .menu-toggle-btn i { transition: transform 0.2s ease; }
    .menu-toggle-btn:hover { background: rgba(255, 255, 255, 0.06); color: #FFFFFF; }
    .menu-toggle-btn:active i { transform: scale(0.85); }

    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998;
      cursor: pointer;
    }

    .sidebar-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    .sidebar {
      position: fixed;
      top: 0;
      bottom: 0;
      left: 0;
      height: 100vh;
      height: 100dvh;
      width: 280px;
      max-width: 80vw;
      background: var(--sidebar-bg);
      z-index: 999;
      display: flex;
      flex-direction: column;
      border-top-right-radius: 24px;
      border-bottom-right-radius: 24px;
      border-right: 1px solid var(--border-light);
      box-shadow: 4px 0 12px rgba(0, 0, 0, 0.4);
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .sidebar.active {
      transform: translateX(0);
    }

    .sidebar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 24px;
      border-bottom: 1px solid var(--border-light);
      height: 73px;
      flex-shrink: 0;
    }

    .sidebar-body {
      flex: 1;
      padding: 20px 12px;  /* Reduced top/left padding to move items up/left */
      overflow-y: auto;
    }

    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;  /* Tighter gap between links */
    }

    .sidebar-nav-link {
      display: flex;
      align-items: flex-start;  /* Align to top for multi-line */
      gap: 14px;
      padding: 10px 14px;       /* Slightly reduced padding */
      color: var(--text-muted);
      text-decoration: none;
      border-radius: 12px;
      transition: all 0.2s ease;
    }

    .sidebar-nav-link i {
      font-size: 1.5rem;
      width: 28px;
      text-align: center;
      margin-top: 2px;  /* Fine-tune vertical alignment */
      transition: color 0.2s ease;
    }

    /* Content wrapper for text and description */
    .nav-content {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .nav-title {
      font-size: 1.1rem;       /* Slightly smaller than before */
      font-weight: 600;
      line-height: 1.3;
      color: var(--text-light);
    }

    .nav-desc {
      font-size: 0.75rem;
      font-weight: 400;
      line-height: 1.3;
      color: var(--text-muted);
      opacity: 0.8;
    }

    .sidebar-nav-link:hover {
      background: rgba(255, 255, 255, 0.04);
      transform: translateX(4px);
    }

    .sidebar-nav-link:hover i {
      color: var(--single-glow-color);
      text-shadow: 0 0 10px rgba(34, 197, 94, 0.4);
    }

    .sidebar-nav-link:hover .nav-title {
      color: #ffffff;
    }

    .sidebar-footer {
      border-top: 1px solid var(--border-light);
      flex-shrink: 0;
      min-height: calc(73px + env(safe-area-inset-bottom));
      padding: 15px 24px;
      padding-bottom: calc(15px + env(safe-area-inset-bottom));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: auto;
    }

    .social-links {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      width: 100%;
    }

    .social-icon {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 42px;
      height: 42px;
      background-color: var(--single-glow-color);
      color: #ffffff;
      border-radius: 50%;
      text-decoration: none;
      font-size: 19px;
      transition: background-color 0.3s ease, transform 0.3s ease;
    }

    .social-icon:hover {
      background-color: var(--single-glow-hover);
      color: #ffffff;
      transform: translateY(-3px);
    }

    .sidebar-header, .sidebar-body, .sidebar-footer {
      opacity: 0;
      transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .sidebar.active .sidebar-header { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
    .sidebar.active .sidebar-body { opacity: 1; transform: translateY(0); transition-delay: 0.18s; }
    .sidebar.active .sidebar-footer { opacity: 1; transform: translateY(0); transition-delay: 0.26s; }

    .sidebar-close-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 1.5rem;
      cursor: pointer;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
      margin-right: -8px;
    }

    .sidebar-close-btn i { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .sidebar.active .sidebar-close-btn i { transform: rotate(90deg); }
    .sidebar-close-btn:hover { background: rgba(255, 255, 255, 0.06); color: #FFFFFF; }

    body.menu-open { overflow: hidden; touch-action: none; }
    .demo-content { padding: 60px 0; text-align: center; color: var(--text-muted); }
  </style>
</head>
<body>

  <canvas id="snow-canvas"></canvas>

  <header class="header">
    <div class="container">
      <nav class="navbar">
        <a href="/" class="header-logo" id="header-logo-container"></a>
        <button class="menu-toggle-btn" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <a href="/" class="sidebar-logo" id="sidebar-logo-container"></a>
      <button class="sidebar-close-btn" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <div class="sidebar-body">
      <nav class="sidebar-nav" id="sidebar-nav-links"></nav>
    </div>

    <div class="sidebar-footer">
      <div class="social-links" id="social-links-container"></div>
    </div>
  </aside>

  <div class="container demo-content">
    <p style="opacity:0.5;">— Dark Gray Header + Green Gaming Theme —</p>
  </div>

  <script>
    window.__FALLBACK_DATA = {
      header: {
        alticon: <%- JSON.stringify(header.alticon || "") %>,
        alttext: <%- JSON.stringify(header.alttext || "") %>
      },
      sidebar: {
        alticon: <%- JSON.stringify(sidebar.header?.alticon || "") %>,
        alttext: <%- JSON.stringify(sidebar.header?.alttext || "") %>
      }
    };
  </script>

  <script>
    (function() {
      const headerLogoContainer = document.getElementById('header-logo-container');
      const sidebarLogoContainer = document.getElementById('sidebar-logo-container');

      function renderLogo(container, logourl, alticon, alttext, prefix) {
        if (logourl && logourl.trim() !== '') {
          const img = document.createElement('img');
          img.src = logourl;
          img.alt = alttext || 'Logo';
          img.dataset.fallback = prefix;
          img.onerror = function() {
            this.onerror = null;
            const parent = this.parentNode;
            if (!parent) return;
            const fallback = window.__FALLBACK_DATA?.[prefix] || { alticon: '', alttext: '' };
            let html = '';
            if (fallback.alticon) html += `<i class="${fallback.alticon} ${prefix}-alticon"></i>`;
            if (fallback.alttext) html += `<span class="${prefix}-alttext">${fallback.alttext}</span>`;
            parent.innerHTML = html || '';
          };
          container.innerHTML = '';
          container.appendChild(img);
        } else {
          let html = '';
          if (alticon) html += `<i class="${alticon} ${prefix}-alticon"></i>`;
          if (alttext) html += `<span class="${prefix}-alttext">${alttext}</span>`;
          container.innerHTML = html;
        }
      }

      renderLogo(
        headerLogoContainer,
        <%- JSON.stringify(header.logourl || "") %>,
        <%- JSON.stringify(header.alticon || "") %>,
        <%- JSON.stringify(header.alttext || "") %>,
        'header'
      );

      renderLogo(
        sidebarLogoContainer,
        <%- JSON.stringify(sidebar.header?.logourl || "") %>,
        <%- JSON.stringify(sidebar.header?.alticon || "") %>,
        <%- JSON.stringify(sidebar.header?.alttext || "") %>,
        'sidebar'
      );

      const navContainer = document.getElementById('sidebar-nav-links');
      const bodyLinks = <%- JSON.stringify(sidebar.body || []) %>;
      if (bodyLinks.length > 0) {
        navContainer.innerHTML = bodyLinks.map(link => `
          <a href="${link.url || '#'}" class="sidebar-nav-link">
            ${link.icon ? `<i class="${link.icon}"></i>` : ''}
            <div class="nav-content">
              <span class="nav-title">${link.text || 'Untitled Link'}</span>
              ${link.description ? `<span class="nav-desc">${link.description}</span>` : ''}
            </div>
          </a>
        `).join('');
      } else {
        navContainer.innerHTML = '<p style="text-align:center;color:var(--text-muted);font-size:13px;margin-top:20px;">No navigation links yet</p>';
      }

      const socialContainer = document.getElementById('social-links-container');
      const socialLinks = <%- JSON.stringify(sidebar.footer || []) %>;
      if (socialLinks.length > 0) {
        socialContainer.innerHTML = socialLinks.map(social => `
          <a href="${social.url}" target="_blank" class="social-icon">
            <i class="${social.icon}"></i>
          </a>
        `).join('');
      } else {
        socialContainer.innerHTML = '<p style="text-align:center;color:var(--text-muted);font-size:13px;width:100%;margin:0;">No socials yet</p>';
      }
    })();
  </script>

  <script>
    const canvas = document.getElementById('snow-canvas');
    const ctx = canvas.getContext('2d');
    
    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    const maxFlakes = width < 768 ? 25 : 60;
    const flakes = [];

    for (let i = 0; i < maxFlakes; i++) {
      flakes.push({
        x: Math.random() * width,
        y: Math.random() * height,
        r: Math.random() * 2.0 + 0.5,
        d: Math.random() * 1.0 + 0.3,
        a: Math.random() * Math.PI * 2,
        aStep: Math.random() * 0.015 + 0.005,
        opacity: Math.random() * 0.4 + 0.1
      });
    }

    function drawSnow() {
      ctx.clearRect(0, 0, width, height);
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        ctx.beginPath();
        ctx.fillStyle = `rgba(255, 255, 255, ${f.opacity})`;
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2, true);
        ctx.fill();
      }
      moveSnow();
      requestAnimationFrame(drawSnow);
    }

    function moveSnow() {
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        f.y += f.d;
        f.a += f.aStep;
        f.x += Math.sin(f.a) * 0.5;
        if (f.y > height) {
          f.y = -10;
          f.x = Math.random() * width;
        }
        if (f.x > width + 10) f.x = -10;
        if (f.x < -10) f.x = width + 10;
      }
    }

    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    });

    drawSnow();

    const openBtn = document.getElementById('open-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    const sidebarElement = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebarElement.classList.add('active');
      overlay.classList.add('active');
      document.body.classList.add('menu-open');
    }

    function closeSidebar() {
      sidebarElement.classList.remove('active');
      overlay.classList.remove('active');
      document.body.classList.remove('menu-open');
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
  </script>
</body>
</html>
