<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Dark Classic Premium</title>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icon CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    /* ✦ DARK CLASSIC PREMIUM PALETTE — Deep Forest Green + Pure Black ✦ */
    :root {
      --bg-dark: #0A0A0F;
      
      /* Deep dark green glass header */
      --header-bg: rgba(10, 28, 22, 0.94);
      
      /* Solid deep forest green sidebar */
      --sidebar-bg: #0F2A23;
      
      --accent-muted: #1E3F37;
      --accent-light: #4A9A7E;
      
      --text-light: #F8FAFC;
      --text-muted: #A3B8B0;
      
      /* ✦ SIGNATURE GREEN GLOW (#22C55E) — kept as the premium accent ✦ */
      --single-glow-color: #22C55E; 
      --single-glow-hover: #16a34a;
      
      --border-light: rgba(255, 255, 255, 0.07);
      --shadow-soft: 0 12px 25px -10px rgba(34, 197, 94, 0.25);
    }

    /* RESET & TYPOGRAPHY */
    * { 
      margin: 0; 
      padding: 0; 
      box-sizing: border-box; 
      -webkit-tap-highlight-color: transparent; 
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* ✦ SNOWFALL CANVAS (kept — looks premium on deep black) ✦ */
    #snow-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    /* LAYOUT */
    .container {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0; 
    }

    /* ✦ HEADER — Dark classic glass with deep green ✦ */
    .header {
      width: 100%;
      background: var(--header-bg);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--border-light);
      box-shadow: var(--shadow-soft);
    }

    /* ✦ GREEN AURORA GLOW (enhanced for premium depth) ✦ */
    .header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 260px; 
      background: radial-gradient(
        ellipse 85% 100% at 50% 0%,
        rgba(34, 197, 94, 0.28) 0%,
        rgba(16, 185, 129, 0.10) 50%,
        transparent 100%
      );
      z-index: -1;
      pointer-events: none;
    }

    /* ✦ LOGO STYLING ✦ */
    .header-logo, .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      transition: opacity 0.2s ease;
      text-decoration: none;
    }
    .header-logo { height: 40px; margin-left: -12px; }
    .sidebar-logo { height: 32px; }
    .header-logo:hover, .sidebar-logo:hover { opacity: 0.9; }
    
    .header-logo img, .sidebar-logo img {
      height: 100%;
      width: auto; 
      object-fit: contain;
    }

    /* Header logo text/icon in glowing green */
    .header-alticon {
      font-size: 1.65rem; 
      color: var(--single-glow-color);
      text-shadow: 0 0 14px rgba(34, 197, 94, 0.6);
      display: inline-block; 
    }
    .header-alttext {
      font-size: 1.75rem; 
      font-weight: 800;
      color: var(--single-glow-color);
      text-shadow: 0 0 14px rgba(34, 197, 94, 0.6);
      letter-spacing: -0.6px;
    }

    /* Sidebar logo in pure white (classic contrast) */
    .sidebar-alticon {
      font-size: 1.65rem; 
      color: #FFFFFF;
      display: inline-block; 
    }
    .sidebar-alttext {
      font-size: 1.75rem; 
      font-weight: 800;
      color: #FFFFFF;
      letter-spacing: -0.6px;
    }

    /* ✦ MENU TOGGLE ✦ */
    .menu-toggle-btn {
      background: transparent;
      border: none;
      color: var(--text-light);
      font-size: 1.65rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 46px; 
      height: 46px; 
      border-radius: 10px;
      transition: all 0.2s ease;
      margin-right: -8px; 
    }
    .menu-toggle-btn i { transition: transform 0.2s ease; }
    .menu-toggle-btn:hover { 
      background: rgba(34, 197, 94, 0.15); 
      color: var(--single-glow-color); 
    }
    .menu-toggle-btn:active i { transform: scale(0.9); }

    /* ✦ SIDEBAR OVERLAY ✦ */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.65); 
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998; 
      cursor: pointer; 
    }
    .sidebar-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    /* ✦ SIDEBAR — Solid deep forest green with premium feel ✦ */
    .sidebar {
      position: fixed;
      top: 0;
      bottom: 0; 
      left: 0;
      height: 100vh; 
      height: 100dvh; 
      width: 268px; 
      max-width: 82vw; 
      background: var(--sidebar-bg);
      z-index: 999;
      display: flex;
      flex-direction: column;
      
      /* Premium thin glowing green border */
      border: 1px solid var(--single-glow-color); 
      border-left: none;
      
      border-top-right-radius: 28px;
      border-bottom-right-radius: 28px;
      
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 12px 0 30px -10px rgba(34, 197, 94, 0.3);
    }
    .sidebar.active {
      transform: translateX(0);
    }

    /* ✦ SIDEBAR SECTIONS ✦ */
    .sidebar-header {
      display: flex;
      justify-content: space-between; 
      align-items: center;
      padding: 0 24px;
      border-bottom: 1px solid var(--border-light);
      height: 74px;
      flex-shrink: 0; 
    }

    .sidebar-body {
      flex: 1; 
      padding: 24px 16px;
      overflow-y: auto; 
    }

    /* ✦ NAVIGATION LINKS ✦ */
    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .sidebar-nav-link {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 13px 18px;
      color: #FFFFFF;
      text-decoration: none;
      font-size: 1.06rem;
      font-weight: 500;
      border-radius: 14px;
      transition: all 0.2s ease;
    }

    .sidebar-nav-link i {
      font-size: 1.25rem;
      width: 24px;
      text-align: center;
      color: var(--single-glow-color);
      transition: all 0.2s ease;
    }

    .sidebar-nav-link:hover {
      background: rgba(34, 197, 94, 0.12);
      transform: translateX(6px);
      color: #FFFFFF;
    }

    .sidebar-nav-link:hover i {
      text-shadow: 0 0 12px rgba(34, 197, 94, 0.7);
    }

    /* ✦ SIDEBAR FOOTER ✦ */
    .sidebar-footer {
      border-top: 1px solid var(--border-light);
      flex-shrink: 0;
      min-height: calc(74px + env(safe-area-inset-bottom)); 
      padding: 16px 24px;
      padding-bottom: calc(16px + env(safe-area-inset-bottom));
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: auto; 
    }

    .social-links {
      display: flex;
      gap: 12px; 
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      width: 100%;
    }

    .social-icon {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 44px; 
      height: 44px;
      background-color: var(--single-glow-color);
      color: #ffffff;
      border-radius: 50%;
      text-decoration: none;
      font-size: 20px; 
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px -4px rgba(34, 197, 94, 0.4);
    }

    .social-icon:hover {
      background-color: var(--single-glow-hover);
      transform: translateY(-4px) scale(1.05);
    }

    /* ✦ ANIMATIONS ✦ */
    .sidebar-header, .sidebar-body, .sidebar-footer {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sidebar.active .sidebar-header { opacity: 1; transform: translateY(0); transition-delay: 0.08s; }
    .sidebar.active .sidebar-body { opacity: 1; transform: translateY(0); transition-delay: 0.16s; }
    .sidebar.active .sidebar-footer { opacity: 1; transform: translateY(0); transition-delay: 0.26s; }
    
    /* ✦ CLOSE BUTTON ✦ */
    .sidebar-close-btn {
      background: transparent;
      border: none;
      color: var(--text-light);
      font-size: 1.55rem;
      cursor: pointer;
      width: 38px;
      height: 38px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      margin-right: -8px; 
    }
    .sidebar-close-btn i { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .sidebar.active .sidebar-close-btn i { transform: rotate(90deg); }
    .sidebar-close-btn:hover { 
      background: rgba(34, 197, 94, 0.15); 
      color: var(--single-glow-color); 
    }
    
    body.menu-open { overflow: hidden; touch-action: none; }

    .demo-content { 
      padding: 80px 0; 
      text-align: center; 
      color: var(--text-muted); 
      font-size: 1.1rem;
    }
  </style>
</head>
<body>

  <!-- NATURAL SNOWFALL CANVAS -->
  <canvas id="snow-canvas"></canvas>

  <!-- HEADER -->
  <header class="header">
    <div class="container">
      <nav class="navbar">
        <!-- MAIN LOGO -->
        <a href="/" class="header-logo" id="header-logo-container">
          <% if (header.logourl && header.logourl !== "") { %>
            <img 
              src="<%= header.logourl %>" 
              alt="Logo" 
              id="header-logo-img"
              onerror="this.onerror=null; fallbackHeaderToIconMode()"
            >
          <% } else { %>
            <% if (header.alticon && header.alticon !== "") { %>
              <i class="<%= header.alticon %> header-alticon" id="header-alticon"></i>
            <% } %>
            <% if (header.alttext && header.alttext !== "") { %>
              <span class="header-alttext" id="header-alttext"><%= header.alttext %></span>
            <% } %>
          <% } %>
        </a>

        <button class="menu-toggle-btn" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <!-- SIDEBAR OVERLAY -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <!-- SIDEBAR MENU -->
  <aside class="sidebar" id="sidebar">
    
    <!-- SECTION 1: HEADER -->
    <div class="sidebar-header">
      <a href="/" class="sidebar-logo" id="sidebar-logo-container">
        <% if (sidebar.header && sidebar.header.logourl && sidebar.header.logourl !== "") { %>
          <img 
            src="<%= sidebar.header.logourl %>" 
            alt="Sidebar Logo" 
            id="sidebar-logo-img"
            onerror="this.onerror=null; fallbackSidebarToIconMode()"
          >
        <% } else if (sidebar.header) { %>
          <% if (sidebar.header.alticon && sidebar.header.alticon !== "") { %>
            <i class="<%= sidebar.header.alticon %> sidebar-alticon" id="sidebar-alticon"></i>
          <% } %>
          <% if (sidebar.header.alttext && sidebar.header.alttext !== "") { %>
            <span class="sidebar-alttext" id="sidebar-alttext"><%= sidebar.header.alttext %></span>
          <% } %>
        <% } %>
      </a>

      <button class="sidebar-close-btn" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <!-- SECTION 2: BODY -->
    <div class="sidebar-body">
      <% if (sidebar.body && sidebar.body.length > 0) { %>
        <nav class="sidebar-nav">
          <% sidebar.body.forEach(function(link) { %>
            <a href="<%= link.url || '#' %>" class="sidebar-nav-link">
              <% if (link.icon) { %>
                <i class="<%= link.icon %>"></i>
              <% } %>
              <span><%= link.text || 'Untitled Link' %></span>
            </a>
          <% }); %>
        </nav>
      <% } else { %>
        <p style="text-align: center; color: var(--text-muted); font-size: 13px; margin-top: 20px;">
          No navigation links yet
        </p>
      <% } %>
    </div>

    <!-- SECTION 3: FOOTER -->
    <div class="sidebar-footer">
      <% if (sidebar.footer && sidebar.footer.length > 0) { %>
        <div class="social-links">
          <% sidebar.footer.forEach(function(social) { %>
            <a href="<%= social.url %>" target="_blank" class="social-icon">
              <i class="<%= social.icon %>"></i>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <p style="text-align: center; color: var(--text-muted); font-size: 13px; width: 100%; margin: 0;">No socials yet</p>
      <% } %>
    </div>
  </aside>

  <div class="container demo-content">
    <p style="opacity:0.6;">— Dark Classic Premium Look • Deep Forest Green + Pure Black —</p>
    <p style="margin-top: 12px; font-size: 0.95rem;">Header &amp; Sidebar fixed exactly as you wanted.</p>
  </div>

  <script>
    // ==========================================
    // ✦ NATURAL SNOWFALL CANVAS EFFECT ✦
    // ==========================================
    const canvas = document.getElementById('snow-canvas');
    const ctx = canvas.getContext('2d');
    
    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    const maxFlakes = width < 768 ? 28 : 65;
    const flakes = [];

    for (let i = 0; i < maxFlakes; i++) {
      flakes.push({
        x: Math.random() * width,
        y: Math.random() * height,
        r: Math.random() * 2.2 + 0.6, 
        d: Math.random() * 1.1 + 0.4, 
        a: Math.random() * Math.PI * 2, 
        aStep: Math.random() * 0.016 + 0.006, 
        opacity: Math.random() * 0.45 + 0.12 
      });
    }

    function drawSnow() {
      ctx.clearRect(0, 0, width, height);
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        ctx.beginPath();
        ctx.fillStyle = `rgba(255, 255, 255, ${f.opacity})`;
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2, true);
        ctx.fill();
      }
      moveSnow();
      requestAnimationFrame(drawSnow);
    }

    function moveSnow() {
      for (let i = 0; i < maxFlakes; i++) {
        let f = flakes[i];
        f.y += f.d;
        f.a += f.aStep; 
        f.x += Math.sin(f.a) * 0.6;

        if (f.y > height) {
          f.y = -10;
          f.x = Math.random() * width;
        }
        if (f.x > width + 10) f.x = -10;
        if (f.x < -10) f.x = width + 10;
      }
    }

    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    });

    drawSnow();

    // ==========================================
    // ✦ HEADER & SIDEBAR LOGIC ✦
    // ==========================================

    function fallbackHeaderToIconMode() {
      const container = document.getElementById('header-logo-container');
      if (!container) return;
      const alticon = '<%= header.alticon && header.alticon !== "" ? header.alticon : "" %>';
      const alttext = '<%= header.alttext && header.alttext !== "" ? header.alttext : "" %>';
      const iconHtml = alticon !== "" ? `<i class="${alticon} header-alticon"></i>` : "";
      const textHtml = alttext !== "" ? `<span class="header-alttext">${alttext}</span>` : "";
      container.innerHTML = iconHtml + textHtml;
    }

    function fallbackSidebarToIconMode() {
      const container = document.getElementById('sidebar-logo-container');
      if (!container) return;
      const alticon = '<%= sidebar.header && sidebar.header.alticon !== "" ? sidebar.header.alticon : "" %>';
      const alttext = '<%= sidebar.header && sidebar.header.alttext !== "" ? sidebar.header.alttext : "" %>';
      const iconHtml = alticon !== "" ? `<i class="${alticon} sidebar-alticon"></i>` : "";
      const textHtml = alttext !== "" ? `<span class="sidebar-alttext">${alttext}</span>` : "";
      container.innerHTML = iconHtml + textHtml;
    }

    const openBtn = document.getElementById('open-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    const sidebarElement = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebarElement.classList.add('active');
      overlay.classList.add('active');
      document.body.classList.add('menu-open'); 
    }

    function closeSidebar() {
      sidebarElement.classList.remove('active');
      overlay.classList.remove('active');
      document.body.classList.remove('menu-open'); 
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
  </script>

</body>
</html>
