<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Dark Gray Header + Purple Aurora Glow</title>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icon CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    /* ✦ DARK GRAY COLOR PALETTE — Clean & Neutral ✦ */
    :root {
      --bg-dark: #0A0A0F;
      --header-bg: rgba(15, 15, 20, 0.75);
      --sidebar-bg: #121218;
      
      --accent-gray: #6B7280;
      --accent-light: #9CA3AF;
      
      --text-light: #F1F5F9;
      --text-muted: #94A3B8;
      
      --gradient-logo: linear-gradient(135deg, #E2E8F0 0%, #94A3B8 100%);
      
      --border-light: rgba(255, 255, 255, 0.06);
      --shadow-soft: 0 10px 20px -8px rgba(0, 0, 0, 0.5);
    }

    /* RESET & TYPOGRAPHY */
    * { 
      margin: 0; 
      padding: 0; 
      box-sizing: border-box; 
      -webkit-tap-highlight-color: transparent; 
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* LAYOUT */
    .container {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0; 
    }

    /* ✦ HEADER — Dark gray glass, no purple on the bar itself ✦ */
    .header {
      width: 100%;
      background: var(--header-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      position: sticky;
      top: 0;
      z-index: 100;
      
      border-bottom: 1px solid var(--border-light);
      box-shadow: var(--shadow-soft);
    }

    /* ✦ PURPLE AURORA GLOW — Restored below the header ✦ */
    .header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 240px; /* Tall visible glow */
      
      background: radial-gradient(
        ellipse 80% 100% at 50% 0%,
        rgba(139, 92, 246, 0.22) 0%,
        rgba(59, 130, 246, 0.08) 55%,
        transparent 100%
      );
      
      z-index: -1;
      pointer-events: none;
    }

    /* ✦ LOGO STYLING ✦ */
    .header-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      height: 40px; 
      margin-left: -12px; 
      transition: opacity 0.2s ease;
      text-decoration: none;
    }
    .header-logo:hover { opacity: 0.8; }
    .header-logo img {
      height: 100%;
      width: auto; 
      object-fit: contain;
    }
    .header-alticon {
      font-size: 1.6rem; 
      color: var(--accent-light);
    }
    .header-alttext {
      font-size: 1.7rem; 
      font-weight: 800;
      background: var(--gradient-logo);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
    }

    /* ✦ ENHANCED HAMBURGER BUTTON — Dark gray, no purple ✦ */
    .menu-toggle-btn {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      color: var(--text-muted);
      font-size: 1.4rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 12px;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      box-shadow: 0 4px 8px -2px rgba(0, 0, 0, 0.3);
      transition: all 0.2s cubic-bezier(0.2, 0.9, 0.4, 1);
      margin-right: -4px;
    }

    .menu-toggle-btn i {
      filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.2));
      transition: transform 0.2s ease;
    }

    .menu-toggle-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.15);
      color: #FFFFFF;
      box-shadow: 0 8px 16px -4px rgba(0, 0, 0, 0.4);
      transform: scale(1.02);
    }

    .menu-toggle-btn:active {
      transform: scale(0.96);
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
    }

    /* ✦ SIDEBAR OVERLAY ✦ */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6); 
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 998; 
      cursor: pointer; 
    }
    .sidebar-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    /* ✦ SIDEBAR — Dark gray, no colored accents ✦ */
    .sidebar {
      position: fixed;
      top: 0;
      bottom: 0; 
      left: 0;
      
      height: 100vh; 
      height: 100dvh; 
      
      width: 320px;
      max-width: 85vw; 
      background: var(--sidebar-bg);
      z-index: 999;
      display: flex;
      flex-direction: column;
      
      border-top-right-radius: 24px;
      border-bottom-right-radius: 24px;
      border-right: 1px solid var(--border-light);
      
      box-shadow: none;
      
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease; 
    }
    .sidebar.active {
      transform: translateX(0);
      box-shadow: 
        30px 0 60px rgba(0, 0, 0, 0.8),
        8px 0 20px rgba(0, 0, 0, 0.6),
        inset -2px 0 10px rgba(255, 255, 255, 0.02);
    }

    /* ✦ SIDEBAR ENTRANCE ANIMATIONS ✦ */
    .sidebar-header, .sidebar-body, .sidebar-footer {
      opacity: 0;
      transform: translateY(15px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .sidebar.active .sidebar-header {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.1s;
    }
    .sidebar.active .sidebar-body {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.18s;
    }
    .sidebar.active .sidebar-footer {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 0.26s;
    }

    /* SIDEBAR SECTIONS */
    .sidebar-header {
      display: flex;
      justify-content: flex-end; 
      align-items: center;
      padding: 20px 24px;
      border-bottom: 1px solid var(--border-light);
      height: 73px; 
    }
    
    /* ✦ CLOSE BUTTON — Matching dark gray style ✦ */
    .sidebar-close-btn {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      color: var(--text-muted);
      font-size: 1.5rem;
      cursor: pointer;
      width: 40px;
      height: 40px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      transition: all 0.2s ease;
    }
    .sidebar-close-btn i {
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sidebar.active .sidebar-close-btn i {
      transform: rotate(90deg);
    }
    .sidebar-close-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.15);
      color: #FFFFFF;
      box-shadow: 0 6px 12px -4px rgba(0, 0, 0, 0.4);
    }

    .sidebar-body {
      flex: 1; 
      padding: 24px;
      overflow-y: auto; 
    }

    .sidebar-footer {
      padding: 24px;
      padding-bottom: calc(24px + env(safe-area-inset-bottom)); 
      border-top: 1px solid var(--border-light);
    }
    
    body.menu-open {
      overflow: hidden;
      touch-action: none; 
    }

    /* Demo content — optional */
    .demo-content {
      padding: 60px 0;
      text-align: center;
      color: var(--text-muted);
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <div class="container">
      <nav class="navbar">
        <!-- LOGO (Left) -->
        <a href="/" class="header-logo" id="header-logo-container">
          <i class="fa-solid fa-cloud header-alticon" id="header-alticon"></i>
          <span class="header-alttext" id="header-alttext">KexCloud</span>
        </a>

        <!-- HAMBURGER BUTTON (Right) -->
        <button class="menu-toggle-btn" id="open-sidebar" aria-label="Open Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </nav>
    </div>
  </header>

  <!-- SIDEBAR OVERLAY -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <!-- SIDEBAR MENU -->
  <aside class="sidebar" id="sidebar">
    <!-- SECTION 1: HEADER -->
    <div class="sidebar-header">
      <button class="sidebar-close-btn" id="close-sidebar" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <!-- SECTION 2: BODY (empty for now) -->
    <div class="sidebar-body">
      <!-- Navigation links can go here -->
    </div>

    <!-- SECTION 3: FOOTER (empty for now) -->
    <div class="sidebar-footer">
      <!-- Social icons / buttons can go here -->
    </div>
  </aside>

  <!-- Optional demo spacer -->
  <div class="container demo-content">
    <p style="opacity:0.5;">— Dark Gray Premium Header with Purple Aurora Glow —</p>
  </div>

  <script>
    /* ✦ SIDEBAR MENU LOGIC ✦ */
    const openBtn = document.getElementById('open-sidebar');
    const closeBtn = document.getElementById('close-sidebar');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function openSidebar() {
      sidebar.classList.add('active');
      overlay.classList.add('active');
      document.body.classList.add('menu-open'); 
    }

    function closeSidebar() {
      sidebar.classList.remove('active');
      overlay.classList.remove('active');
      document.body.classList.remove('menu-open'); 
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
  </script>

</body>
</html>
