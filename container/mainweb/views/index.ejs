<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>KexCloud | Premium Dark Header</title>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- FontAwesome Icon CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    /* ✦ PREMIUM COLOR PALETTE: "Midnight Aurora" ✦ */
    :root {
      /* Deep Obsidian - much richer than plain black */
      --bg-dark: #05050A; 
      
      /* Smoked Glass Header */
      --header-bg: rgba(5, 5, 10, 0.65); 
      --header-border: rgba(139, 92, 246, 0.15); 
      
      /* Core Accent Colors */
      --accent-violet: #8B5CF6; /* Vibrant Purple */
      --accent-blue: #3B82F6;   /* Electric Blue */
      
      --text-light: #F8FAFC;
      
      /* Premium Holographic Text Gradient */
      --gradient-logo: linear-gradient(135deg, #A855F7 0%, #3B82F6 100%);
    }

    /* RESET & TYPOGRAPHY */
    * { 
      margin: 0; 
      padding: 0; 
      box-sizing: border-box; 
      -webkit-tap-highlight-color: transparent; 
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    /* LAYOUT */
    .container {
      position: relative;
      z-index: 2;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0; /* Perfectly balanced padding */
    }

    /* ✦ HEADER GLASS ✦ */
    .header {
      width: 100%;
      background: var(--header-bg);
      backdrop-filter: blur(20px); /* Increased blur for higher-end frosted glass look */
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--header-border);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    /* ✦ MULTI-COLOR AURORA GLOW ✦ */
    .header::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      
      width: 100vw; 
      max-width: 800px; /* Widened slightly for a softer spread */
      height: 350px; 
      
      /* Blends from Violet to Blue to Transparent for a stunning ambient light */
      background: radial-gradient(
        50% 100% at 50% 0%, 
        rgba(139, 92, 246, 0.22) 0%,   /* Violet Core */
        rgba(59, 130, 246, 0.08) 45%,  /* Blue Mid-tone */
        transparent 100%               /* Flawless fade out */
      );
      
      z-index: -1;
      pointer-events: none;
    }

    /* ✦ LOGO STYLING ✦ */
    .header-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      height: 40px; /* Slightly refined height */
      margin-left: -12px; /* Pulled slightly left as requested */
      transition: opacity 0.2s ease;
    }
    .header-logo:hover {
      opacity: 0.85; /* Premium hover effect */
    }
    .header-logo img {
      height: 100%;
      width: auto; /* Ensures image isn't warped */
      object-fit: contain;
      filter: drop-shadow(0 4px 12px rgba(139, 92, 246, 0.3)); /* Adds a subtle glow behind image logos */
    }
    
    /* Icon Fallback Styling */
    .header-alticon {
      font-size: 1.6rem; 
      color: var(--accent-violet);
      filter: drop-shadow(0 2px 8px rgba(139, 92, 246, 0.5)); /* Glowing icon */
    }
    
    /* Text Fallback Styling */
    .header-alttext {
      font-size: 1.7rem; 
      font-weight: 800;
      background: var(--gradient-logo);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <div class="container">
      <nav class="navbar">
        <div class="header-logo" id="header-logo-container">
          <% if (header.logourl && header.logourl !== "") { %>
            <img 
              src="<%= header.logourl %>" 
              alt="Logo" 
              id="header-logo-img"
              onerror="this.onerror=null; fallbackToIconMode()"
            >
          <% } else { %>
            <% if (header.alticon && header.alticon !== "") { %>
              <i class="<%= header.alticon %> header-alticon" id="header-alticon"></i>
            <% } %>
            <% if (header.alttext && header.alttext !== "") { %>
              <span class="header-alttext" id="header-alttext"><%= header.alttext %></span>
            <% } %>
          <% } %>
        </div>
      </nav>
    </div>
  </header>

  <script>
    /* HEADER LOGO FALLBACK */
    function fallbackToIconMode() {
      const container = document.getElementById('header-logo-container');
      if (!container) return;
      
      const alticon = '<%= header.alticon && header.alticon !== "" ? header.alticon : "" %>';
      const alttext = '<%= header.alttext && header.alttext !== "" ? header.alttext : "" %>';
      
      const iconHtml = alticon !== "" ? `<i class="${alticon} header-alticon"></i>` : "";
      const textHtml = alttext !== "" ? `<span class="header-alttext">${alttext}</span>` : "";
      
      container.innerHTML = iconHtml + textHtml;
    }
  </script>

</body>
</html>
