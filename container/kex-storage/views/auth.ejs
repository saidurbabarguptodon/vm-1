<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeronotics | Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg: #08090a;
            --card: #121417;
            --emerald: #10b981;
            --text: #ffffff;
            --muted: #94a3b8;
            --border: rgba(255, 255, 255, 0.08);
        }
        body { background: var(--bg); color: var(--text); font-family: 'Plus Jakarta Sans', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .auth-card { 
            background: var(--card); 
            border: 1px solid var(--border); 
            padding: 45px; 
            border-radius: 28px; 
            width: 100%; 
            max-width: 420px;
            box-shadow: 0 30px 60px -12px rgba(0,0,0,0.5);
        }
        .brand { color: var(--emerald); font-size: 1.8rem; font-weight: 800; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 30px; }
        .form-control { 
            background: #1a1d21; 
            border: 1px solid var(--border); 
            color: #fff; 
            padding: 14px; 
            border-radius: 12px; 
            margin-bottom: 15px;
        }
        .form-control:focus { background: #1a1d21; color: #fff; border-color: var(--emerald); box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1); }
        .btn-primary { 
            background: var(--emerald); 
            border: none; 
            padding: 14px; 
            border-radius: 12px; 
            font-weight: 700; 
            width: 100%; 
            transition: 0.2s;
        }
        .btn-primary:hover { background: #0ca673; transform: translateY(-1px); }
        .toggle-link { color: var(--emerald); cursor: pointer; font-weight: 700; text-decoration: none; }
        .alert-error { background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #f87171; border-radius: 10px; padding: 10px; font-size: 0.85rem; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="auth-card">
        <a href="#" class="brand"><i class="fas fa-rocket"></i> Aeronotics</a>
        <% if (error) { %><div class="alert-error text-center"><i class="fas fa-circle-exclamation me-2"></i><%= error %></div><% } %>

        <div id="loginArea">
            <h4 class="fw-bold mb-1">Access Console</h4>
            <p class="small text-muted mb-4">Enter your credentials to manage your storage.</p>
            <form action="/auth/login" method="POST">
                <input type="email" name="email" class="form-control" placeholder="Email" required>
                <input type="password" name="password" class="form-control" placeholder="Password" required>
                <button type="submit" class="btn btn-primary mt-2">Sign In</button>
            </form>
            <p class="text-center mt-4 small text-muted">No account? <span class="toggle-link" onclick="toggle()">Create one</span></p>
        </div>

        <div id="signupArea" style="display:none;">
            <h4 class="fw-bold mb-1">Register</h4>
            <p class="small text-muted mb-4">Join Aeronotics Cloud Storage.</p>
            <form action="/auth/signup" method="POST">
                <input type="email" name="email" class="form-control" placeholder="Email" required>
                <input type="password" name="password" class="form-control" placeholder="Password" required>
                <button type="submit" class="btn btn-primary mt-2">Create Account</button>
            </form>
            <p class="text-center mt-4 small text-muted">Have an account? <span class="toggle-link" onclick="toggle()">Sign In</span></p>
        </div>
    </div>
    <script>
        function toggle() {
            const l = document.getElementById('loginArea'), s = document.getElementById('signupArea');
            l.style.display = l.style.display === 'none' ? 'block' : 'none';
            s.style.display = s.style.display === 'none' ? 'block' : 'none';
        }
    </script>
</body>
</html>
