<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kex Storage</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-color: #1a1a1a;
            --sidebar-bg: #121212;
            --input-bg: #262626;
            --text-primary: #ececec;
            --text-secondary: #a0a0a0;
            --emerald: #00A67E;
            --emerald-dark: #008f6b;
            --hover-color: #333;
            --divider-color: rgba(255, 255, 255, 0.08);
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }
        /* Navbar */
        .navbar-top {
            background-color: var(--sidebar-bg);
            border-bottom: 2px solid var(--emerald);
            height: 64px;
        }
        .header-logo-text {
            font-size: 1.3rem;
            color: var(--emerald);
            margin-right: 8px;
            font-weight: bold;
        }
        /* Hamburger sliding from left, button on right */
        .offcanvas-start {
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--divider-color);
            width: 45% !important; /* Fixed at 45% */
            max-width: 400px;
        }
        /* Cards */
        .card {
            background-color: var(--input-bg);
            border: 1px solid var(--divider-color);
            border-radius: 0.5rem;
            color: var(--text-primary);
        }
        /* High contrast Table fix */
        .table-container {
            background-color: var(--input-bg);
            border-radius: 8px;
            border: 1px solid var(--divider-color);
            overflow: hidden;
        }
        .table {
            color: var(--text-primary);
            margin-bottom: 0;
            --bs-table-bg: transparent;
        }
        .table thead th {
            border-bottom: 1px solid var(--divider-color);
            background-color: var(--sidebar-bg);
            color: var(--text-secondary);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            padding: 1rem;
        }
        .table tbody td {
            border-bottom: 1px solid var(--divider-color);
            background-color: var(--input-bg) !important;
            color: var(--text-primary) !important;
            vertical-align: middle;
            padding: 1rem;
        }
        .table tbody tr:last-child td { border-bottom: none; }
        .table tbody tr:hover td {
            background-color: var(--hover-color) !important;
            color: #ffffff !important;
        }
        /* Buttons */
        .btn-primary {
            background-color: var(--emerald);
            border-color: var(--emerald);
            color: #ffffff;
            font-weight: 500;
        }
        .btn-primary:hover {
            background-color: var(--emerald-dark);
            border-color: var(--emerald-dark);
        }
        /* Utilities */
        .text-muted { color: var(--text-secondary) !important; }
        .text-primary { color: var(--emerald) !important; }
        .icon-action {
            color: var(--text-secondary);
            cursor: pointer;
            transition: color 0.2s;
            background: none;
            border: none;
            padding: 0.25rem 0.5rem;
        }
        .icon-action:hover { color: var(--emerald); }
        .icon-action.delete:hover { color: #ef4444; }
        
        .breadcrumb-item a { color: var(--emerald); text-decoration: none; }
        .breadcrumb-item a:hover { text-decoration: underline; }
        .breadcrumb-item.active { color: var(--text-primary); }
        
        /* Sidebar Links */
        .nav-link-custom {
            color: var(--text-secondary);
            transition: all 0.2s;
            border-radius: 8px;
        }
        .nav-link-custom:hover, .nav-link-custom.active {
            color: #ffffff;
            background-color: var(--emerald);
        }
        /* Modals */
        .modal-content {
            border: 1px solid var(--divider-color);
            background-color: var(--sidebar-bg);
            color: var(--text-primary);
        }
        .modal-header { border-bottom: 1px solid var(--divider-color); }
        .modal-footer { border-top: 1px solid var(--divider-color); }
        .form-control {
            background-color: var(--input-bg);
            border: 1px solid var(--divider-color);
            color: var(--text-primary);
        }
        .form-control:focus {
            background-color: var(--input-bg);
            border-color: var(--emerald);
            color: #ffffff;
            box-shadow: 0 0 0 0.25rem rgba(0, 166, 126, 0.25);
        }
        /* Progress bars */
        .toast {
            background-color: var(--sidebar-bg);
            border: 1px solid var(--divider-color);
            color: var(--text-primary);
        }
        .progress-bar { background-color: var(--emerald); }
        .progress-bg { background-color: var(--input-bg); }
    </style>
</head>
<body>

<nav class="navbar navbar-top px-4 d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <h5 class="mb-0 text-light fw-bold"><i class="fas fa-server text-primary me-2"></i> <span class="header-logo-text">Kex Storage</span></h5>
    </div>
    <!-- Hamburger button on the right -->
    <button class="btn btn-outline-secondary border-0 text-light" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
        <i class="fas fa-bars fa-lg"></i>
    </button>
</nav>

<div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarMenu">
    <div class="offcanvas-header border-bottom" style="border-color: var(--divider-color) !important;">
        <h5 class="offcanvas-title fw-bold"><i class="fas fa-server text-primary me-2"></i> Kex Storage</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-3">
        <div class="d-flex flex-column gap-2">
            <a href="/dash" class="text-decoration-none p-3 nav-link-custom <%= page === 'dash' ? 'active' : '' %> d-flex align-items-center">
                <i class="fas fa-tachometer-alt fa-fw me-3"></i> Dash
            </a>
            <a href="/files" class="text-decoration-none p-3 nav-link-custom <%= page === 'files' ? 'active' : '' %> d-flex align-items-center">
                <i class="fas fa-folder-open fa-fw me-3"></i> Files
            </a>
        </div>
    </div>
</div>

<div class="container mt-5">
    <% if (page === 'dash') { %>
        <h4 class="mb-4 fw-bold">System Overview</h4>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card p-4 text-center shadow-sm">
                    <i class="fas fa-hdd fa-3x mb-3 text-primary"></i>
                    <h6 class="text-muted text-uppercase fw-semibold mb-1">Total Storage Used</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.totalSize %></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center shadow-sm">
                    <i class="fas fa-file-alt fa-3x mb-3 text-primary"></i>
                    <h6 class="text-muted text-uppercase fw-semibold mb-1">Total Files</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.fileCount %></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center shadow-sm">
                    <i class="fas fa-folder fa-3x mb-3 text-primary"></i>
                    <h6 class="text-muted text-uppercase fw-semibold mb-1">Total Folders</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.folderCount %></h3>
                </div>
            </div>
        </div>
    <% } else if (page === 'files') { %>
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 fs-5 fw-semibold">
                    <li class="breadcrumb-item"><a href="/files?dir=root">/root</a></li>
                    <% breadcrumbs.forEach(crumb => { %>
                        <li class="breadcrumb-item"><a href="/files?dir=<%= crumb.id %>"><%= crumb.name %></a></li>
                    <% }) %>
                </ol>
            </nav>
            <div class="btn-group">
                <button class="btn btn-primary btn-sm px-3" data-bs-toggle="modal" data-bs-target="#folderModal">
                    <i class="fas fa-folder-plus me-1"></i> New Folder
                </button>
                <button class="btn btn-primary btn-sm px-3" data-bs-toggle="modal" data-bs-target="#fileModal">
                    <i class="fas fa-file-signature me-1"></i> New File
                </button>
                <button class="btn btn-primary btn-sm px-3" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-upload me-1"></i> Upload
                </button>
            </div>
        </div>

        <div class="table-container shadow-sm">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 50%;">Name</th>
                            <th style="width: 15%;">Size</th>
                            <th style="width: 15%;">Type</th>
                            <th style="width: 20%;" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (parentId !== 'root') { %>
                        <tr>
                            <td colspan="4">
                                <a href="javascript:history.back()" class="text-decoration-none text-light d-flex align-items-center fw-medium">
                                    <i class="fas fa-level-up-alt fa-rotate-270 me-3 text-muted"></i> ...
                                </a>
                            </td>
                        </tr>
                        <% } %>

                        <% items.forEach(item => { %>
                        <tr>
                            <td>
                                <% if (item.type === 'folder') { %>
                                    <a href="/files?dir=<%= item.id %>" class="text-decoration-none text-light d-flex align-items-center fw-medium">
                                        <i class="fas fa-folder me-3 text-primary"></i> <%= item.name %>
                                    </a>
                                <% } else { %>
                                    <div class="d-flex align-items-center fw-medium text-light">
                                        <i class="fas <%= item.name.endsWith('.zip') ? 'fa-file-archive text-warning' : 'fa-file-alt text-muted' %> me-3"></i> <%= item.name %>
                                    </div>
                                <% } %>
                            </td>
                            <td class="text-muted"><%= item.type === 'folder' ? '-' : formatBytes(item.size) %></td>
                            <td class="text-muted"><%= item.type === 'folder' ? 'Directory' : 'File' %></td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end align-items-center">
                                    <% if (item.type === 'folder') { %>
                                        <form action="/zip/<%= item.id %>" method="POST" class="m-0 p-0 me-1">
                                            <button type="submit" class="icon-action" title="Archive Folder"><i class="fas fa-file-archive"></i></button>
                                        </form>
                                    <% } else { %>
                                        <button class="icon-action me-1" onclick="downloadFile('<%= item.id %>', '<%= item.name %>')" title="Download">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <% if (item.name.endsWith('.zip')) { %>
                                            <form action="/unzip/<%= item.id %>" method="POST" class="m-0 p-0 me-1">
                                                <button type="submit" class="icon-action" title="Unarchive"><i class="fas fa-box-open"></i></button>
                                            </form>
                                        <% } %>
                                    <% } %>
                                    <form action="/delete/<%= item.id %>" method="POST" class="m-0 p-0">
                                        <button type="submit" class="icon-action delete" title="Delete Permanent"><i class="fas fa-trash-alt"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>

                        <% if (items.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                This directory is empty.
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    <% } %>
</div>

<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form id="uploadForm" class="modal-content">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title text-light">Upload File</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="parentId" value="<%= typeof parentId !== 'undefined' ? parentId : 'root' %>">
                <input type="file" name="file" class="form-control" required>
                
                <div id="uploadProgressUI" class="mt-3" style="display: none;">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small text-light">Uploading to Telegram...</span>
                        <span id="uploadETA" class="small text-muted" style="color: var(--emerald) !important;">0%</span>
                    </div>
                    <div class="progress progress-bg" style="height: 10px;">
                        <div id="uploadProgressBar" class="progress-bar" style="width: 0%;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="submit" id="uploadSubmitBtn" class="btn btn-primary px-4">Upload</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="folderModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/create-folder" method="POST" class="modal-content">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title text-light">Create Directory</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="parentId" value="<%= typeof parentId !== 'undefined' ? parentId : 'root' %>">
                <input type="text" name="name" class="form-control" placeholder="Directory Name" required>
            </div>
            <div class="modal-footer border-top-0">
                <button type="submit" class="btn btn-primary px-4">Create</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="fileModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <form action="/create-file" method="POST" class="modal-content">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title text-light">Create File</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="parentId" value="<%= typeof parentId !== 'undefined' ? parentId : 'root' %>">
                <input type="text" name="name" class="form-control mb-3" placeholder="filename.txt" required>
                <textarea name="content" class="form-control" rows="8" placeholder="Enter file contents here..." style="font-family: monospace;"></textarea>
            </div>
            <div class="modal-footer border-top-0">
                <button type="submit" class="btn btn-primary px-4">Create File</button>
            </div>
        </form>
    </div>
</div>

<!-- Floating Download Progress UI -->
<div id="downloadProgressContainer" class="position-fixed bottom-0 end-0 p-4" style="z-index: 1100; display: none;">
    <div class="toast show border-0 shadow" style="background-color: var(--sidebar-bg); width: 300px;">
        <div class="toast-body p-3">
            <div class="mb-2 fw-semibold text-light" id="downloadFileName">Downloading...</div>
            <div class="progress progress-bg" style="height: 8px;">
                <div id="downloadProgressBar" class="progress-bar" style="width: 0%"></div>
            </div>
            <div id="downloadProgressText" class="mt-2 text-muted small" style="color: var(--emerald) !important;">0% - ETA: Calculating...</div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Format seconds into a readable ETA
    function formatTime(seconds) {
        if (!Number.isFinite(seconds) || seconds < 0) return 'Calculating...';
        if (seconds < 60) return Math.round(seconds) + 's';
        return Math.floor(seconds/60) + 'm ' + Math.round(seconds%60) + 's';
    }

    // Upload with progress and ETA
    const uploadForm = document.getElementById('uploadForm');
    if (uploadForm) {
        uploadForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const xhr = new XMLHttpRequest();
            
            document.getElementById('uploadSubmitBtn').style.display = 'none';
            document.getElementById('uploadProgressUI').style.display = 'block';
            
            let startTime = Date.now();
            xhr.upload.addEventListener("progress", (evt) => {
                if (evt.lengthComputable) {
                    let percentComplete = (evt.loaded / evt.total) * 100;
                    document.getElementById('uploadProgressBar').style.width = percentComplete + '%';
                    
                    let timeElapsed = (Date.now() - startTime) / 1000;
                    let speed = evt.loaded / timeElapsed;
                    let timeRemaining = (evt.total - evt.loaded) / speed;
                    
                    document.getElementById('uploadETA').innerText = `${Math.round(percentComplete)}% - ETA: ${formatTime(timeRemaining)}`;
                }
            });

            xhr.addEventListener("load", () => window.location.reload());
            xhr.open("POST", "/upload");
            xhr.send(formData);
        });
    }

    // Download with fast backend stream tracking
    function downloadFile(id, fileName) {
        document.getElementById('downloadProgressContainer').style.display = 'block';
        document.getElementById('downloadFileName').innerText = 'Downloading ' + fileName;
        document.getElementById('downloadProgressBar').style.width = '0%';
        document.getElementById('downloadProgressText').innerText = 'Starting...';
        
        const xhr = new XMLHttpRequest();
        xhr.open('GET', '/download/' + id, true);
        xhr.responseType = 'blob'; // Storing in RAM temporarily to show progress
        let startTime = Date.now();

        xhr.addEventListener('progress', function(evt) {
            if (evt.lengthComputable) {
                let percentComplete = (evt.loaded / evt.total) * 100;
                document.getElementById('downloadProgressBar').style.width = percentComplete + '%';
                
                let timeElapsed = (Date.now() - startTime) / 1000;
                let speed = evt.loaded / timeElapsed;
                let timeRemaining = (evt.total - evt.loaded) / speed;
                
                document.getElementById('downloadProgressText').innerText = 
                    `${Math.round(percentComplete)}% - ETA: ${formatTime(timeRemaining)}`;
            } else {
                document.getElementById('downloadProgressText').innerText = 'Downloading... (Processing Fast Stream)';
            }
        });

        xhr.addEventListener('load', function() {
            if (xhr.status === 200) {
                // Trigger auto-download to user device once Blob stream is fully received
                const blob = xhr.response;
                const link = document.createElement('a');
                link.href = window.URL.createObjectURL(blob);
                link.download = fileName;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                
                document.getElementById('downloadProgressText').innerText = 'Complete!';
                setTimeout(() => {
                    document.getElementById('downloadProgressContainer').style.display = 'none';
                }, 2000);
            }
        });
        xhr.send();
    }
</script>
</body>
</html>
