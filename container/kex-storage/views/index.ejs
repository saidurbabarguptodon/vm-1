<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cloud Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #0f172a;
            color: #e2e8f0;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }
        .navbar-top {
            background-color: #1e293b;
            border-bottom: 1px solid #334155;
            height: 64px;
        }
        .offcanvas-start {
            background-color: #1e293b;
            border-right: 1px solid #334155;
            width: 280px;
        }
        .card {
            background-color: #1e293b;
            border: 1px solid #334155;
            border-radius: 0.5rem;
        }
        .table {
            color: #e2e8f0;
            margin-bottom: 0;
        }
        .table thead th {
            border-bottom: 1px solid #334155;
            color: #94a3b8;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            padding: 1rem;
        }
        .table tbody td {
            border-bottom: 1px solid #334155;
            vertical-align: middle;
            padding: 1rem;
        }
        .table tbody tr:last-child td {
            border-bottom: none;
        }
        .table tbody tr:hover td {
            background-color: #334155;
            color: #f8fafc;
        }
        .btn-primary {
            background-color: #3b82f6;
            border: none;
        }
        .btn-primary:hover {
            background-color: #2563eb;
        }
        .text-muted {
            color: #94a3b8 !important;
        }
        .icon-action {
            color: #94a3b8;
            cursor: pointer;
            transition: color 0.2s;
            background: none;
            border: none;
            padding: 0.25rem 0.5rem;
        }
        .icon-action:hover {
            color: #e2e8f0;
        }
        .icon-action.delete:hover {
            color: #ef4444;
        }
        .breadcrumb-item a {
            color: #3b82f6;
            text-decoration: none;
        }
        .breadcrumb-item a:hover {
            text-decoration: underline;
        }
        .breadcrumb-item.active {
            color: #e2e8f0;
        }
        .nav-link-custom {
            color: #cbd5e1;
            transition: all 0.2s;
        }
        .nav-link-custom:hover, .nav-link-custom.active {
            color: #f8fafc;
            background-color: #334155;
            border-radius: 0.375rem;
        }
        .modal-content {
            border: 1px solid #334155;
        }
        .form-control {
            background-color: #0f172a;
            border: 1px solid #334155;
            color: #e2e8f0;
        }
        .form-control:focus {
            background-color: #0f172a;
            border-color: #3b82f6;
            color: #f8fafc;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
        }
    </style>
</head>
<body>

<nav class="navbar navbar-top px-4 d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <h5 class="mb-0 text-light fw-bold"><i class="fas fa-server text-primary me-2"></i> PteroCloud</h5>
    </div>
    <button class="btn btn-outline-secondary border-0 text-light" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
        <i class="fas fa-bars fa-lg"></i>
    </button>
</nav>

<div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarMenu" data-bs-theme="dark">
    <div class="offcanvas-header border-bottom" style="border-color: #334155 !important;">
        <h5 class="offcanvas-title fw-bold"><i class="fas fa-server text-primary me-2"></i> PteroCloud</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-3">
        <div class="d-flex flex-column gap-2">
            <a href="#" onclick="switchTab('dashboard')" class="text-decoration-none p-3 nav-link-custom d-flex align-items-center" data-bs-dismiss="offcanvas">
                <i class="fas fa-tachometer-alt fa-fw me-3"></i> Dashboard
            </a>
            <a href="#" onclick="switchTab('storage')" class="text-decoration-none p-3 nav-link-custom d-flex align-items-center" data-bs-dismiss="offcanvas">
                <i class="fas fa-folder-open fa-fw me-3"></i> Storage
            </a>
        </div>
    </div>
</div>

<div class="container mt-5">
    
    <div id="dashboard-view" style="display: none;">
        <h4 class="mb-4 fw-bold">System Overview</h4>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card p-4 text-center shadow-sm">
                    <i class="fas fa-hdd fa-3x mb-3 text-primary"></i>
                    <h6 class="text-muted text-uppercase fw-semibold mb-1">Total Storage Used</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.totalSize %></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center shadow-sm">
                    <i class="fas fa-file-alt fa-3x mb-3 text-success"></i>
                    <h6 class="text-muted text-uppercase fw-semibold mb-1">Total Files</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.fileCount %></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center shadow-sm">
                    <i class="fas fa-folder fa-3x mb-3 text-warning"></i>
                    <h6 class="text-muted text-uppercase fw-semibold mb-1">Total Folders</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.folderCount %></h3>
                </div>
            </div>
        </div>
    </div>

    <div id="storage-view" style="display: none;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 fs-5 fw-semibold">
                    <li class="breadcrumb-item"><a href="/?dir=root">/root</a></li>
                    <% breadcrumbs.forEach(crumb => { %>
                        <li class="breadcrumb-item"><a href="/?dir=<%= crumb.id %>"><%= crumb.name %></a></li>
                    <% }) %>
                </ol>
            </nav>
            <div class="btn-group">
                <button class="btn btn-primary btn-sm px-3" data-bs-toggle="modal" data-bs-target="#folderModal">
                    <i class="fas fa-folder-plus me-1"></i> New Folder
                </button>
                <button class="btn btn-primary btn-sm px-3" data-bs-toggle="modal" data-bs-target="#fileModal">
                    <i class="fas fa-file-signature me-1"></i> New File
                </button>
                <button class="btn btn-primary btn-sm px-3" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-upload me-1"></i> Upload
                </button>
            </div>
        </div>

        <div class="card shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width: 50%;">Name</th>
                            <th style="width: 15%;">Size</th>
                            <th style="width: 15%;">Type</th>
                            <th style="width: 20%;" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (parentId !== 'root') { %>
                        <tr>
                            <td colspan="4">
                                <a href="javascript:history.back()" class="text-decoration-none text-light d-flex align-items-center fw-medium">
                                    <i class="fas fa-level-up-alt fa-rotate-270 me-3 text-muted"></i> ...
                                </a>
                            </td>
                        </tr>
                        <% } %>

                        <% items.forEach(item => { %>
                        <tr>
                            <td>
                                <% if (item.type === 'folder') { %>
                                    <a href="/?dir=<%= item.id %>" class="text-decoration-none text-light d-flex align-items-center fw-medium">
                                        <i class="fas fa-folder me-3" style="color: #60a5fa;"></i> <%= item.name %>
                                    </a>
                                <% } else { %>
                                    <div class="d-flex align-items-center fw-medium text-light">
                                        <i class="fas <%= item.name.endsWith('.zip') ? 'fa-file-archive text-warning' : 'fa-file-alt text-secondary' %> me-3"></i> <%= item.name %>
                                    </div>
                                <% } %>
                            </td>
                            <td class="text-muted"><%= item.type === 'folder' ? '-' : formatBytes(item.size) %></td>
                            <td class="text-muted"><%= item.type === 'folder' ? 'Directory' : 'File' %></td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end align-items-center">
                                    <% if (item.type === 'folder') { %>
                                        <form action="/zip/<%= item.id %>" method="POST" class="m-0 p-0 me-1">
                                            <button type="submit" class="icon-action" title="Archive"><i class="fas fa-file-archive"></i></button>
                                        </form>
                                    <% } else { %>
                                        <a href="/download/<%= item.id %>" class="icon-action text-decoration-none me-1" title="Download"><i class="fas fa-download"></i></a>
                                        <% if (item.name.endsWith('.zip')) { %>
                                            <form action="/unzip/<%= item.id %>" method="POST" class="m-0 p-0 me-1">
                                                <button type="submit" class="icon-action" title="Unarchive"><i class="fas fa-box-open"></i></button>
                                            </form>
                                        <% } %>
                                    <% } %>
                                    <form action="/delete/<%= item.id %>" method="POST" class="m-0 p-0">
                                        <button type="submit" class="icon-action delete" title="Delete"><i class="fas fa-trash-alt"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>

                        <% if (items.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                This directory is empty.
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="uploadModal" tabindex="-1" data-bs-theme="dark">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/upload" method="POST" enctype="multipart/form-data" class="modal-content" style="background-color: #1e293b;">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title">Upload File</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="parentId" value="<%= parentId %>">
                <input type="file" name="file" class="form-control" required>
            </div>
            <div class="modal-footer border-top-0">
                <button type="submit" class="btn btn-primary px-4">Upload</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="folderModal" tabindex="-1" data-bs-theme="dark">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/create-folder" method="POST" class="modal-content" style="background-color: #1e293b;">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title">Create Directory</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="parentId" value="<%= parentId %>">
                <input type="text" name="name" class="form-control" placeholder="Directory Name" required>
            </div>
            <div class="modal-footer border-top-0">
                <button type="submit" class="btn btn-primary px-4">Create</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="fileModal" tabindex="-1" data-bs-theme="dark">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <form action="/create-file" method="POST" class="modal-content" style="background-color: #1e293b;">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title">Create File</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="parentId" value="<%= parentId %>">
                <input type="text" name="name" class="form-control mb-3" placeholder="filename.txt" required>
                <textarea name="content" class="form-control" rows="8" placeholder="Enter file contents here..." style="font-family: monospace;"></textarea>
            </div>
            <div class="modal-footer border-top-0">
                <button type="submit" class="btn btn-primary px-4">Create File</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function switchTab(tabId) {
        document.getElementById('dashboard-view').style.display = tabId === 'dashboard' ? 'block' : 'none';
        document.getElementById('storage-view').style.display = tabId === 'storage' ? 'block' : 'none';
        
        const url = new URL(window.location);
        if (tabId === 'dashboard') {
            url.searchParams.delete('dir');
        } else if (!url.searchParams.has('dir')) {
            url.searchParams.set('dir', 'root');
        }
        window.history.replaceState({}, '', url);
    }

    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('dir')) {
            switchTab('storage');
        } else {
            switchTab('dashboard');
        }
    });
</script>

</body>
</html>
