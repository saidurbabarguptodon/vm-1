<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kex Storage | Cloud Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-dark: #0b0d0f;
            --card-bg: #16191d;
            --sidebar-bg: #0f1216;
            --input-bg: #1e2329;
            --text-main: #ffffff;
            --text-muted: #cbd5e1; /* Much lighter for better contrast */
            --emerald: #10b981;
            --emerald-glow: rgba(16, 185, 129, 0.2);
            --border-color: rgba(255, 255, 255, 0.1);
            --transition: all 0.2s ease;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
        }

        /* Navbar */
        .navbar-top {
            background-color: rgba(15, 18, 22, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
            height: 70px;
            padding: 0 1.5rem;
        }

        .brand-logo {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--emerald);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Sidebar - Sliding from LEFT */
        .offcanvas-start {
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            width: 280px !important;
        }

        .nav-link-custom {
            color: var(--text-muted);
            padding: 12px 16px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            transition: var(--transition);
            margin-bottom: 5px;
            font-weight: 500;
        }

        .nav-link-custom:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }

        .nav-link-custom.active {
            background: var(--emerald);
            color: #fff;
        }

        /* Stats Cards */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 24px;
            height: 100%;
        }

        /* FIX: Contrast for the small labels */
        .stat-label {
            color: var(--text-muted); 
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            font-weight: 700;
            margin-bottom: 8px;
            display: block;
        }

        .stat-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: #fff;
        }

        .icon-box {
            width: 48px;
            height: 48px;
            background: rgba(16, 185, 129, 0.1);
            color: var(--emerald);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            margin-bottom: 20px;
        }

        /* Table Design */
        .table-container {
            background: var(--card-bg);
            border-radius: 16px;
            border: 1px solid var(--border-color);
            overflow: hidden;
            margin-top: 20px;
        }

        .table { margin-bottom: 0; color: var(--text-main); }
        .table thead th {
            background: rgba(255, 255, 255, 0.03);
            color: var(--text-muted);
            font-size: 0.7rem;
            text-transform: uppercase;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .table tbody td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            background: transparent !important;
            color: #fff !important;
        }

        .table tbody tr:hover td {
            background: rgba(255, 255, 255, 0.02) !important;
        }

        /* Action Buttons */
        .btn-action {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            background: var(--input-bg);
            color: var(--text-muted);
            border: 1px solid var(--border-color);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
        }

        .btn-action:hover {
            background: var(--emerald);
            color: white;
            border-color: var(--emerald);
        }

        /* Breadcrumbs */
        .breadcrumb-item a { color: var(--emerald); text-decoration: none; font-weight: 600; }
        .breadcrumb-item.active { color: var(--text-muted); }
        .breadcrumb-item + .breadcrumb-item::before { color: rgba(255,255,255,0.2); content: "›"; font-size: 1.2rem; line-height: 1; }

        /* Empty State */
        .empty-ghost {
            opacity: 0.2; /* Increased from previous version */
            filter: grayscale(1) brightness(2);
        }
    </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-top d-flex justify-content-between align-items-center">
    <a href="/dash" class="brand-logo">
        <i class="fas fa-box-open"></i> Kex Storage
    </a>
    
    <!-- Hamburger button stays on the RIGHT -->
    <button class="btn-action border-0" style="background: transparent;" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
        <i class="fas fa-bars fa-lg"></i>
    </button>
</nav>

<!-- Sidebar slides from the LEFT -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarMenu">
    <div class="offcanvas-header border-bottom border-secondary">
        <h5 class="offcanvas-title fw-bold text-white"><i class="fas fa-folder-tree me-2 text-emerald"></i>Explorer</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-3">
        <a href="/dash" class="nav-link-custom <%= page === 'dash' ? 'active' : '' %>">
            <i class="fas fa-th-large"></i> Dashboard
        </a>
        <a href="/files" class="nav-link-custom <%= page === 'files' ? 'active' : '' %>">
            <i class="fas fa-hdd"></i> My Files
        </a>
    </div>
</div>

<div class="container py-4 py-md-5">
    <% if (page === 'dash') { %>
        <div class="mb-4">
            <h2 class="fw-bold mb-1">System Overview</h2>
            <p style="color: var(--text-muted)">Real-time storage analytics and status.</p>
        </div>
        
        <div class="row g-3">
            <div class="col-12 col-md-4">
                <div class="stat-card">
                    <div class="icon-box"><i class="fas fa-database"></i></div>
                    <span class="stat-label">Capacity Used</span>
                    <div class="stat-value"><%= stats.totalSize %></div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card">
                    <div class="icon-box"><i class="fas fa-file-alt"></i></div>
                    <span class="stat-label">Total Files</span>
                    <div class="stat-value"><%= stats.fileCount %></div>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <div class="stat-card">
                    <div class="icon-box"><i class="fas fa-folder"></i></div>
                    <span class="stat-label">Total Folders</span>
                    <div class="stat-value"><%= stats.folderCount %></div>
                </div>
            </div>
        </div>

    <% } else if (page === 'files') { %>
        
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-end mb-4 gap-3">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a href="/files?dir=root">Root</a></li>
                        <% breadcrumbs.forEach(crumb => { %>
                            <li class="breadcrumb-item"><a href="/files?dir=<%= crumb.id %>"><%= crumb.name %></a></li>
                        <% }) %>
                    </ol>
                </nav>
                <h3 class="fw-bold m-0">Files</h3>
            </div>
            
            <div class="d-flex gap-2 w-100 w-md-auto">
                <button class="btn btn-success bg-emerald border-0 flex-grow-1 px-4 fw-600" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-cloud-upload-alt me-2"></i> Upload
                </button>
                <button class="btn btn-dark border-secondary" data-bs-toggle="modal" data-bs-target="#folderModal">
                    <i class="fas fa-plus"></i>
                </button>
            </div>
        </div>

        <div class="table-container shadow-lg">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Size</th>
                            <th class="d-none d-md-table-cell">Type</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (parentId !== 'root') { %>
                        <tr>
                            <td colspan="4">
                                <a href="/files?dir=<%= parentFolderId || 'root' %>" class="text-decoration-none d-flex align-items-center" style="color: var(--text-muted)">
                                    <i class="fas fa-level-up-alt fa-rotate-270 me-3"></i> Parent Directory
                                </a>
                            </td>
                        </tr>
                        <% } %>

                        <% items.forEach(item => { %>
                        <tr>
                            <td>
                                <% if (item.type === 'folder') { %>
                                    <a href="/files?dir=<%= item.id %>" class="text-decoration-none text-white d-flex align-items-center fw-semibold">
                                        <i class="fas fa-folder me-3 text-emerald"></i> <%= item.name %>
                                    </a>
                                <% } else { %>
                                    <div class="d-flex align-items-center">
                                        <i class="fas <%= item.name.endsWith('.zip') ? 'fa-file-archive text-warning' : 'fa-file' %> me-3 opacity-50"></i> 
                                        <span><%= item.name %></span>
                                    </div>
                                <% } %>
                            </td>
                            <td style="color: var(--text-muted); font-size: 0.85rem;"><%= item.type === 'folder' ? '--' : formatBytes(item.size) %></td>
                            <td class="d-none d-md-table-cell text-muted"><%= item.type === 'folder' ? 'Folder' : 'File' %></td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1">
                                    <% if (item.type !== 'folder') { %>
                                        <button class="btn-action" onclick="downloadFile('<%= item.id %>', '<%= item.name %>')">
                                            <i class="fas fa-download"></i>
                                        </button>
                                    <% } %>
                                    <form action="/delete/<%= item.id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete permanently?')">
                                        <button type="submit" class="btn-action"><i class="fas fa-trash-alt"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>

                        <% if (items.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="fas fa-ghost fa-3x mb-3 empty-ghost"></i>
                                <p class="text-muted mb-0">This folder is empty</p>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    <% } %>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form id="uploadForm" class="modal-content border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Upload Files</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="parentId" value="<%= typeof parentId !== 'undefined' ? parentId : 'root' %>">
                <div class="p-4 border border-secondary border-dashed rounded-4 text-center mb-3">
                    <i class="fas fa-file-upload fa-2x text-emerald mb-3"></i>
                    <input type="file" name="file" class="form-control bg-dark border-secondary text-white" required>
                </div>
                
                <div id="uploadProgressUI" style="display: none;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small text-muted">Uploading...</span>
                        <span id="uploadETA" class="small text-emerald fw-bold">0%</span>
                    </div>
                    <div class="progress" style="height: 6px; background: #222;">
                        <div id="uploadProgressBar" class="progress-bar bg-emerald" style="width: 0%;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="submit" id="uploadSubmitBtn" class="btn btn-success bg-emerald w-100 py-2 fw-bold border-0">Start Upload</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Improved Upload Script with dynamic progress
    const uploadForm = document.getElementById('uploadForm');
    if (uploadForm) {
        uploadForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const xhr = new XMLHttpRequest();
            
            document.getElementById('uploadSubmitBtn').disabled = true;
            document.getElementById('uploadProgressUI').style.display = 'block';
            
            xhr.upload.addEventListener("progress", (evt) => {
                if (evt.lengthComputable) {
                    let percent = Math.round((evt.loaded / evt.total) * 100);
                    document.getElementById('uploadProgressBar').style.width = percent + '%';
                    document.getElementById('uploadETA').innerText = percent + '%';
                }
            });

            xhr.onload = () => window.location.reload();
            xhr.open("POST", "/upload");
            xhr.send(formData);
        });
    }

    // Dummy download function (Connect to your backend)
    function downloadFile(id, name) {
        window.location.href = `/download/${id}`;
    }
</script>
</body>
</html>
