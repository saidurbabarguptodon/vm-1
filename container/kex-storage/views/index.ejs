<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PteroCloud VFS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        [x-cloak] { display: none !important; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4b5563; }
    </style>
</head>
<body class="bg-gray-900 text-gray-400 font-sans antialiased" x-data="{ sidebarOpen: false, tab: new URLSearchParams(window.location.search).get('tab') || 'storage', folderModal: false, fileModal: false, uploadModal: false }">

    <header class="bg-gray-800 border-b border-gray-700 flex justify-between items-center px-6 py-4">
        <div class="flex items-center space-x-6">
            <h1 class="text-xl font-bold text-gray-100 flex items-center"><i class="fa-solid fa-server text-blue-500 mr-3"></i> PteroVFS</h1>
            <nav class="hidden md:flex space-x-6">
                <button @click="tab = 'dashboard'" :class="tab === 'dashboard' ? 'text-gray-100 border-b-2 border-blue-500' : 'hover:text-gray-100'" class="pb-1 text-sm font-medium transition">Dashboard</button>
                <button @click="tab = 'storage'" :class="tab === 'storage' ? 'text-gray-100 border-b-2 border-blue-500' : 'hover:text-gray-100'" class="pb-1 text-sm font-medium transition">Storage</button>
            </nav>
        </div>
        <button @click="sidebarOpen = true" class="text-gray-400 text-2xl hover:text-gray-100 transition">
            <i class="fa-solid fa-bars"></i>
        </button>
    </header>

    <div x-show="sidebarOpen" class="fixed inset-0 z-50 flex" x-cloak>
        <div x-show="sidebarOpen" x-transition.opacity class="fixed inset-0 bg-black bg-opacity-60" @click="sidebarOpen = false"></div>
        <div x-show="sidebarOpen" 
             x-transition:enter="transition ease-out duration-300" 
             x-transition:enter-start="-translate-x-full" 
             x-transition:enter-end="translate-x-0" 
             x-transition:leave="transition ease-in duration-300" 
             x-transition:leave-start="translate-x-0" 
             x-transition:leave-end="-translate-x-full" 
             class="relative w-64 bg-gray-800 h-full shadow-2xl flex flex-col border-r border-gray-700">
            <div class="p-6 border-b border-gray-700 flex justify-between items-center">
                <h2 class="text-lg font-bold text-gray-100"><i class="fa-solid fa-server text-blue-500 mr-2"></i> Menu</h2>
                <button @click="sidebarOpen = false" class="text-gray-400 hover:text-white transition"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="p-4 flex flex-col space-y-2">
                <button @click="tab = 'dashboard'; sidebarOpen = false" :class="tab === 'dashboard' ? 'bg-gray-700 text-white' : 'text-gray-300'" class="text-left px-4 py-2 rounded hover:bg-gray-700 hover:text-white transition text-sm font-medium"><i class="fa-solid fa-chart-pie w-6"></i> Dashboard</button>
                <button @click="tab = 'storage'; sidebarOpen = false" :class="tab === 'storage' ? 'bg-gray-700 text-white' : 'text-gray-300'" class="text-left px-4 py-2 rounded hover:bg-gray-700 hover:text-white transition text-sm font-medium"><i class="fa-solid fa-folder-open w-6"></i> Storage</button>
            </div>
        </div>
    </div>

    <main class="p-6 max-w-7xl mx-auto">
        <div x-show="tab === 'dashboard'" x-transition x-cloak>
            <h2 class="text-2xl font-bold text-gray-100 mb-6">Dashboard</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-gray-800 border border-gray-700 rounded-lg p-6 shadow-sm flex items-center space-x-5">
                    <div class="p-4 bg-blue-500 bg-opacity-10 text-blue-500 rounded-lg text-2xl"><i class="fa-solid fa-hard-drive"></i></div>
                    <div>
                        <p class="text-xs text-gray-400 uppercase tracking-wider font-bold mb-1">Total Storage Used</p>
                        <p class="text-2xl font-bold text-gray-100"><%= formatBytes(totalSize) %></p>
                    </div>
                </div>
                <div class="bg-gray-800 border border-gray-700 rounded-lg p-6 shadow-sm flex items-center space-x-5">
                    <div class="p-4 bg-green-500 bg-opacity-10 text-green-500 rounded-lg text-2xl"><i class="fa-regular fa-file"></i></div>
                    <div>
                        <p class="text-xs text-gray-400 uppercase tracking-wider font-bold mb-1">Total Files</p>
                        <p class="text-2xl font-bold text-gray-100"><%= totalFiles %></p>
                    </div>
                </div>
                <div class="bg-gray-800 border border-gray-700 rounded-lg p-6 shadow-sm flex items-center space-x-5">
                    <div class="p-4 bg-yellow-500 bg-opacity-10 text-yellow-500 rounded-lg text-2xl"><i class="fa-regular fa-folder"></i></div>
                    <div>
                        <p class="text-xs text-gray-400 uppercase tracking-wider font-bold mb-1">Total Folders</p>
                        <p class="text-2xl font-bold text-gray-100"><%= totalFolders %></p>
                    </div>
                </div>
            </div>
        </div>

        <div x-show="tab === 'storage'" x-transition x-cloak>
            <div class="flex flex-col md:flex-row justify-between items-center mb-4 space-y-4 md:space-y-0">
                <div class="flex items-center space-x-2 text-sm text-gray-300 bg-gray-800 px-4 py-2 rounded-lg border border-gray-700 shadow-sm w-full md:w-auto overflow-x-auto">
                    <a href="/?dir=root&tab=storage" class="hover:text-gray-100 transition font-semibold whitespace-nowrap"><i class="fa-solid fa-server mr-1"></i> / home / container</a>
                    <% breadcrumbs.forEach(crumb => { %>
                        <span class="text-gray-600">/</span>
                        <a href="/?dir=<%= crumb.id %>&tab=storage" class="hover:text-gray-100 transition font-semibold whitespace-nowrap"><%= crumb.name %></a>
                    <% }) %>
                </div>

                <div class="flex space-x-2 w-full md:w-auto justify-end">
                    <button @click="folderModal = true" class="bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-200 px-4 py-2 rounded shadow-sm text-sm font-semibold transition whitespace-nowrap">
                        Create Directory
                    </button>
                    <button @click="fileModal = true" class="bg-gray-800 border border-gray-700 hover:bg-gray-700 text-gray-200 px-4 py-2 rounded shadow-sm text-sm font-semibold transition whitespace-nowrap">
                        New File
                    </button>
                    <button @click="uploadModal = true" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded shadow-sm text-sm font-semibold transition whitespace-nowrap">
                        Upload File
                    </button>
                </div>
            </div>

            <div class="bg-gray-800 border border-gray-700 rounded-lg shadow-sm overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-gray-700 text-gray-400 text-xs uppercase tracking-wider bg-gray-800 bg-opacity-50">
                            <th class="p-4 w-10"><input type="checkbox" class="rounded bg-gray-900 border-gray-700 text-blue-500 focus:ring-blue-500 focus:ring-opacity-20 cursor-pointer"></th>
                            <th class="p-4 font-semibold">File Name</th>
                            <th class="p-4 font-semibold w-32 text-right">Size</th>
                            <th class="p-4 font-semibold w-48 text-right hidden md:table-cell">Date</th>
                            <th class="p-4 font-semibold w-16 text-center"></th>
                        </tr>
                    </thead>
                    <tbody class="text-sm">
                        <% if (parentId !== 'root') { %>
                            <tr class="border-b border-gray-700 hover:bg-gray-700 transition group">
                                <td class="p-4"></td>
                                <td class="p-4 flex items-center space-x-3">
                                    <i class="fa-solid fa-level-up-alt text-gray-500 w-5 text-center"></i>
                                    <a href="javascript:history.back()" class="text-gray-200 font-semibold group-hover:text-blue-400 transition w-full">..</a>
                                </td>
                                <td class="p-4 text-right text-gray-400"></td>
                                <td class="p-4 text-right text-gray-400 hidden md:table-cell"></td>
                                <td class="p-4"></td>
                            </tr>
                        <% } %>

                        <% items.forEach(item => { %>
                            <tr class="border-b border-gray-700 hover:bg-gray-700 hover:bg-opacity-50 transition group">
                                <td class="p-4"><input type="checkbox" class="rounded bg-gray-900 border-gray-700 text-blue-500 focus:ring-blue-500 focus:ring-opacity-20 cursor-pointer"></td>
                                <td class="p-4 flex items-center space-x-3">
                                    <% if (item.type === 'folder') { %>
                                        <i class="fa-solid fa-folder text-blue-400 text-lg w-5 text-center"></i>
                                        <a href="/?dir=<%= item.id %>&tab=storage" class="text-gray-200 font-semibold group-hover:text-blue-400 transition truncate"><%= item.name %></a>
                                    <% } else { %>
                                        <i class="fa-regular fa-file-lines text-gray-400 text-lg w-5 text-center"></i>
                                        <span class="text-gray-200 font-semibold truncate"><%= item.name %></span>
                                    <% } %>
                                </td>
                                <td class="p-4 text-right text-gray-400 whitespace-nowrap"><%= item.type === 'folder' ? '-' : formatBytes(item.size || 0) %></td>
                                <td class="p-4 text-right text-gray-400 hidden md:table-cell whitespace-nowrap"><%= formatDate(item.createdAt) %></td>
                                <td class="p-4 text-center">
                                    <div x-data="{ open: false }" class="relative inline-block text-left">
                                        <button @click="open = !open" @click.away="open = false" class="text-gray-400 hover:text-gray-100 transition px-2 py-1 rounded hover:bg-gray-600">
                                            <i class="fa-solid fa-ellipsis-vertical"></i>
                                        </button>
                                        <div x-show="open" x-transition x-cloak class="absolute right-0 mt-2 w-48 bg-gray-800 border border-gray-700 rounded shadow-xl z-50 overflow-hidden py-1">
                                            <% if (item.type === 'folder') { %>
                                                <form action="/zip/<%= item.id %>" method="POST">
                                                    <button type="submit" class="w-full text-left px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition"><i class="fa-solid fa-file-zipper mr-2 w-4 text-center"></i> Archive</button>
                                                </form>
                                            <% } else { %>
                                                <a href="/download/<%= item.id %>" class="block w-full text-left px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition"><i class="fa-solid fa-download mr-2 w-4 text-center"></i> Download</a>
                                                <% if (item.name.endsWith('.zip')) { %>
                                                    <form action="/unzip/<%= item.id %>" method="POST">
                                                        <button type="submit" class="w-full text-left px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition"><i class="fa-solid fa-box-open mr-2 w-4 text-center"></i> Unarchive</button>
                                                    </form>
                                                <% } %>
                                            <% } %>
                                            <div class="border-t border-gray-700 my-1"></div>
                                            <form action="/delete/<%= item.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this?');">
                                                <button type="submit" class="w-full text-left px-4 py-2 text-sm text-red-400 hover:bg-red-500 hover:bg-opacity-10 transition"><i class="fa-solid fa-trash mr-2 w-4 text-center"></i> Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (items.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-12 text-center text-gray-500">
                                    <i class="fa-regular fa-folder-open text-5xl mb-4 opacity-50 block"></i>
                                    <p class="text-sm font-medium">This directory is empty.</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div x-show="folderModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-70 backdrop-blur-sm">
            <div @click.away="folderModal = false" class="bg-gray-800 border border-gray-700 rounded-lg shadow-2xl w-full max-w-md p-6 transform transition-all">
                <h3 class="text-lg font-bold text-gray-100 mb-5">Create Directory</h3>
                <form action="/create-folder" method="POST">
                    <input type="hidden" name="parentId" value="<%= parentId %>">
                    <div class="mb-5">
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Name</label>
                        <input type="text" name="name" class="w-full bg-gray-900 border border-gray-700 text-gray-100 rounded px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition" required>
                    </div>
                    <div class="flex justify-end space-x-3">
                        <button type="button" @click="folderModal = false" class="px-4 py-2.5 text-sm font-semibold text-gray-400 hover:text-white transition">Cancel</button>
                        <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white px-5 py-2.5 rounded text-sm font-semibold shadow transition">Create</button>
                    </div>
                </form>
            </div>
        </div>

        <div x-show="fileModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-70 backdrop-blur-sm">
            <div @click.away="fileModal = false" class="bg-gray-800 border border-gray-700 rounded-lg shadow-2xl w-full max-w-md p-6 transform transition-all">
                <h3 class="text-lg font-bold text-gray-100 mb-5">New File</h3>
                <form action="/create-file" method="POST">
                    <input type="hidden" name="parentId" value="<%= parentId %>">
                    <input type="hidden" name="content" value="">
                    <div class="mb-5">
                        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">File Name</label>
                        <input type="text" name="name" class="w-full bg-gray-900 border border-gray-700 text-gray-100 rounded px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition" placeholder="newfile.txt" required>
                    </div>
                    <div class="flex justify-end space-x-3">
                        <button type="button" @click="fileModal = false" class="px-4 py-2.5 text-sm font-semibold text-gray-400 hover:text-white transition">Cancel</button>
                        <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white px-5 py-2.5 rounded text-sm font-semibold shadow transition">Create File</button>
                    </div>
                </form>
            </div>
        </div>

        <div x-show="uploadModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-70 backdrop-blur-sm">
            <div @click.away="uploadModal = false" class="bg-gray-800 border border-gray-700 rounded-lg shadow-2xl w-full max-w-md p-6 transform transition-all">
                <h3 class="text-lg font-bold text-gray-100 mb-5">Upload File</h3>
                <form action="/upload" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="parentId" value="<%= parentId %>">
                    <div class="mb-5">
                        <div class="flex items-center justify-center w-full">
                            <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-700 border-dashed rounded-lg cursor-pointer bg-gray-900 hover:border-blue-500 hover:bg-gray-800 transition">
                                <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                    <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-500 mb-2"></i>
                                    <p class="text-sm text-gray-400"><span class="font-semibold text-blue-500">Click to upload</span> or drag and drop</p>
                                </div>
                                <input type="file" name="file" class="hidden" required onchange="document.getElementById('file-name-display').innerText = this.files[0].name">
                            </label>
                        </div>
                        <p id="file-name-display" class="mt-2 text-center text-sm text-gray-300 font-medium truncate"></p>
                    </div>
                    <div class="flex justify-end space-x-3">
                        <button type="button" @click="uploadModal = false; document.getElementById('file-name-display').innerText = ''" class="px-4 py-2.5 text-sm font-semibold text-gray-400 hover:text-white transition">Cancel</button>
                        <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white px-5 py-2.5 rounded text-sm font-semibold shadow transition">Upload</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

</body>
</html>
