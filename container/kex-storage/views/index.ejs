<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Telegram Cloud Storage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .icon { font-size: 1.5rem; margin-right: 10px; }
        .list-group-item { display: flex; align-items: center; justify-content: space-between; }
        .item-name { display: flex; align-items: center; text-decoration: none; color: inherit; font-weight: 500; }
        .item-name:hover { color: #0d6efd; }
    </style>
</head>
<body class="bg-light">

<div class="container mt-5">
    <h2 class="mb-4">☁️ Telegram Cloud VFS</h2>

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb fs-5">
            <li class="breadcrumb-item"><a href="/?dir=root">Home</a></li>
            <% breadcrumbs.forEach(crumb => { %>
                <li class="breadcrumb-item"><a href="/?dir=<%= crumb.id %>"><%= crumb.name %></a></li>
            <% }) %>
        </ol>
    </nav>

    <div class="card p-3 mb-4 shadow-sm">
        <div class="row g-3">
            <div class="col-md-4">
                <form action="/upload" method="POST" enctype="multipart/form-data" class="d-flex">
                    <input type="hidden" name="parentId" value="<%= parentId %>">
                    <input type="file" name="file" class="form-control form-control-sm me-2" required>
                    <button type="submit" class="btn btn-primary btn-sm">Upload</button>
                </form>
            </div>
            <div class="col-md-4">
                <form action="/create-folder" method="POST" class="d-flex">
                    <input type="hidden" name="parentId" value="<%= parentId %>">
                    <input type="text" name="name" class="form-control form-control-sm me-2" placeholder="Folder Name" required>
                    <button type="submit" class="btn btn-success btn-sm">New Folder</button>
                </form>
            </div>
            <div class="col-md-4">
                <form action="/create-file" method="POST" class="d-flex">
                    <input type="hidden" name="parentId" value="<%= parentId %>">
                    <input type="text" name="name" class="form-control form-control-sm me-2" placeholder="File Name (.txt)" required>
                    <input type="hidden" name="content" value="Empty text file created from cloud.">
                    <button type="submit" class="btn btn-secondary btn-sm">New File</button>
                </form>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <ul class="list-group list-group-flush">
            <% if (parentId !== 'root') { %>
                <li class="list-group-item bg-light">
                    <a href="javascript:history.back()" class="item-name">
                        <span class="icon">🔙</span> ..
                    </a>
                </li>
            <% } %>

            <% items.forEach(item => { %>
                <li class="list-group-item">
                    <% if (item.type === 'folder') { %>
                        <a href="/?dir=<%= item.id %>" class="item-name">
                            <span class="icon">📁</span> <%= item.name %>
                        </a>
                        <div>
                            <form action="/zip/<%= item.id %>" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-dark">Zip Folder</button>
                            </form>
                        </div>
                    <% } else { %>
                        <div class="item-name">
                            <span class="icon"><%= item.name.endsWith('.zip') ? '🗜️' : '📄' %></span> <%= item.name %>
                        </div>
                        <div>
                            <a href="/download/<%= item.id %>" class="btn btn-sm btn-outline-primary">Download</a>
                            <% if (item.name.endsWith('.zip')) { %>
                                <form action="/unzip/<%= item.id %>" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Unzip</button>
                                </form>
                            <% } %>
                        </div>
                    <% } %>
                </li>
            <% }) %>

            <% if (items.length === 0) { %>
                <li class="list-group-item text-muted justify-content-center py-4">
                    This folder is empty. Upload or create something!
                </li>
            <% } %>
        </ul>
    </div>
</div>

</body>
</html>
