<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kex Storage | Cloud Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-dark: #0f1113;
            --card-bg: #1a1d21;
            --sidebar-bg: #131619;
            --input-bg: #22262b;
            --text-main: #f8f9fa;
            --text-muted: #94a3b8;
            --emerald: #10b981;
            --emerald-glow: rgba(16, 185, 129, 0.15);
            --border-color: rgba(255, 255, 255, 0.06);
            --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Plus Jakarta Sans', sans-serif;
            letter-spacing: -0.01em;
            min-height: 100vh;
        }

        /* Navbar & Brand */
        .navbar-top {
            background-color: rgba(19, 22, 25, 0.8);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            height: 70px;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .brand-logo {
            font-size: 1.25rem;
            font-weight: 700;
            background: linear-gradient(135deg, #fff 0%, var(--emerald) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Sidebar / Offcanvas */
        .offcanvas {
            background-color: var(--sidebar-bg);
            border-left: 1px solid var(--border-color); /* Changed to right-side for ergonomic burger */
            width: 300px !important;
        }

        @media (max-width: 576px) { .offcanvas { width: 85% !important; } }

        .nav-link-custom {
            color: var(--text-muted);
            padding: 12px 18px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            transition: var(--transition);
            margin-bottom: 4px;
        }

        .nav-link-custom:hover {
            color: var(--text-main);
            background: var(--input-bg);
        }

        .nav-link-custom.active {
            color: #fff;
            background: var(--emerald);
            box-shadow: 0 4px 12px var(--emerald-glow);
        }

        /* Stats Cards */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 24px;
            transition: var(--transition);
        }
        .stat-card:hover {
            transform: translateY(-5px);
            border-color: var(--emerald);
        }

        /* Breadcrumbs */
        .breadcrumb { background: transparent; padding: 0; margin-bottom: 0; }
        .breadcrumb-item a { color: var(--emerald); text-decoration: none; font-weight: 500; }
        .breadcrumb-item.active { color: var(--text-muted); }
        .breadcrumb-item + .breadcrumb-item::before { color: var(--text-muted); content: "→"; }

        /* Tables */
        .table-container {
            background: var(--card-bg);
            border-radius: 16px;
            border: 1px solid var(--border-color);
            overflow: hidden;
        }

        .table { margin-bottom: 0; color: var(--text-main); }
        .table thead th {
            background: rgba(255,255,255,0.02);
            color: var(--text-muted);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .table tbody td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            background: transparent !important;
        }

        .table tbody tr:hover td {
            background: rgba(255,255,255,0.03) !important;
        }

        /* Action Buttons */
        .btn-action {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: var(--input-bg);
            color: var(--text-muted);
            border: none;
            transition: var(--transition);
        }

        .btn-action:hover {
            background: var(--emerald);
            color: white;
            transform: scale(1.1);
        }

        .btn-action.delete:hover { background: #ef4444; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-dark); }
        ::-webkit-scrollbar-thumb { background: var(--input-bg); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

        /* Modals */
        .modal-content {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
        }
        .form-control {
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            color: white;
            border-radius: 10px;
            padding: 12px;
        }
        .form-control:focus {
            background: var(--input-bg);
            box-shadow: 0 0 0 3px var(--emerald-glow);
            border-color: var(--emerald);
            color: white;
        }

        .btn-primary {
            background: var(--emerald);
            border: none;
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 600;
        }
    </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-top px-4 d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <div class="brand-logo me-2">
            <i class="fas fa-layer-group me-2"></i>Kex Storage
        </div>
    </div>
    <button class="btn-action" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
        <i class="fas fa-bars"></i>
    </button>
</nav>

<!-- Sidebar (Right side for mobile convenience) -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="sidebarMenu">
    <div class="offcanvas-header border-bottom border-secondary">
        <h5 class="offcanvas-title fw-bold text-white">Menu</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-4">
        <div class="d-flex flex-column gap-2">
            <a href="/dash" class="nav-link-custom <%= page === 'dash' ? 'active' : '' %>">
                <i class="fas fa-chart-pie"></i> Dashboard
            </a>
            <a href="/files" class="nav-link-custom <%= page === 'files' ? 'active' : '' %>">
                <i class="fas fa-folder-tree"></i> File Manager
            </a>
            <hr class="my-3 opacity-10">
            <a href="/settings" class="nav-link-custom">
                <i class="fas fa-cog"></i> Settings
            </a>
        </div>
    </div>
</div>

<div class="container py-5">
    <% if (page === 'dash') { %>
        <div class="mb-5">
            <h2 class="fw-bold mb-1">System Overview</h2>
            <p class="text-muted">Monitor your cloud storage usage and assets.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="p-3 bg-primary bg-opacity-10 rounded-3">
                            <i class="fas fa-database text-emerald"></i>
                        </div>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Capacity Used</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.totalSize %></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="p-3 bg-primary bg-opacity-10 rounded-3">
                            <i class="fas fa-file-code text-emerald"></i>
                        </div>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Total Files</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.fileCount %></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="p-3 bg-primary bg-opacity-10 rounded-3">
                            <i class="fas fa-folder-open text-emerald"></i>
                        </div>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Total Folders</h6>
                    <h3 class="mb-0 fw-bold"><%= stats.folderCount %></h3>
                </div>
            </div>
        </div>
    <% } else if (page === 'files') { %>
        <div class="d-flex flex-wrap justify-content-between align-items-end mb-4 gap-3">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a href="/files?dir=root">Root</a></li>
                        <% breadcrumbs.forEach(crumb => { %>
                            <li class="breadcrumb-item"><a href="/files?dir=<%= crumb.id %>"><%= crumb.name %></a></li>
                        <% }) %>
                    </ol>
                </nav>
                <h3 class="fw-bold m-0">Files</h3>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-cloud-arrow-up me-2"></i>Upload
                </button>
                <div class="dropdown">
                    <button class="btn btn-dark border btn-sm" data-bs-toggle="dropdown">
                        <i class="fas fa-plus"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow">
                        <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#folderModal"><i class="fas fa-folder-plus me-2"></i>New Folder</a></li>
                        <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#fileModal"><i class="fas fa-file-circle-plus me-2"></i>New Text File</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="table-container shadow">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Size</th>
                            <th>Type</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Glitch Fix: Proper parent navigation instead of history.back -->
                        <% if (parentId !== 'root') { %>
                        <tr>
                            <td colspan="4">
                                <a href="/files?dir=<%= parentFolderId || 'root' %>" class="text-decoration-none text-muted d-flex align-items-center">
                                    <i class="fas fa-arrow-turn-up me-3 opacity-50"></i> Go Up One Level
                                </a>
                            </td>
                        </tr>
                        <% } %>

                        <% items.forEach(item => { %>
                        <tr>
                            <td>
                                <% if (item.type === 'folder') { %>
                                    <a href="/files?dir=<%= item.id %>" class="text-decoration-none text-white d-flex align-items-center fw-semibold">
                                        <i class="fas fa-folder me-3 text-emerald shadow-sm"></i> <%= item.name %>
                                    </a>
                                <% } else { %>
                                    <div class="d-flex align-items-center text-white-50">
                                        <i class="fas <%= item.name.endsWith('.zip') ? 'fa-file-zipper text-warning' : 'fa-file-lines' %> me-3"></i> 
                                        <span class="text-white"><%= item.name %></span>
                                    </div>
                                <% } %>
                            </td>
                            <td class="text-muted small"><%= item.type === 'folder' ? '--' : formatBytes(item.size) %></td>
                            <td><span class="badge bg-secondary bg-opacity-25 text-muted fw-normal"><%= item.type === 'folder' ? 'Folder' : 'File' %></span></td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1">
                                    <% if (item.type === 'folder') { %>
                                        <form action="/zip/<%= item.id %>" method="POST" class="d-inline">
                                            <button type="submit" class="btn-action" title="Zip"><i class="fas fa-box-archive"></i></button>
                                        </form>
                                    <% } else { %>
                                        <button class="btn-action" onclick="downloadFile('<%= item.id %>', '<%= item.name %>')" title="Download">
                                            <i class="fas fa-download"></i>
                                        </button>
                                        <% if (item.name.endsWith('.zip')) { %>
                                            <form action="/unzip/<%= item.id %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn-action" title="Unzip"><i class="fas fa-file-export"></i></button>
                                            </form>
                                        <% } %>
                                    <% } %>
                                    <form action="/delete/<%= item.id %>" method="POST" class="d-inline" onsubmit="return confirm('Permanently delete this item?')">
                                        <button type="submit" class="btn-action delete" title="Delete"><i class="fas fa-trash-alt"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>

                        <% if (items.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fas fa-ghost fa-3x mb-3 opacity-10"></i>
                                <p>No files found in this directory.</p>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    <% } %>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form id="uploadForm" class="modal-content shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Upload to Cloud</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <input type="hidden" name="parentId" value="<%= typeof parentId !== 'undefined' ? parentId : 'root' %>">
                <div class="upload-area p-4 text-center border border-dashed rounded-4 mb-3" style="border-style: dashed !important; border-color: var(--border-color) !important;">
                    <i class="fas fa-cloud-upload-alt fa-3x text-emerald mb-3"></i>
                    <input type="file" name="file" id="fileInput" class="form-control" required>
                </div>
                
                <div id="uploadProgressUI" style="display: none;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small">Uploading...</span>
                        <span id="uploadETA" class="small text-emerald fw-bold">0%</span>
                    </div>
                    <div class="progress" style="height: 6px; background: var(--input-bg);">
                        <div id="uploadProgressBar" class="progress-bar bg-emerald" style="width: 0%;"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="submit" id="uploadSubmitBtn" class="btn btn-primary w-100">Start Upload</button>
            </div>
        </form>
    </div>
</div>

<!-- Fixed Download Progress Container -->
<div id="downloadProgressContainer" class="position-fixed bottom-0 end-0 p-4" style="z-index: 2000; display: none;">
    <div class="toast show border-0 bg-dark shadow-lg rounded-4" style="width: 320px;">
        <div class="toast-body p-3">
            <div class="d-flex align-items-center mb-3">
                <div class="spinner-border spinner-border-sm text-emerald me-2"></div>
                <div class="fw-bold small text-truncate" id="downloadFileName">File</div>
            </div>
            <div class="progress mb-2" style="height: 6px; background: #222;">
                <div id="downloadProgressBar" class="progress-bar bg-emerald progress-bar-striped progress-bar-animated" style="width: 0%"></div>
            </div>
            <div id="downloadProgressText" class="x-small text-muted" style="font-size: 0.75rem;">0% - Calculating...</div>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function formatTime(seconds) {
        if (!Number.isFinite(seconds) || seconds < 0) return '...';
        if (seconds < 60) return Math.round(seconds) + 's';
        return Math.floor(seconds/60) + 'm ' + Math.round(seconds%60) + 's';
    }

    // Modern Upload Logic
    const uploadForm = document.getElementById('uploadForm');
    if (uploadForm) {
        uploadForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const xhr = new XMLHttpRequest();
            
            document.getElementById('uploadSubmitBtn').disabled = true;
            document.getElementById('uploadProgressUI').style.display = 'block';
            
            let startTime = Date.now();
            xhr.upload.addEventListener("progress", (evt) => {
                if (evt.lengthComputable) {
                    let percent = (evt.loaded / evt.total) * 100;
                    document.getElementById('uploadProgressBar').style.width = percent + '%';
                    
                    let elapsed = (Date.now() - startTime) / 1000;
                    let speed = evt.loaded / elapsed;
                    let remaining = (evt.total - evt.loaded) / speed;
                    document.getElementById('uploadETA').innerText = `${Math.round(percent)}% (ETA: ${formatTime(remaining)})`;
                }
            });

            xhr.onload = () => window.location.reload();
            xhr.open("POST", "/upload");
            xhr.send(formData);
        });
    }

    // Improved Download Logic
    // NOTE: For very large files (>500MB), downloading via Blob (XHR) can crash the browser.
    // This script works for most files, but for massive ones, a direct <a> link is safer.
    function downloadFile(id, fileName) {
        const ui = document.getElementById('downloadProgressContainer');
        ui.style.display = 'block';
        document.getElementById('downloadFileName').innerText = fileName;
        
        const xhr = new XMLHttpRequest();
        xhr.open('GET', '/download/' + id, true);
        xhr.responseType = 'blob'; 
        let startTime = Date.now();

        xhr.onprogress = (evt) => {
            if (evt.lengthComputable) {
                let percent = (evt.loaded / evt.total) * 100;
                document.getElementById('downloadProgressBar').style.width = percent + '%';
                let elapsed = (Date.now() - startTime) / 1000;
                let speed = evt.loaded / elapsed;
                let remaining = (evt.total - evt.loaded) / speed;
                document.getElementById('downloadProgressText').innerText = 
                    `${Math.round(percent)}% - ETA: ${formatTime(remaining)}`;
            }
        };

        xhr.onload = () => {
            if (xhr.status === 200) {
                const blob = xhr.response;
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.getElementById('downloadProgressText').innerText = 'Complete!';
                setTimeout(() => ui.style.display = 'none', 3000);
            }
        };
        xhr.send();
    }
</script>
</body>
</html>
