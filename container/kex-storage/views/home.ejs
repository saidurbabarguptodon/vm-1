<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeronotics | Console</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg: #08090a;
            --sidebar: #0e1013;
            --card: #121417;
            --emerald: #10b981;
            --text: #ffffff;
            --muted: #94a3b8;
            --border: rgba(255, 255, 255, 0.08);
        }
        body { background: var(--bg); color: var(--text); font-family: 'Plus Jakarta Sans', sans-serif; }
        .nav-top { height: 75px; background: rgba(8, 9, 10, 0.85); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); padding: 0 25px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 1000; }
        .brand { font-size: 1.3rem; font-weight: 800; color: var(--emerald); text-decoration: none; }
        .offcanvas { background: var(--sidebar); border-right: 1px solid var(--border); width: 280px !important; }
        .nav-link-custom { display: flex; align-items: center; gap: 12px; padding: 14px 18px; color: var(--muted); text-decoration: none; border-radius: 12px; margin-bottom: 5px; font-weight: 600; }
        .nav-link-custom:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .nav-link-custom.active { background: var(--emerald); color: #fff; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.25); }
        .content-card { background: var(--card); border: 1px solid var(--border); border-radius: 24px; padding: 35px; margin-top: 20px; }
        .info-label { font-size: 0.75rem; color: var(--muted); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
        .info-value { font-size: 1.1rem; font-weight: 600; color: #fff; margin-bottom: 20px; }
        .btn-hamburger { width: 45px; height: 45px; border-radius: 12px; border: 1px solid var(--border); background: #1a1d21; color: #fff; display: flex; align-items: center; justify-content: center; }
    </style>
</head>
<body>

<header class="nav-top">
    <a href="/" class="brand"><i class="fas fa-rocket me-2"></i>Aeronotics</a>
    <button class="btn-hamburger" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
        <i class="fas fa-bars-staggered"></i>
    </button>
</header>

<div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarMenu">
    <div class="offcanvas-header p-4 border-bottom border-secondary">
        <h5 class="offcanvas-title fw-bold">Console Menu</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-3">
        <a href="/?view=overview" class="nav-link-custom <%= view === 'overview' ? 'active' : '' %>">
            <i class="fas fa-th-large"></i> Overview
        </a>
        <a href="/?view=settings" class="nav-link-custom <%= view === 'settings' ? 'active' : '' %>">
            <i class="fas fa-cog"></i> Settings
        </a>
        <a href="/auth/logout" class="nav-link-custom text-danger mt-4">
            <i class="fas fa-sign-out-alt"></i> Sign Out
        </a>
    </div>
</div>

<div class="container py-4">
    <% if (view === 'overview') { %>
        <h2 class="fw-bold">System Overview</h2>
        <p class="text-muted">Status and analytics for your active storage instance.</p>
        <div class="content-card">
            <div class="d-flex align-items-center gap-4">
                <i class="fas fa-circle-check text-emerald" style="font-size: 2.5rem;"></i>
                <div>
                    <h5 class="fw-bold mb-1">Operational</h5>
                    <p class="text-muted m-0">Storage node is connected and protocols are healthy.</p>
                </div>
            </div>
        </div>
    <% } else if (view === 'settings') { %>
        <h2 class="fw-bold">Settings</h2>
        <p class="text-muted">Account information and security details.</p>
        <div class="content-card">
            <div class="info-label">Current Identity</div>
            <div class="info-value"><%= user.email %></div>
            <div class="info-label">Console UID</div>
            <div class="info-value small font-monospace" style="color: var(--emerald)"><%= user.id %></div>
            <div class="info-label">Session Established</div>
            <div class="info-value"><%= new Date(user.last_sign_in_at).toLocaleString() %></div>
            <button class="btn btn-outline-danger btn-sm mt-2" onclick="location.href='/auth/logout'">Destroy Session</button>
        </div>
    <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
