<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeronotics | Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --bg-dark: #0b0d0f; --card: #16191d; --sidebar: #0f1216; --text-muted: #cbd5e1; --emerald: #10b981; --border: rgba(255, 255, 255, 0.1); }
        body { background-color: var(--bg-dark); color: #fff; font-family: 'Plus Jakarta Sans', sans-serif; }
        .navbar-top { background: rgba(15, 18, 22, 0.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); height: 70px; padding: 0 1.5rem; }
        .brand-logo { font-size: 1.3rem; font-weight: 700; color: var(--emerald); text-decoration: none; }
        .offcanvas { background-color: var(--sidebar); border-right: 1px solid var(--border); width: 280px !important; }
        .nav-link-custom { color: var(--text-muted); padding: 12px 16px; border-radius: 10px; display: flex; align-items: center; gap: 12px; text-decoration: none; margin-bottom: 5px; font-weight: 500; }
        .nav-link-custom:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .nav-link-custom.active { background: var(--emerald); color: #fff; }
        .settings-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 24px; }
        .btn-action { width: 34px; height: 34px; border-radius: 8px; background: #1e2329; color: var(--text-muted); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; }
    </style>
</head>
<body>

<!-- Header -->
<nav class="navbar navbar-top d-flex justify-content-between align-items-center">
    <a href="/" class="brand-logo"><i class="fas fa-rocket me-2"></i>Aeronotics</a>
    <button class="btn-action border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
        <i class="fas fa-bars fa-lg"></i>
    </button>
</nav>

<!-- Hamburger Menu (Sidebar) -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarMenu">
    <div class="offcanvas-header border-bottom border-secondary">
        <h5 class="offcanvas-title fw-bold text-white">Menu</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-3">
        <div class="small text-muted text-uppercase fw-bold mb-2 ps-2" style="letter-spacing: 1px; font-size: 0.7rem;">Main</div>
        <a href="/?view=overview" class="nav-link-custom <%= view === 'overview' ? 'active' : '' %>">
            <i class="fas fa-th-large"></i> Overview
        </a>
        
        <div class="small text-muted text-uppercase fw-bold mt-4 mb-2 ps-2" style="letter-spacing: 1px; font-size: 0.7rem;">Account</div>
        <a href="/?view=settings" class="nav-link-custom <%= view === 'settings' ? 'active' : '' %>">
            <i class="fas fa-cog"></i> Settings
        </a>
        <a href="/auth/logout" class="nav-link-custom text-danger">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </div>
</div>

<!-- Main Content -->
<div class="container py-5">
    <% if (view === 'overview') { %>
        <h2 class="fw-bold">System Overview</h2>
        <p class="text-muted">Welcome back to your aeronautics dashboard.</p>
        <div class="row mt-4">
            <div class="col-md-4">
                <div class="settings-card text-center">
                    <i class="fas fa-shield-alt fa-3x text-emerald mb-3"></i>
                    <h5>Secure Session</h5>
                    <p class="small text-muted m-0">Your account is currently protected by Supabase Auth.</p>
                </div>
            </div>
        </div>

    <% } else if (view === 'settings') { %>
        <h2 class="fw-bold">Settings</h2>
        <p class="text-muted">Manage your profile and account preferences.</p>
        
        <div class="settings-card mt-4">
            <h5 class="fw-bold mb-4"><i class="fas fa-user-circle me-2 text-emerald"></i> User Information</h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="small text-muted d-block">Email Address</label>
                    <div class="fw-bold"><%= user.email %></div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="small text-muted d-block">User ID</label>
                    <div class="fw-bold small text-truncate"><%= user.id %></div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="small text-muted d-block">Last Sign In</label>
                    <div class="fw-bold small"><%= new Date(user.last_sign_in_at).toLocaleString() %></div>
                </div>
            </div>
            <hr class="border-secondary my-4">
            <button class="btn btn-outline-danger btn-sm" onclick="location.href='/auth/logout'">Sign Out from all devices</button>
        </div>
    <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
