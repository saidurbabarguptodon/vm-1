<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aeronotics | Home</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --bg: #0b0d0f; --card: #16191d; --sidebar: #0f1216; --text-muted: #cbd5e1; --emerald: #10b981; --border: rgba(255,255,255,0.1); }
        body { background: var(--bg); color: #fff; font-family: 'Plus Jakarta Sans', sans-serif; }
        .navbar-top { background: rgba(15,18,22,0.9); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); height: 70px; padding: 0 1.5rem; }
        .brand-logo { font-size: 1.3rem; font-weight: 700; color: var(--emerald); text-decoration: none; }
        .offcanvas { background-color: var(--sidebar); border-right: 1px solid var(--border); width: 280px !important; }
        .nav-link-custom { color: var(--text-muted); padding: 12px 16px; border-radius: 10px; display: flex; align-items: center; gap: 12px; text-decoration: none; margin-bottom: 5px; }
        .nav-link-custom:hover, .nav-link-custom.active { background: var(--emerald); color: #fff; }
        .data-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 24px; }
        .btn-action { width: 40px; height: 40px; background: #1e2329; color: #fff; border: 1px solid var(--border); border-radius: 8px; display: flex; align-items: center; justify-content: center; cursor: pointer; }
    </style>
</head>
<body>

<nav class="navbar navbar-top d-flex justify-content-between align-items-center">
    <a href="/" class="brand-logo"><i class="fas fa-rocket me-2"></i>Aeronotics</a>
    <button class="btn-action border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
        <i class="fas fa-bars"></i>
    </button>
</nav>

<div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarMenu">
    <div class="offcanvas-header border-bottom border-secondary">
        <h5 class="offcanvas-title fw-bold">Aeronotics Menu</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-3">
        <div class="text-muted small fw-bold mb-2">GENERAL</div>
        <a href="/?view=overview" class="nav-link-custom <%= view === 'overview' ? 'active' : '' %>">
            <i class="fas fa-th-large"></i> Overview
        </a>
        <div class="text-muted small fw-bold mt-4 mb-2">ACCOUNT</div>
        <a href="/?view=settings" class="nav-link-custom <%= view === 'settings' ? 'active' : '' %>">
            <i class="fas fa-user-gear"></i> User Settings
        </a>
        <a href="/auth/logout" class="nav-link-custom text-danger">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </div>
</div>

<div class="container py-5">
    <% if (view === 'overview') { %>
        <h2 class="fw-bold mb-4">Overview</h2>
        <div class="data-card">
            <h5>System Status</h5>
            <p class="text-muted">Welcome to your storage dashboard. Everything is running smoothly.</p>
        </div>
    <% } else if (view === 'settings') { %>
        <h2 class="fw-bold mb-4">Settings</h2>
        <div class="data-card">
            <h5 class="text-emerald mb-3">User Profile</h5>
            <p class="mb-1 text-muted small">Email Address</p>
            <p class="fw-bold"><%= user.email %></p>
            <p class="mb-1 text-muted small">Account ID</p>
            <p class="fw-bold small text-truncate"><%= user.id %></p>
            <p class="mb-1 text-muted small">Last Login</p>
            <p class="fw-bold"><%= new Date(user.last_sign_in_at).toLocaleString() %></p>
        </div>
    <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
